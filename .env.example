# Environment Variables - Copy to .env.local and fill with your values

# JWT Secret for token signing (min 32 chars, use a random string)
JWT_SECRET=replace-with-a-very-long-random-secret-value

# Database
DATABASE_URL=./kampus_cadilari.db

# Node Environment
NODE_ENV=production

# Admin Users (one email per line, they will have admin access)
ADMIN_EMAILS=admin@kampuscadilari.org

# Optional local admin seed passwords (never commit real passwords)
ADMIN_DEFAULT_PASSWORD=
TEST_ADMIN_PASSWORD=

# Email Configuration (optional, for future email features)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@example.com

# External Auth (optional, for future OAuth integration)
GITHUB_CLIENT_ID=your-github-app-id
GITHUB_CLIENT_SECRET=your-github-app-secret
GOOGLE_CLIENT_ID=your-google-app-id
GOOGLE_CLIENT_SECRET=your-google-app-secret

# Base URL
BASE_URL=https://example.com
PUBLIC_BASE_URL=https://example.com
