---
import { getArticleById, getArticleBySlug } from '../../../utils/db.js';
import { getCategorySlug } from '../../../utils/articleCategories';

export const prerender = false;

const rawId = String(Astro.params.id || '').trim();
let article = null;

if (/^\d+$/.test(rawId)) {
  const candidate = getArticleById(Number(rawId));
  if (candidate && candidate.status === 'published') {
    article = candidate;
  }
} else if (rawId) {
  article = getArticleBySlug(rawId, { publishedOnly: true });
}

if (!article) {
  return Astro.redirect('/en/articles');
}

const categorySlug = getCategorySlug(article.category || 'Gundem ve Politika');
return Astro.redirect(`/en/articles/${categorySlug}/${article.slug}`);
---
