---
import MainLayout from '../../layouts/MainLayout.astro';
import { getApprovedArchiveEntries } from '../../utils/db.js';
import { toEnglishArchiveItem } from '../../utils/contentI18n.js';

const allApproved = getApprovedArchiveEntries().map((item) => toEnglishArchiveItem(item));
const initialItems = allApproved.slice(0, 12);
const decades = [...new Set(allApproved.map((item) => item.decade).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'en'));
const focusTopics = [...new Set(allApproved.map((item) => item.focus_topic).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'en'));
---

<MainLayout title="Archive - Campus Witches" description="Admin-approved feminist newspaper archive" currentLang="en">
  <section class="relative overflow-hidden rounded-[2rem] border border-[#5b2c84]/20 bg-gradient-to-br from-[#4b1f6f] via-[#5b2c84] to-[#2f264d] px-6 py-12 text-white shadow-2xl md:px-10 md:py-14">
    <div class="absolute -left-16 top-0 h-44 w-44 rounded-full bg-amber-200/15 blur-3xl"></div>
    <div class="absolute -bottom-10 right-0 h-56 w-56 rounded-full bg-fuchsia-100/10 blur-3xl"></div>
    <div class="relative max-w-4xl">
      <p class="inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs font-bold uppercase tracking-[0.18em]">Archive Section</p>
      <h1 class="app-h1 mt-4 text-4xl font-black leading-tight md:text-5xl">Feminist Newspaper Archive</h1>
      <p class="mt-4 max-w-3xl text-base leading-8 text-white/95 md:text-lg">
        We list admin-approved feminist newspaper records in a curated and research-friendly flow.
      </p>
    </div>
  </section>

  <section class="mt-8 rounded-[1.5rem] border border-[#d7c8b2] bg-[#f6f0e4] p-5 shadow-sm">
    <div class="grid gap-4 md:grid-cols-3">
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Filter by decade
        <select id="archive-decade" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none">
          <option value="all">All decades</option>
          {decades.map((decade) => <option value={decade}>{decade}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Focus topic
        <select id="archive-focus" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none">
          <option value="all">All topics</option>
          {focusTopics.map((topic) => <option value={topic}>{topic}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Search archive
        <input id="archive-search" type="search" placeholder="Publication, topic, year..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
    </div>
  </section>

  <section class="mt-8">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-2xl font-black text-slate-900">Admin Approved Records</h2>
      <p id="archive-count" class="text-sm font-semibold text-slate-600">{initialItems.length} records shown</p>
    </div>

    <div id="archive-list" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {initialItems.map((item) => (
        <article class="group relative overflow-hidden rounded-[1.4rem] border border-[#d5c6ac] bg-[#fdf8ef] shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl">
          <div class="relative">
            <img src={item.cover_image_url || '/archive/placeholder-cover.svg'} alt={`${item.publication_name} cover`} class="h-56 w-full object-cover" loading="lazy" />
            <div class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full border border-amber-300/70 bg-amber-100/95 px-3 py-1 text-xs font-bold text-amber-900">
              <span>OK</span>
              <span>Admin Approved</span>
            </div>
          </div>

          <div class="p-5">
            <p class="text-xs font-bold uppercase tracking-wide text-[#5b2c84]">{item.decade} - {item.publication_year}</p>
            <h3 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-700">{item.publication_name}</p>
            <p class="mt-2 line-clamp-2 text-sm text-slate-600">Focus: {item.focus_topic || 'General feminist agenda'}</p>

            <div class="mt-4 grid grid-cols-3 gap-2 text-xs font-bold">
              <a href={`/en/archive/${item.id}`} class="rounded-lg bg-[#5b2c84] px-2 py-2 text-center text-white transition hover:bg-[#4a236c]">Details</a>
              <a href={item.pdf_url || '#'} download class={`rounded-lg border px-2 py-2 text-center transition ${item.pdf_url ? 'border-[#5b2c84] text-[#5b2c84] hover:bg-[#efe5f7]' : 'pointer-events-none border-slate-300 text-slate-400'}`}>PDF</a>
              <button data-link={`/en/archive/${item.id}`} class="archive-copy-btn rounded-lg border border-amber-400 bg-amber-50 px-2 py-2 text-amber-900 transition hover:bg-amber-100">Copy Link</button>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mt-10 rounded-[1.6rem] border border-[#d5c6ac] bg-[#fdf8ef] p-6 shadow-sm md:p-8">
    <div class="mb-5">
      <h2 class="text-2xl font-black text-slate-900">Suggest a Newspaper Record</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Submitted records enter admin review first. They are published to the archive once all active admin approvals are complete.
      </p>
    </div>

    <form id="archive-submit-form" class="grid gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Publication name
        <input name="publication_name" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Issue title
        <input name="title" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Publication year
        <input name="publication_year" type="number" min="1800" max="2100" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Focus topic
        <input name="focus_topic" placeholder="Voting rights, labor rights..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 md:col-span-2">
        Short summary
        <textarea name="summary" rows="3" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none"></textarea>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Cover image URL
        <input name="cover_image_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        PDF URL
        <input name="pdf_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Source URL
        <input name="source_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Submitted by
        <input name="submitted_by" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Email
        <input name="submitted_email" type="email" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <div class="md:col-span-2">
        <button id="archive-submit-btn" type="submit" class="rounded-xl bg-[#5b2c84] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#4a236c]">Send to Review</button>
        <p id="archive-submit-feedback" class="mt-2 text-sm font-semibold text-slate-600"></p>
      </div>
    </form>
  </section>

  <script>
    const decadeSelect = document.getElementById('archive-decade');
    const focusSelect = document.getElementById('archive-focus');
    const searchInput = document.getElementById('archive-search');
    const listEl = document.getElementById('archive-list');
    const countEl = document.getElementById('archive-count');
    const submitForm = document.getElementById('archive-submit-form');
    const submitButton = document.getElementById('archive-submit-btn');
    const submitFeedback = document.getElementById('archive-submit-feedback');

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function cardTemplate(item) {
      const cover = item.cover_image_url || '/archive/placeholder-cover.svg';
      const pdfClass = item.pdf_url
        ? 'border-[#5b2c84] text-[#5b2c84] hover:bg-[#efe5f7]'
        : 'pointer-events-none border-slate-300 text-slate-400';
      const pdfUrl = item.pdf_url || '#';

      return `
        <article class="group relative overflow-hidden rounded-[1.4rem] border border-[#d5c6ac] bg-[#fdf8ef] shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl">
          <div class="relative">
            <img src="${escapeHtml(cover)}" alt="${escapeHtml(item.publication_name)} cover" class="h-56 w-full object-cover" loading="lazy" />
            <div class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full border border-amber-300/70 bg-amber-100/95 px-3 py-1 text-xs font-bold text-amber-900">
              <span>OK</span>
              <span>Admin Approved</span>
            </div>
          </div>

          <div class="p-5">
            <p class="text-xs font-bold uppercase tracking-wide text-[#5b2c84]">${escapeHtml(item.decade || '')} - ${escapeHtml(item.publication_year || '')}</p>
            <h3 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">${escapeHtml(item.title)}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-700">${escapeHtml(item.publication_name)}</p>
            <p class="mt-2 line-clamp-2 text-sm text-slate-600">Focus: ${escapeHtml(item.focus_topic || 'General feminist agenda')}</p>

            <div class="mt-4 grid grid-cols-3 gap-2 text-xs font-bold">
              <a href="/en/archive/${item.id}" class="rounded-lg bg-[#5b2c84] px-2 py-2 text-center text-white transition hover:bg-[#4a236c]">Details</a>
              <a href="${escapeHtml(pdfUrl)}" download class="rounded-lg border px-2 py-2 text-center transition ${pdfClass}">PDF</a>
              <button data-link="/en/archive/${item.id}" class="archive-copy-btn rounded-lg border border-amber-400 bg-amber-50 px-2 py-2 text-amber-900 transition hover:bg-amber-100">Copy Link</button>
            </div>
          </div>
        </article>
      `;
    }

    function bindCopyButtons() {
      document.querySelectorAll('.archive-copy-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const pageLink = `${window.location.origin}${button.dataset.link || '/archive'}`;
          try {
            await navigator.clipboard.writeText(pageLink);
            const oldText = button.textContent;
            button.textContent = 'Copied';
            setTimeout(() => {
              button.textContent = oldText;
            }, 1200);
          } catch {
            button.textContent = 'Failed';
            setTimeout(() => {
              button.textContent = 'Copy Link';
            }, 1200);
          }
        });
      });
    }

    async function loadArchive() {
      const params = new URLSearchParams();
      const decade = decadeSelect?.value || 'all';
      const focus = focusSelect?.value || 'all';
      const search = searchInput?.value?.trim() || '';

      if (decade !== 'all') params.set('decade', decade);
      if (focus !== 'all') params.set('focus', focus);
      if (search) params.set('search', search);

      try {
        params.set('lang', 'en');
        const response = await fetch(`/api/archive/list?${params.toString()}`);
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.error || 'Archive could not be loaded');

        if (!data.items.length) {
          listEl.innerHTML = '<div class="col-span-full rounded-2xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-500">No records found for this filter.</div>';
          countEl.textContent = '0 records shown';
          return;
        }

        listEl.innerHTML = data.items.map(cardTemplate).join('');
        countEl.textContent = `${data.items.length} records shown`;
        bindCopyButtons();
      } catch (error) {
        listEl.innerHTML = `<div class="col-span-full rounded-2xl border border-red-200 bg-red-50 p-8 text-center text-sm text-red-700">${escapeHtml(error.message)}</div>`;
      }
    }

    let searchTimer;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(loadArchive, 280);
    });

    decadeSelect?.addEventListener('change', loadArchive);
    focusSelect?.addEventListener('change', loadArchive);

    submitForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(submitForm);
      const payload = Object.fromEntries(formData.entries());

      submitButton.disabled = true;
      submitFeedback.textContent = 'Sending...';

      try {
        const response = await fetch('/api/archive/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json();
        if (!response.ok || !result.success) throw new Error(result.error || 'Submission failed');
        submitForm.reset();
        submitFeedback.textContent = 'The record is now in review. It will be published after all admin approvals.';
      } catch (error) {
        submitFeedback.textContent = error.message || 'Submission failed';
      } finally {
        submitButton.disabled = false;
      }
    });

    bindCopyButtons();
  </script>
</MainLayout>
