---
import MainLayout from '../../../layouts/MainLayout.astro';
import { articles } from '../../../data/articles-en';

export async function getStaticPaths() {
  const categoryMap = new Map<string, string>();
  
  articles.forEach((article) => {
    const slug = article.category.toLowerCase().replace(/\s+/g, '-');
    categoryMap.set(slug, article.category);
  });

  return Array.from(categoryMap.entries()).map(([slug, name]) => ({
    params: { category: slug },
    props: { categoryName: name },
  }));
}

interface Props {
  categoryName: string;
}

const { category } = Astro.params;
const { categoryName } = Astro.props as Props;

// Filter articles by category
const categoryArticles = articles.filter((article) => article.category === categoryName);
---

<MainLayout 
  title={`${categoryName} - Campus Witches`} 
  description={`Articles in the ${categoryName} category`}
  currentLang="en"
>
  <div class="min-h-screen bg-gray-50">
    <!-- Breadcrumb Navigation -->
    <nav class="mb-8 flex items-center gap-2 text-sm text-gray-600">
      <a href="/en/articles" class="hover:text-purple-600 transition">Articles</a>
      <span class="text-gray-400">/</span>
      <span class="text-gray-900 font-medium">{categoryName}</span>
    </nav>

    <!-- Header -->
    <div class="mb-12 pb-8 border-b border-gray-200">
      <h1 class="mb-2 text-4xl font-bold text-slate-900">{categoryName}</h1>
      <p class="text-lg text-gray-600">
        {categoryArticles.length} article{categoryArticles.length !== 1 ? 's' : ''}
      </p>
    </div>

    <!-- Articles List -->
    <section>
      {categoryArticles.length === 0 ? (
        <div class="py-16 text-center">
          <p class="text-lg text-gray-500 mb-4">No articles have been added to this section yet.</p>
          <a href="/en/articles" class="inline-block px-6 py-2 bg-purple-600 text-white rounded-lg hover:bg-purple-700 transition">
            Back to Articles
          </a>
        </div>
      ) : (
        <div class="space-y-6">
          {categoryArticles.map((article) => (
            <article class="bg-white rounded-lg border border-gray-200 p-6 hover:shadow-md transition">
              <div class="flex gap-6">
                {/* Image */}
                <div class="hidden sm:flex flex-shrink-0">
                  <div class="w-24 h-24 rounded-lg bg-purple-50 flex items-center justify-center text-4xl">
                    {article.image}
                  </div>
                </div>

                {/* Content */}
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="text-xs font-medium px-2 py-1 bg-purple-100 text-purple-700 rounded-full">
                      {article.category}
                    </span>
                    <span class="text-xs text-gray-500">
                      {new Date(article.date).toLocaleDateString('en-US')}
                    </span>
                  </div>
                  
                  <h2 class="text-xl font-bold text-slate-900 mb-2 hover:text-purple-700 transition">
                    <a href={`/en/article/${article.id}`}>
                      {article.title}
                    </a>
                  </h2>
                  
                  <p class="text-gray-600 mb-3 line-clamp-2">{article.excerpt}</p>
                  
                  <div class="flex flex-wrap items-center gap-4 text-sm text-gray-500">
                    <span>{article.author}</span>
                    <span>•</span>
                    <span>{article.readTime}</span>
                    <a 
                      href={`/en/article/${article.id}`}
                      class="ml-auto text-purple-600 hover:text-purple-700 font-medium"
                    >
                      Read More →
                    </a>
                  </div>
                </div>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </div>
</MainLayout>

<style>
  @media (max-width: 640px) {
    /* Mobile optimization */
  }
</style>
