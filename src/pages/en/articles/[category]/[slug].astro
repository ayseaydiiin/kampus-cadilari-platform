---
/**
 * Article Detail Page (English)
 * Route: /en/articles/[category]/[slug]
 * 
 * English version of the Turkish article detail page
 */

import MainLayout from '../../../../layouts/MainLayout.astro';
import { articles } from '../../../../data/articles-en';
import { generateArticleSlug } from '../../../../utils/slugify';

export function getStaticPaths() {
  const paths: any[] = [];
  
  for (const article of articles) {
    const slug = generateArticleSlug(article.title, article.id);
    paths.push({
      params: { category: article.category, slug },
      props: { article },
    });
  }
  
  return paths;
}

interface Props {
  article: any;
}

const { article } = Astro.props as Props;

if (!article) {
  return Astro.redirect('/en/articles');
}

const slug = generateArticleSlug(article.title, article.id);
const currentUrl = `${Astro.url.origin}/en/articles/${article.category}/${slug}`;
---

<MainLayout title={article.title}>
  <!-- Breadcrumb -->
  <nav class="max-w-4xl mx-auto px-4 py-4 text-sm text-gray-600">
    <a href="/en/articles" class="hover:text-purple-600">Articles</a>
    <span class="mx-2">/</span>
    <a href={`/en/articles/${article.category}`} class="hover:text-purple-600">
      {article.category}
    </a>
    <span class="mx-2">/</span>
    <span class="text-gray-900">{article.title}</span>
  </nav>

  <!-- Article header -->
  <div class="bg-gradient-to-r from-purple-50 to-purple-100 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex items-center gap-2 mb-4">
        <span class="text-3xl">{article.image}</span>
        <span class="text-sm font-semibold text-purple-600 uppercase">
          {article.category}
        </span>
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-4">{article.title}</h1>
      
      <!-- Meta info -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-gray-600">
        <span>By: <strong>{article.author}</strong></span>
        <span>•</span>
        <span>{new Date(article.date).toLocaleDateString('en-US', { 
          year: 'numeric', 
          month: 'long', 
          day: 'numeric' 
        })}</span>
        <span>•</span>
        <span id="readTime">{article.readTime}</span>
      </div>
    </div>
  </div>

  <!-- Article content -->
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2">
        <!-- Excerpt -->
        <p class="text-lg text-gray-700 mb-6 leading-relaxed border-l-4 border-purple-600 pl-4">
          {article.excerpt}
        </p>

        <!-- Body paragraphs -->
        <div class="prose prose-lg max-w-none space-y-6">
          {article.body && article.body.map((paragraph: string) => (
            <p class="text-gray-800 leading-relaxed">{paragraph}</p>
          ))}
        </div>

        <!-- Related action (CTA) -->
        <div class="bg-purple-50 border-l-4 border-purple-600 p-6 mt-8 rounded">
          <h3 class="text-lg font-semibold text-gray-900 mb-2">What can we do?</h3>
          <p class="text-gray-700">{article.relatedAction}</p>
        </div>

        <!-- Share buttons -->
        <div class="flex flex-wrap gap-3 mt-8 pt-8 border-t">
          <span class="text-sm text-gray-600 self-center">Share:</span>
          
          <!-- WhatsApp -->
          <a
            href={`https://wa.me/?text=${encodeURIComponent(article.title + ' ' + currentUrl)}`}
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 bg-green-500 text-white rounded hover:bg-green-600 transition"
          >
            💬 WhatsApp
          </a>

          <!-- Twitter -->
          <a
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 bg-blue-400 text-white rounded hover:bg-blue-500 transition"
          >
            𝕏 Twitter
          </a>

          <!-- LinkedIn -->
          <a
            href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(currentUrl)}`}
            target="_blank"
            class="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition"
          >
            in LinkedIn
          </a>

          <!-- Copy link -->
          <button
            class="inline-flex items-center gap-2 px-4 py-2 bg-gray-300 text-gray-900 rounded hover:bg-gray-400 transition"
            onclick="copyToClipboard()"
          >
            🔗 Copy Link
          </button>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="lg:col-span-1">
        <!-- Article info card -->
        <div class="bg-white border border-gray-200 rounded-lg p-6 sticky top-20">
          <div class="space-y-4">
            <div class="text-center">
              <div class="text-3xl">{article.image}</div>
              <p class="text-sm text-gray-600 mt-2">{article.category}</p>
            </div>

            <div class="border-t pt-4">
              <p class="text-xs text-gray-600 uppercase tracking-wider mb-2">Article Info</p>
              <dl class="space-y-2 text-sm">
                <div>
                  <dt class="text-gray-600">Author</dt>
                  <dd class="font-semibold text-gray-900">{article.author}</dd>
                </div>
                <div>
                  <dt class="text-gray-600">Published</dt>
                  <dd class="font-semibold text-gray-900">
                    {new Date(article.date).toLocaleDateString('en-US')}
                  </dd>
                </div>
                <div>
                  <dt class="text-gray-600">Read time</dt>
                  <dd class="font-semibold text-gray-900">{article.readTime}</dd>
                </div>
              </dl>
            </div>

            <!-- Related articles link -->
            <div class="border-t pt-4">
              <a
                href={`/en/articles/${article.category}`}
                class="inline-block w-full text-center px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 transition"
              >
                Related Articles ({article.category})
              </a>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <!-- Back to articles -->
  <div class="max-w-4xl mx-auto px-4 py-8">
    <a
      href="/en/articles"
      class="inline-flex items-center gap-2 text-purple-600 hover:text-purple-700 font-medium"
    >
      ← All Articles
    </a>
  </div>
</MainLayout>

<script define:vars={{ slug }}>
  // Track view on page load
  async function trackView() {
    try {
      await fetch('/api/articles/view', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: slug }),
      });
    } catch (error) {
      console.error('View tracking failed:', error);
    }
  }

  function copyToClipboard() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      alert('Link copied!');
    });
  }

  // Track view when page loads
  document.addEventListener('DOMContentLoaded', trackView);
</script>
