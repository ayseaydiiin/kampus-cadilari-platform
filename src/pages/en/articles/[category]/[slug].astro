---
import MainLayout from '../../../../layouts/MainLayout.astro';
import { getArticleBySlug } from '../../../../utils/db.js';
import { getCategoryLabel, getCategorySlug } from '../../../../utils/articleCategories';
import { toEnglishArticle } from '../../../../utils/contentI18n.js';

export const prerender = false;

const categorySlug = String(Astro.params.category || '').trim();
const slug = String(Astro.params.slug || '').trim();
const article = toEnglishArticle(getArticleBySlug(slug, { publishedOnly: true }));

if (!article) {
  return Astro.redirect('/en/articles');
}

const expectedCategory = getCategorySlug(article.category || 'Gundem ve Politika');
if (categorySlug !== expectedCategory) {
  return Astro.redirect(`/en/articles/${expectedCategory}/${article.slug}`);
}

const bodyParagraphs = String(article.body || '')
  .split(/\r?\n\r?\n/)
  .map((item) => item.trim())
  .filter(Boolean);

const pageUrl = `${Astro.url.origin}/en/articles/${expectedCategory}/${article.slug}`;
---

<MainLayout title={`${article.title} - Campus Witches`} description={article.excerpt || String(article.body || '').slice(0, 160)} currentLang="en">
  <article class="mx-auto max-w-4xl">
    <a href={`/en/articles/${expectedCategory}`} class="inline-flex items-center gap-2 rounded-full bg-purple-50 px-4 py-2 text-sm font-bold text-purple-700 hover:bg-purple-100">
      Back to category
    </a>

    <header class="mt-6 rounded-[2rem] bg-gradient-to-br from-purple-700 via-fuchsia-700 to-rose-600 px-6 py-8 text-white shadow-2xl md:px-10 md:py-12">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-purple-100">{getCategoryLabel(article.category || 'Gundem ve Politika', 'en')}</p>
      <h1 class="app-h1 mt-3 text-3xl font-black md:text-5xl">{article.title}</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-white/90">{article.excerpt || ''}</p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-white/90">
        <span class="rounded-full bg-white/10 px-4 py-2 ring-1 ring-white/20">
          {new Date(article.created_at || Date.now()).toLocaleDateString('en-US')}
        </span>
        <span id="header-view-count" class="rounded-full bg-white/10 px-4 py-2 ring-1 ring-white/20">
          {(article.tracked_view_count || 0)} reads
        </span>
      </div>
    </header>

    {article.image_url ? (
      <figure class="mt-8 overflow-hidden rounded-[2rem] border border-[#ddcdb8] bg-gradient-to-br from-[#fffaf2] via-[#f8f2e7] to-[#f3ecdf] p-4 shadow-xl">
        <div class="overflow-hidden rounded-[1.4rem] border border-white/70 bg-white/70 p-2 backdrop-blur-[1px]">
          <img src={article.image_url} alt={article.title || 'Article image'} class="mx-auto h-auto max-h-[36rem] w-full rounded-[1rem] bg-white object-contain" loading="lazy" />
        </div>
      </figure>
    ) : null}

    <section class="mt-8 rounded-[1.75rem] bg-white p-6 shadow-lg ring-1 ring-slate-200 md:p-8">
      {bodyParagraphs.length ? (
        <div class="space-y-6 text-base leading-8 text-slate-700">
          {bodyParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      ) : (
        <p class="text-slate-700">{article.body}</p>
      )}
    </section>

    <section class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-black text-slate-900">Share</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`https://wa.me/?text=${encodeURIComponent(`${article.title} ${pageUrl}`)}`}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700"
        >
          WhatsApp
        </a>
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg bg-sky-500 px-4 py-2 text-sm font-bold text-white hover:bg-sky-600"
        >
          X/Twitter
        </a>
        <button id="copy-link-btn" class="rounded-lg bg-slate-200 px-4 py-2 text-sm font-bold text-slate-900 hover:bg-slate-300">
          Copy link
        </button>
      </div>
      <p id="copy-link-state" class="mt-2 text-xs font-semibold text-emerald-700"></p>
    </section>
  </article>

  <script define:vars={{ slug }}>
    const headerView = document.getElementById('header-view-count');
    const copyBtn = document.getElementById('copy-link-btn');
    const copyState = document.getElementById('copy-link-state');

    async function trackView() {
      try {
        const response = await fetch('/api/articles/view', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });
        const data = await response.json();
        if (data.success && headerView) {
          headerView.textContent = `${data.view_count || 0} reads`;
        }
      } catch (error) {
        console.error('view tracking failed', error);
      }
    }

    copyBtn?.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        if (copyState) copyState.textContent = 'Link copied.';
      } catch {
        if (copyState) copyState.textContent = 'Copy failed.';
      }
      setTimeout(() => {
        if (copyState) copyState.textContent = '';
      }, 1200);
    });

    document.addEventListener('DOMContentLoaded', trackView);
  </script>
</MainLayout>
