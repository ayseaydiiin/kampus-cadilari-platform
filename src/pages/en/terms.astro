---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Terms of Use - Campus Witches" currentLang="en">
  <div class="max-w-3xl py-12">
    <h1 class="app-h1 mb-6 text-4xl font-black text-purple-600">Terms of Use</h1>

    <div class="prose prose-lg max-w-none space-y-6">
      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">1. Introduction</h2>
        <p class="leading-relaxed text-gray-700">
          This website is provided by Campus Witches. By using the site, you agree to these terms.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">2. Content and Copyright</h2>
        <p class="leading-relaxed text-gray-700">
          Text, visuals, and other materials on this site are protected. Unauthorized copying or redistribution is not allowed.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">3. Disclaimer</h2>
        <p class="leading-relaxed text-gray-700">
          Site content is provided for information purposes. We do not guarantee uninterrupted access or absolute accuracy.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">4. Prohibited Conduct</h2>
        <p class="leading-relaxed text-gray-700">You may not:</p>
        <ul class="ml-4 list-inside list-disc space-y-2 text-gray-700">
          <li>Publish illegal content</li>
          <li>Harass or threaten other users</li>
          <li>Attempt unauthorized system access</li>
          <li>Upload malware or harmful code</li>
        </ul>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">5. Changes</h2>
        <p class="leading-relaxed text-gray-700">
          Campus Witches may update these terms when needed. The latest version is always available on this page.
        </p>
      </section>

      <section>
        <h2 class="mb-3 text-2xl font-bold text-purple-600">6. Contact</h2>
        <p class="leading-relaxed text-gray-700">
          For questions, contact us at
          <a href="mailto:kampuscadilari8@gmail.com" class="text-purple-600 hover:underline">kampuscadilari8@gmail.com</a>
          or through the community's official social media accounts.
        </p>
      </section>
    </div>
  </div>
</MainLayout>
