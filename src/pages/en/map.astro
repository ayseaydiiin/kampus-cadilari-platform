---
// src/pages/en/map.astro
import MainLayout from '../../layouts/MainLayout.astro';
import TurkeyMap from '../../components/TurkeyMap.astro';
---

<MainLayout title="Join Us - Campus Witches" currentLang="en">
  <!-- Header -->
  <div class="py-12 text-center mb-8">
    <h1 class="text-5xl md:text-6xl font-black mb-4">
      <span class="bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">
        Join the Movement
      </span>
    </h1>
    <p class="text-lg text-gray-600 max-w-2xl mx-auto">
      Campus Witches organize in 82 provinces across Turkey. Find your local chapter and join us.
    </p>
  </div>

  <!-- Interactive Map -->
  <section class="bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl p-8 md:p-12 mb-12 border-2 border-purple-200">
    <h2 class="text-3xl font-bold mb-6 text-center">Find Your Province</h2>
    <TurkeyMap />
  </section>

  <!-- Join Form -->
  <section class="grid grid-cols-1 md:grid-cols-2 gap-12 mb-12">
    <!-- Form -->
    <div>
      <h2 class="text-3xl font-bold mb-6">
        <span class="text-purple-600">Sign Up</span> for Our Network
      </h2>
      
      <form id="en-join-form" class="bg-white p-8 rounded-xl border-2 border-gray-200 space-y-4">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Full Name *</label>
          <input type="text" name="name" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" placeholder="Your name" required />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Email Address *</label>
          <input type="email" name="email" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" placeholder="your@email.com" required />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Province *</label>
          <select name="province" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" required>
            <option value="">-- Select Province --</option>
            <option value="istanbul">Istanbul</option>
            <option value="ankara">Ankara</option>
            <option value="izmir">Izmir</option>
            <option value="other">Other...</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">University / Organization</label>
          <input type="text" name="organization" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" placeholder="Your institution" />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">How can you contribute? *</label>
          <div class="space-y-2">
            <label class="flex items-center">
              <input type="checkbox" name="skills" value="organizing" class="mr-2" /> Organizing & Events
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="skills" value="writing" class="mr-2" /> Writing & Media
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="skills" value="education" class="mr-2" /> Education & Training
            </label>
            <label class="flex items-center">
              <input type="checkbox" name="skills" value="support" class="mr-2" /> Support & Care
            </label>
          </div>
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Social Media Handle</label>
          <input type="text" name="social" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600" placeholder="@yourhandle" />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Why do you want to join us?</label>
          <textarea name="message" class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 h-24" placeholder="Tell us your motivation..." required></textarea>
        </div>

        <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold py-3 rounded-lg hover:shadow-lg transition text-lg">
          Join the Movement
        </button>
      </form>
    </div>

    <!-- Why Join -->
    <div>
      <h2 class="text-3xl font-bold mb-6">
        Why <span class="text-purple-600">Join Us</span>?
      </h2>

      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="text-4xl">👭</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Community & Sisterhood</h3>
            <p class="text-gray-600">Connect with like-minded women organizing for change in your province.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-4xl">🎓</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Knowledge & Skills</h3>
            <p class="text-gray-600">Learn about feminist theory, organizing, media, and activism from experts.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-4xl">✊</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Direct Action</h3>
            <p class="text-gray-600">Participate in marches, protests, workshops, and cultural events nationwide.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-4xl">📢</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Amplify Your Voice</h3>
            <p class="text-gray-600">Platform to publish articles, organize campaigns, and build solidarity networks.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-4xl">🛡️</div>
          <div>
            <h3 class="font-bold text-lg mb-2">Mutual Support</h3>
            <p class="text-gray-600">Care networks for legal support, mental health, and community protection.</p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="text-4xl">🌍</div>
          <div>
            <h3 class="font-bold text-lg mb-2">International Solidarity</h3>
            <p class="text-gray-600">Connect with feminist movements across the globe and build transnational power.</p>
          </div>
        </div>
      </div>

      <!-- Stats Box -->
      <div class="mt-8 bg-gradient-to-br from-purple-100 to-pink-100 p-6 rounded-xl">
        <h3 class="font-bold text-lg mb-4">Current Network</h3>
        <div class="space-y-2">
          <p class="flex justify-between"><span>Active Provinces:</span> <strong>82</strong></p>
          <p class="flex justify-between"><span>Active Members:</span> <strong>1,500+</strong></p>
          <p class="flex justify-between"><span>Events This Year:</span> <strong>250+</strong></p>
          <p class="flex justify-between"><span>Articles Published:</span> <strong>480+</strong></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="bg-gradient-to-r from-purple-600 to-pink-600 text-white rounded-2xl p-8 md:p-12 text-center">
    <h2 class="text-4xl font-bold mb-6">Our Three Core Values</h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white bg-opacity-10 p-6 rounded-xl backdrop-blur">
        <div class="text-4xl mb-3">🦅</div>
        <h3 class="font-bold text-xl mb-2">Freedom</h3>
        <p>Liberation from patriarchal oppression. Bodily autonomy for all women.</p>
      </div>
      
      <div class="bg-white bg-opacity-10 p-6 rounded-xl backdrop-blur">
        <div class="text-4xl mb-3">🤝</div>
        <h3 class="font-bold text-xl mb-2">Solidarity</h3>
        <p>United across differences. Our strength comes from collective action.</p>
      </div>
      
      <div class="bg-white bg-opacity-10 p-6 rounded-xl backdrop-blur">
        <div class="text-4xl mb-3">⚡</div>
        <h3 class="font-bold text-xl mb-2">Struggle</h3>
        <p>Resistance as our path. Fighting for justice and equality for all.</p>
      </div>
    </div>
  </section>

  <script>
    // English Join Form Handler
    const enJoinForm = document.getElementById('en-join-form');
    enJoinForm.addEventListener('submit', (e) => {
      e.preventDefault();
      
      const formData = new FormData(enJoinForm);
      const name = formData.get('name');
      const email = formData.get('email');
      const province = formData.get('province');
      
      // Basic validation
      if (!name || !email || !province) {
        alert('❌ Please fill in all required fields!');
        return;
      }
      
      // Update form with success message
      enJoinForm.innerHTML = `
        <div class="bg-green-100 border-2 border-green-500 text-green-800 rounded-lg p-6 text-center">
          <p class="text-2xl font-bold mb-2">✓ Welcome to the Movement!</p>
          <p class="text-lg mb-4">Thank you for joining! We'll be in touch soon with more information about your local chapter.</p>
          <p class="text-sm opacity-75">Page will reload in 3 seconds...</p>
        </div>
      `;
      
      setTimeout(() => {
        window.location.reload();
      }, 3000);
    });
  </script>
</MainLayout>
