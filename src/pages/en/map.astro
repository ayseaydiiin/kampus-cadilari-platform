---
import MainLayout from '../../layouts/MainLayout.astro';

const provinces = [
  { code: 'istanbul', name: 'Istanbul', region: 'Marmara', status: 'active', members: 145, contacts: ['Zeynep Kaya', 'Ayse Yilmaz'] },
  { code: 'ankara', name: 'Ankara', region: 'Central Anatolia', status: 'active', members: 89, contacts: ['Fatma Demir', 'Gulsum Alp'] },
  { code: 'izmir', name: 'Izmir', region: 'Aegean', status: 'growing', members: 67, contacts: ['Muzeyyen Senar'] },
  { code: 'bursa', name: 'Bursa', region: 'Marmara', status: 'active', members: 54, contacts: ['Emine Kara'] },
  { code: 'gaziantep', name: 'Gaziantep', region: 'Southeast Anatolia', status: 'growing', members: 42, contacts: ['Leyla Sahin'] },
  { code: 'adana', name: 'Adana', region: 'Mediterranean', status: 'starting', members: 28, contacts: [] },
  { code: 'eskisehir', name: 'Eskisehir', region: 'Central Anatolia', status: 'active', members: 51, contacts: ['Sevim Aydin'] },
  { code: 'mersin', name: 'Mersin', region: 'Mediterranean', status: 'growing', members: 35, contacts: [] },
];
---

<MainLayout title="Join Us - Campus Witches" currentLang="en">
  <section class="mb-12 rounded-2xl bg-gradient-to-r from-purple-700 to-pink-600 p-8 text-white md:p-12">
    <h1 class="app-h1 mb-4 text-4xl font-black md:text-5xl">Join Us</h1>
    <p class="max-w-2xl text-lg text-white/90">
      Join our feminist network organized across 82 provinces. Select your province, tell us about yourself, and join the team.
    </p>
  </section>

  <section class="mb-12 grid grid-cols-1 gap-8 lg:grid-cols-[1fr_1.2fr]">
    <div class="space-y-6">
      <div class="rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-200">
        <label class="mb-3 block text-sm font-bold uppercase text-gray-600">
          1. Select Province
        </label>
        <select id="province-select" class="w-full rounded-lg border-2 border-purple-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none">
          <option value="">-- Select Your Province --</option>
          {provinces.map((p) => (
            <option value={p.code}>{p.name}</option>
          ))}
        </select>
      </div>

      <div id="province-details" class="hidden space-y-4 rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-200">
        <label class="text-sm font-bold uppercase text-gray-600">
          2. Province Details
        </label>

        <div id="details-content" class="space-y-4"></div>

        <button id="select-province-btn" class="w-full rounded-lg bg-purple-600 py-3 font-bold text-white transition hover:bg-purple-700">
          Select This Province
        </button>
      </div>

      <div class="rounded-2xl border-2 border-purple-200 bg-purple-50 p-6">
        <p class="mb-3 text-sm font-bold uppercase text-purple-700">Info</p>
        <p class="text-sm leading-6 text-gray-700">
          After your application is received, the contact person or team in your selected province will get in touch with you.
          For active provinces, you will be directed to the local team. For provinces in setup phase, you will be directed to the founding volunteer pool.
        </p>
      </div>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-lg ring-1 ring-gray-200">
      <label class="mb-6 block text-sm font-bold uppercase text-gray-600">
        3. Application Form
      </label>

      <form id="application-form" class="space-y-4">
        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            Province (Auto)
          </label>
          <input
            id="form-province"
            type="text"
            disabled
            class="w-full rounded-lg border-2 border-gray-300 bg-gray-100 px-4 py-3 font-semibold text-gray-700"
            placeholder="Waiting for province selection..."
          />
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            Full Name *
          </label>
          <input
            type="text"
            name="name"
            required
            class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none"
            placeholder="Enter your full name"
          />
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            E-mail *
          </label>
          <input
            type="email"
            name="email"
            required
            class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none"
            placeholder="example@mail.com"
          />
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            University / Organization (Optional)
          </label>
          <input
            type="text"
            name="organization"
            class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none"
            placeholder="e.g. Bogazici University"
          />
        </div>

        <div>
          <label class="mb-3 block text-xs font-bold uppercase text-gray-600">
            Contribution Areas *
          </label>
          <div class="space-y-2">
            <label class="flex cursor-pointer items-center gap-3">
              <input type="checkbox" name="skills" value="organizing" class="h-4 w-4 rounded border-gray-300" />
              <span class="text-gray-700">Organizing and Event Coordination</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input type="checkbox" name="skills" value="writing" class="h-4 w-4 rounded border-gray-300" />
              <span class="text-gray-700">Writing and Editorial</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input type="checkbox" name="skills" value="education" class="h-4 w-4 rounded border-gray-300" />
              <span class="text-gray-700">Education and Learning Materials</span>
            </label>
            <label class="flex cursor-pointer items-center gap-3">
              <input type="checkbox" name="skills" value="support" class="h-4 w-4 rounded border-gray-300" />
              <span class="text-gray-700">Support and Care (Psychological, Legal, etc.)</span>
            </label>
          </div>
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            Social Media Handle (Optional)
          </label>
          <input
            type="text"
            name="social"
            class="w-full rounded-lg border-2 border-gray-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none"
            placeholder="@username or your profile link"
          />
        </div>

        <div>
          <label class="mb-2 block text-xs font-bold uppercase text-gray-600">
            Tell Us About Yourself *
          </label>
          <textarea
            name="message"
            required
            rows="4"
            class="w-full resize-none rounded-lg border-2 border-gray-300 px-4 py-3 font-semibold focus:border-purple-600 focus:outline-none"
            placeholder="Why do you want to join? How can you contribute to local organizing?"
          ></textarea>
        </div>

        <button
          id="submit-btn"
          type="submit"
          disabled
          class="w-full cursor-not-allowed rounded-lg bg-gray-300 py-3 font-bold text-gray-600 transition disabled:opacity-50"
        >
          Submit Application (select province first)
        </button>
      </form>
    </div>
  </section>

  <script>
    const provinceSelect = document.getElementById('province-select');
    const provinceDetails = document.getElementById('province-details');
    const detailsContent = document.getElementById('details-content');
    const selectProvinceBtn = document.getElementById('select-province-btn');
    const formProvince = document.getElementById('form-province');
    const applicationForm = document.getElementById('application-form');
    const submitBtn = document.getElementById('submit-btn');

    const provincesData = {
      istanbul: { name: 'Istanbul', region: 'Marmara', status: 'active', members: 145, contacts: ['Zeynep Kaya', 'Ayse Yilmaz'] },
      ankara: { name: 'Ankara', region: 'Central Anatolia', status: 'active', members: 89, contacts: ['Fatma Demir', 'Gulsum Alp'] },
      izmir: { name: 'Izmir', region: 'Aegean', status: 'growing', members: 67, contacts: ['Muzeyyen Senar'] },
      bursa: { name: 'Bursa', region: 'Marmara', status: 'active', members: 54, contacts: ['Emine Kara'] },
      gaziantep: { name: 'Gaziantep', region: 'Southeast Anatolia', status: 'growing', members: 42, contacts: ['Leyla Sahin'] },
      adana: { name: 'Adana', region: 'Mediterranean', status: 'starting', members: 28, contacts: [] },
      eskisehir: { name: 'Eskisehir', region: 'Central Anatolia', status: 'active', members: 51, contacts: ['Sevim Aydin'] },
      mersin: { name: 'Mersin', region: 'Mediterranean', status: 'growing', members: 35, contacts: [] },
    };

    provinceSelect.addEventListener('change', (e) => {
      const selectedCode = e.target.value;

      if (!selectedCode) {
        provinceDetails.classList.add('hidden');
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submit Application (select province first)';
        return;
      }

      const prov = provincesData[selectedCode];

      detailsContent.innerHTML = `
        <div>
          <p class="text-xs font-bold text-gray-600">PROVINCE</p>
          <p class="mt-1 text-2xl font-black text-purple-700">${prov.name}</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-600">REGION</p>
          <p class="mt-1 text-lg font-semibold text-gray-900">${prov.region}</p>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-600">STATUS</p>
          <div class="mt-1">
            <span class="inline-block rounded-full px-3 py-1 text-sm font-bold ${
              prov.status === 'active' ? 'bg-green-100 text-green-700' :
              prov.status === 'growing' ? 'bg-blue-100 text-blue-700' :
              'bg-yellow-100 text-yellow-700'
            }">
              ${prov.status === 'active' ? 'Active' : prov.status === 'growing' ? 'Growing' : 'Setup Phase'}
            </span>
          </div>
        </div>
        <div>
          <p class="text-xs font-bold text-gray-600">ACTIVE MEMBERS</p>
          <p class="mt-1 text-lg font-semibold text-gray-900">${prov.members} people</p>
        </div>
        ${prov.contacts.length > 0 ? `
          <div>
            <p class="text-xs font-bold text-gray-600">PROVINCE COORDINATOR</p>
            <p class="mt-1 text-lg font-semibold text-gray-900">${prov.contacts.join(', ')}</p>
          </div>
        ` : ''}
      `;

      provinceDetails.classList.remove('hidden');
    });

    selectProvinceBtn.addEventListener('click', () => {
      const selectedCode = provinceSelect.value;
      const selectedName = provincesData[selectedCode].name;

      formProvince.value = selectedName;
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Application';
      submitBtn.classList.remove('bg-gray-300', 'text-gray-600', 'cursor-not-allowed');
      submitBtn.classList.add('bg-purple-600', 'text-white', 'hover:bg-purple-700');

      applicationForm.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    applicationForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const formData = {
        full_name: applicationForm.querySelector('input[name="name"]').value,
        email: applicationForm.querySelector('input[name="email"]').value,
        province: formProvince.value,
        organization: applicationForm.querySelector('input[name="organization"]').value,
        skills: Array.from(applicationForm.querySelectorAll('input[name="skills"]:checked')).map((cb) => cb.value),
        social_media: applicationForm.querySelector('input[name="social"]').value,
        message: applicationForm.querySelector('textarea[name="message"]').value,
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';

      try {
        const response = await fetch('/api/submit-application', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(formData),
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'An error occurred');
        }

        applicationForm.innerHTML = `
          <div class="space-y-3 rounded-2xl border-2 border-green-300 bg-green-50 p-6 text-center">
            <p class="text-4xl">OK</p>
            <p class="text-2xl font-bold text-green-700">Application Received!</p>
            <p class="mt-4 text-gray-700">
              <strong>${formData.full_name}</strong>, your application will be reviewed by the <strong>${formData.province}</strong> coordination team.
            </p>
            <div class="mt-4 rounded-lg bg-green-100 p-4">
              <p class="text-sm text-gray-600">
                <strong>${formData.email}</strong> will receive updates about review progress.
              </p>
              <p class="mt-2 text-sm text-gray-600">
                Average response time: <strong>3-5 business days</strong>.
              </p>
            </div>
            <p class="mt-4 text-xs text-gray-500">
              Application ID: <code class="rounded bg-gray-100 px-2 py-1">#APP-${result.applicationId}</code>
            </p>
            <button onclick="location.reload()" class="mt-6 w-full rounded-lg bg-purple-600 py-3 font-bold text-white transition hover:bg-purple-700">
              Done
            </button>
          </div>
        `;
      } catch (error) {
        console.error('Submission error:', error);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Application';
        alert(`Error: ${error.message}\n\nPlease try again later.`);
      }
    });
  </script>
</MainLayout>