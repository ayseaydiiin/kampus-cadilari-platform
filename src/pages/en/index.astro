---
import MainLayout from '../../layouts/MainLayout.astro';
import SelectedWordPanel from '../../components/SelectedWordPanel.astro';
import { feministWords } from '../../data/feministWords';
import { getCategoryLabel, getCategorySlug } from '../../utils/articleCategories';
import { getApprovedArchiveEntries, getPublishedArticles } from '../../utils/db.js';
import { toEnglishArchiveItem, toEnglishArticle } from '../../utils/contentI18n.js';

const today = new Date();
const dayOfYear = Math.floor((today.getTime() - new Date(today.getFullYear(), 0, 0).getTime()) / 86400000);
const todaysWord = feministWords[(dayOfYear - 1) % feministWords.length];

const publishedArticles = getPublishedArticles().map((article) => toEnglishArticle(article));
const homeArticles = publishedArticles.map((article) => ({
  id: article.slug,
  slug: article.slug,
  title: article.title,
  category: article.category || 'Gundem ve Politika',
  excerpt: article.excerpt || String(article.body || '').slice(0, 180),
  date: article.created_at,
  image: '*',
}));

const categoryMap = new Map();
for (const article of homeArticles) {
  const displayCategory = getCategoryLabel(article.category || 'Gundem ve Politika', 'en');
  const current = categoryMap.get(displayCategory);
  if (current) current.count += 1;
  else {
    categoryMap.set(displayCategory, {
      name: displayCategory,
      count: 1,
      icon: article.image || '*',
    });
  }
}

const categories = Array.from(categoryMap.values())
  .map((category) => ({ ...category, slug: getCategorySlug(category.name) }))
  .sort((a, b) => a.name.localeCompare(b.name, 'en'));

const latestArticles = [...homeArticles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 3);

const featuredArchiveItems = getApprovedArchiveEntries({ limit: 3 }).map((item) => toEnglishArchiveItem(item));
---

<MainLayout title="Campus Witches - Feminist Solidarity Network" description="A platform bringing feminist agenda and solidarity movements together." currentLang="en">
  <section class="mx-auto max-w-6xl rounded-[2rem] bg-gradient-to-br from-[#4f1d73] via-[#5b2c84] to-[#1f2554] px-6 py-10 text-white shadow-xl md:px-10 md:py-12">
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <h2 class="text-4xl font-black leading-tight text-white md:text-5xl">Campus Witches</h2>
        <p class="mt-5 max-w-2xl text-base leading-8 text-white md:text-lg">
          A reading platform on feminist agenda, social mobilization, and solidarity movements.
          Access daily updated writing, analysis, and issue collections.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/en/articles" class="rounded-xl bg-white px-5 py-2.5 text-sm font-bold text-purple-700 transition hover:bg-purple-100">
            Explore All Articles
          </a>
          <button id="join-modal-btn" class="rounded-xl border border-white/50 px-5 py-2.5 text-sm font-bold text-white transition hover:bg-white/10">
            Join Us
          </button>
        </div>
      </div>

      <SelectedWordPanel initialWord={todaysWord} lang="en" />
    </div>
  </section>

  <section class="mx-auto mt-14 max-w-5xl">
    <div class="mb-5 flex items-center justify-between gap-3">
      <h3 class="text-3xl font-black text-slate-900">Newspaper Archive</h3>
      <a href="/en/archive" class="text-sm font-bold text-purple-700 hover:text-purple-900">View full archive</a>
    </div>

    <div class="grid gap-4 md:grid-cols-3">
      {featuredArchiveItems.map((item) => (
        <article class="group overflow-hidden rounded-2xl border border-[#d5c6ac] bg-[#fdf8ef] shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
          <div class="relative">
            <img src={item.cover_image_url || '/archive/placeholder-cover.svg'} alt={`${item.publication_name} cover`} class="h-44 w-full object-cover" loading="lazy" />
            <span class="absolute left-3 top-3 rounded-full border border-amber-300 bg-amber-100 px-2.5 py-1 text-[11px] font-bold text-amber-900">Admin Approved</span>
          </div>
          <div class="p-4">
            <p class="text-xs font-bold uppercase tracking-wide text-[#5b2c84]">{item.decade} - {item.publication_year}</p>
            <h4 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">{item.title}</h4>
            <p class="mt-2 text-sm font-semibold text-slate-700">{item.publication_name}</p>
            <a href={`/en/archive/${item.id}`} class="mt-4 inline-flex text-sm font-bold text-purple-700 transition group-hover:text-purple-900">
              View archive record ->
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-14 max-w-5xl">
    <h3 class="text-3xl font-black text-slate-900">About The Platform</h3>
    <p class="mt-4 max-w-4xl text-base leading-8 text-slate-600">
      Campus Witches is a community-driven content platform that approaches current social topics from a feminist lens.
      From legal analysis to culture writing, interviews to research, it offers a broad editorial perspective.
    </p>
  </section>

  <section class="mx-auto mt-14 max-w-5xl">
    <h3 class="text-3xl font-black text-slate-900">Content Categories</h3>
    <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
      {categories.map((category) => (
        <a href={`/en/articles/${category.slug}`} class="group rounded-2xl border border-slate-200 bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
          <div class="flex items-center justify-between gap-4">
            <h4 class="text-lg font-bold text-slate-900">{category.name}</h4>
            <span class="text-2xl" aria-hidden="true">{category.icon}</span>
          </div>
          <p class="mt-3 text-sm font-semibold text-slate-500">{category.count} article{category.count === 1 ? '' : 's'}</p>
          <p class="mt-4 text-sm font-bold text-purple-700 transition group-hover:text-purple-900">Open category -></p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto mt-14 max-w-5xl">
    <div class="mb-5 flex items-center justify-between gap-3">
      <h3 class="text-3xl font-black text-slate-900">Latest Articles</h3>
      <a href="/en/articles" class="text-sm font-bold text-purple-700 hover:text-purple-900">View all</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {latestArticles.map((article) => (
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
            {new Date(article.date).toLocaleDateString('en-US', { day: '2-digit', month: 'long', year: 'numeric' })}
          </p>
          <h4 class="mt-2 text-xl font-bold leading-tight text-slate-900">{article.title}</h4>
          <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">{article.excerpt}</p>
          <a href={`/en/articles/${getCategorySlug(article.category || 'Gundem ve Politika')}/${article.slug}`} class="mt-4 inline-flex text-sm font-bold text-purple-700 hover:text-purple-900">
            Read article ->
          </a>
        </article>
      ))}
    </div>
  </section>

  <div id="join-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/60 p-4">
    <div class="relative w-full max-w-3xl overflow-hidden rounded-2xl bg-white shadow-2xl">
      <button id="join-modal-close" class="absolute right-4 top-4 text-slate-500 hover:text-slate-800" aria-label="Close">
        x
      </button>
      <div class="max-h-[80vh] overflow-auto">
        <iframe
          src="https://docs.google.com/forms/d/e/1FAIpQLSc4YtEELBG3XF3VuH0t37alzBNFGwteBTS1Fn6IbBqghFtYeA/viewform?embedded=true"
          class="h-[80vh] w-full border-0"
          loading="lazy"
          title="Join Form"
        ></iframe>
      </div>
    </div>
  </div>

  <script>
    const joinBtn = document.getElementById('join-modal-btn');
    const joinModal = document.getElementById('join-modal');
    const joinClose = document.getElementById('join-modal-close');

    function closeModal() {
      joinModal?.classList.add('hidden');
      joinModal?.classList.remove('flex');
    }

    joinBtn?.addEventListener('click', () => {
      joinModal?.classList.remove('hidden');
      joinModal?.classList.add('flex');
    });

    joinClose?.addEventListener('click', closeModal);
    joinModal?.addEventListener('click', (event) => {
      if (event.target === joinModal) closeModal();
    });
  </script>
</MainLayout>
