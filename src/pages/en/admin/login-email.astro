---
// src/pages/en/admin/login-email.astro
import MainLayout from '../../../layouts/MainLayout.astro';
---

<MainLayout title="Admin Login - Campus Witches" currentLang="en">
  <div class="min-h-screen bg-gradient-to-br from-purple-600 via-red-500 to-pink-600 flex items-center justify-center py-12 px-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-2xl p-8">
      <!-- Logo -->
      <div class="text-center mb-8">
        <div class="text-6xl mb-4">🔮</div>
        <h1 class="text-3xl font-bold text-purple-600">Campus Witches</h1>
        <p class="text-gray-600 mt-2">Admin Portal</p>
      </div>

      <!-- Messages -->
      <div id="message" class="hidden p-4 mb-4 rounded-lg text-sm font-semibold"></div>
      <div id="loading" class="hidden p-4 mb-4 rounded-lg bg-blue-100 text-blue-800">
        🔄 Processing...
      </div>

      <!-- Email/Password Form -->
      <form id="login-form" class="space-y-4">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">
            📧 Email Address
          </label>
          <input 
            type="email" 
            id="email"
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 transition" 
            placeholder="admin@kampuscadilari.org" 
            required 
          />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">
            🔐 Password
          </label>
          <input 
            type="password" 
            id="password"
            class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:border-purple-600 transition" 
            placeholder="••••••••" 
            required 
          />
        </div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white font-bold py-3 rounded-lg hover:shadow-lg transition text-lg disabled:opacity-50"
        >
          ✊ Sign In
        </button>
      </form>

      <!-- Divider -->
      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center">
          <div class="w-full border-t border-gray-300"></div>
        </div>
        <div class="relative flex justify-center text-xs">
          <span class="px-2 bg-white text-gray-600">or</span>
        </div>
      </div>

      <!-- OAuth -->
      <div class="space-y-3 mb-6">
        <button type="button" class="w-full border-2 border-gray-300 text-gray-700 font-bold py-3 rounded-lg hover:bg-gray-50 transition flex items-center justify-center gap-2">
          <span>🐙</span> Sign in with GitHub
        </button>
        <button type="button" class="w-full border-2 border-gray-300 text-gray-700 font-bold py-3 rounded-lg hover:bg-gray-50 transition flex items-center justify-center gap-2">
          <span>🔴</span> Sign in with Google
        </button>
      </div>

      <!-- Decap CMS Link -->
      <div class="text-center border-t border-gray-200 pt-6">
        <p class="text-sm text-gray-600 mb-3">Want to use Decap CMS?</p>
        <a href="/admin/" class="inline-block bg-gradient-to-r from-purple-100 to-pink-100 text-purple-700 font-bold px-6 py-2 rounded-lg hover:from-purple-200 hover:to-pink-200 transition border-2 border-purple-200">
          → Go to CMS
        </a>
      </div>

      <!-- Back Link -->
      <div class="text-center mt-6">
        <a href="/en/admin-login" class="text-purple-600 hover:underline text-sm font-semibold">
          ← Back to login methods
        </a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('login-form');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const submitBtn = document.getElementById('submit-btn');
    const messageDiv = document.getElementById('message');
    const loadingDiv = document.getElementById('loading');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = emailInput.value;
      const password = passwordInput.value;

      // Clear previous messages
      messageDiv.classList.add('hidden');
      messageDiv.innerHTML = '';

      // Show loading
      loadingDiv.classList.remove('hidden');
      submitBtn.disabled = true;

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({ email, password })
        });

        const data = await response.json();

        if (data.success) {
          // Show success message
          messageDiv.classList.remove('hidden');
          messageDiv.classList.add('bg-green-100', 'text-green-800', 'border', 'border-green-400');
          messageDiv.textContent = '✓ Login successful! Redirecting to admin panel...';
          
          // Redirect after 2 seconds
          setTimeout(() => {
            window.location.href = '/admin/';
          }, 2000);
        } else {
          // Show error message
          messageDiv.classList.remove('hidden');
          messageDiv.classList.add('bg-red-100', 'text-red-800', 'border', 'border-red-400');
          messageDiv.textContent = `✗ Error: ${data.error}`;
          
          // Clear password field
          passwordInput.value = '';
          passwordInput.focus();
        }
      } catch (error) {
        messageDiv.classList.remove('hidden');
        messageDiv.classList.add('bg-red-100', 'text-red-800', 'border', 'border-red-400');
        messageDiv.textContent = '✗ Connection error. Please try again.';
      } finally {
        loadingDiv.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</MainLayout>
