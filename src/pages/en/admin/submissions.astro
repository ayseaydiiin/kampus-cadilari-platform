    async function setEventVisibility(item, shouldPublish, reason = null) {
      if (shouldPublish) {
        const response = await fetch(`/api/admin/event-proposals/${item.id}/approve`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ comment: 'Republished from records tab.' }),
        });
        const payload = await response.json();
        if (!response.ok || !payload.success) {
          showToast(payload.error || 'Event could not be restored.', 'error');
          return;
        }
        showToast('Event restored to published listing.', 'success');
        return;
      }

      const response = await fetch('/api/admin/event-proposals', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: item.id, notes: reason ? `Hidden from page. Reason: ${reason}` : 'Hidden from page from records tab.' }),
      });
      const payload = await response.json();
      if (!response.ok || !payload.success) {
        showToast(payload.error || 'Event could not be hidden.', 'error');
        return;
      }
      showToast('Event hidden from page listing.', 'success');
    }

    async function setArchiveVisibility(item, shouldPublish, reason = null) {
      const endpoint = `/api/admin/archive/${item.id}/${shouldPublish ? 'approve' : 'reject'}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          comment: shouldPublish
            ? 'Republished from records tab.'
            : (reason ? `Hidden from page. Reason: ${reason}` : 'Hidden from page from records tab.'),
        }),
      });
      const payload = await response.json();
      if (!response.ok || !payload.success) {
        showToast(payload.error || 'Archive record could not be updated.', 'error');
        return;
      }
      showToast(shouldPublish ? 'Archive record restored to published listing.' : 'Archive record hidden from page listing.', 'success');
    }

    async function loadRecordsTab() {
      recordsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Loading records...</p>';
      try {
        const [eventResp, archiveResp] = await Promise.all([
          fetch('/api/admin/event-proposals'),
          fetch('/api/admin/archive'),
        ]);
        const eventData = await eventResp.json();
        const archiveData = await archiveResp.json();
        const eventRows = (Array.isArray(eventData) ? eventData : []).map((item) => ({
          ...item,
          raw_status: String(item.status || '').toLowerCase(),
          category: localizeEventCategory(item.category),
          status: localizeStatus(item.status),
        }));
        const archiveRows = archiveData?.success && Array.isArray(archiveData.data)
          ? archiveData.data.map((item) => localizeArchiveItem(item))
          : [];

        const eventRecords = eventRows
          .filter((item) => ['approved', 'reviewed'].includes(String(item.raw_status || '').toLowerCase()))
          .map((item) => ({
            type: 'event',
            id: Number(item.id),
            title: item.title || 'Event',
            status: String(item.status || 'Reviewed'),
            subtitle: `${item.province || '-'} • ${item.category || '-'}`,
            raw: item,
            createdAt: item.created_at || item.reviewed_at || '',
          }));

        const archiveRecords = archiveRows
          .filter((item) => ['approved', 'reviewed', 'rejected'].includes(String(item.raw_status || '').toLowerCase()))
          .map((item) => ({
            type: 'archive',
            id: Number(item.id),
            title: item.title || 'Archive',
            status: String(item.status || 'Reviewed'),
            subtitle: `${item.publication_name || '-'} • ${item.publication_year || '-'}`,
            raw: item,
            createdAt: item.created_at || item.reviewed_at || '',
          }));

        const allRecords = [...eventRecords, ...archiveRecords]
          .sort((a, b) => new Date(b.createdAt || 0).getTime() - new Date(a.createdAt || 0).getTime());

        if (!allRecords.length) {
          recordsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">No records to display.</p>';
          return;
        }

        const pagination = getPageSlice(allRecords, 'records');
        recordsTab.innerHTML = pagination.items.map((record) => {
          const isVisible = record.status === 'approved';
          const actionLabel = isVisible ? 'Hide from Page' : 'Restore';
          const statusLabel = isVisible ? 'Published' : 'Hidden';
          return `
            <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0 flex-1">
                  <p class="text-xs font-bold uppercase tracking-wide text-slate-500">${record.type === 'event' ? 'Event' : 'Newspaper Archive'}</p>
                  <h3 class="mt-1 text-base font-black text-slate-900">${escapeHtml(record.title)}</h3>
                  <p class="mt-1 text-sm text-slate-600">${escapeHtml(record.subtitle)}</p>
                  <p class="mt-2 text-xs font-semibold uppercase tracking-wide ${isVisible ? 'text-emerald-700' : 'text-amber-700'}">${statusLabel}</p>
                </div>
                <div class="shrink-0">
                  <button
                    type="button"
                    class="record-toggle-btn rounded-lg px-3 py-2 text-sm font-bold ${isVisible ? 'bg-rose-600 text-white hover:bg-rose-700' : 'bg-emerald-600 text-white hover:bg-emerald-700'}"
                    data-type="${record.type}"
                    data-id="${record.id}"
                    data-status="${record.status}"
                  >${actionLabel}</button>
                </div>
              </div>
            </article>
          `;
        }).join('') + renderPager('records', pagination.totalPages, pagination.page);

        recordsTab.querySelectorAll('.record-toggle-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const type = String(button.dataset.type || '');
            const id = Number(button.dataset.id || '0');
            const status = String(button.dataset.status || '');
            const item = allRecords.find((entry) => entry.type === type && entry.id === id);
            if (!item) return;
            const shouldPublish = String(status || '').toLowerCase() !== 'approved';
            const confirmMessage = shouldPublish
              ? 'Do you want to restore this record to the page?'
              : 'Do you want to hide this record from the page?';
            const ok = await (ui ? ui.confirm(confirmMessage, 'Confirmation', 'Yes', 'Cancel') : Promise.resolve(false));
            if (!ok) return;
            let reason = null;
            if (!shouldPublish) {
              reason = await askText('Hide reason:', 'Write reason');
              if (!reason || !reason.trim()) {
                showToast('Reason is required.', 'warning');
                return;
              }
            }
            if (type === 'event') {
              await setEventVisibility(item.raw, shouldPublish, reason ? reason.trim() : null);
            } else {
              await setArchiveVisibility(item.raw, shouldPublish, reason ? reason.trim() : null);
            }
            await loadRecordsTab();
            await loadNotifications();
          });
        });

        recordsTab.querySelectorAll('.pager-btn').forEach((button) => {
          button.addEventListener('click', () => {
            pageState.records = Number(button.dataset.page || '1');
            loadRecordsTab();
          });
        });
      } catch (error) {
        recordsTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Records could not be loaded.</p>';
      }
    }

