---
import MainLayout from '../../../layouts/MainLayout.astro';
import AdminNotificationPanel from '../../../components/AdminNotificationPanel.astro';
---

<MainLayout title="Admin Submissions - Campus Witches" currentLang="en">
  <section class="mx-auto max-w-6xl px-4 py-8">
    <header class="rounded-2xl bg-gradient-to-r from-purple-700 to-pink-600 p-8 text-white shadow-xl">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-purple-100">Admin workflow</p>
          <h1 class="app-h1 mt-2 text-3xl font-black">Applications and Event Proposals</h1>
          <p class="mt-3 text-sm text-white/90">Manage the full approval workflow that requires admin decisions.</p>
        </div>
        <button id="notifToggleBtn" class="relative rounded-full bg-white px-5 py-2 font-bold text-purple-700 hover:bg-purple-50">
          Notifications
          <span id="notifBadge" class="ml-2 hidden rounded-full bg-rose-600 px-2 py-0.5 text-xs text-white">0</span>
        </button>
      </div>
    </header>

    <div id="authBox" class="mt-6 rounded-xl border border-gray-200 bg-white p-5 text-sm text-gray-600 shadow-sm">
      Checking session...
    </div>

    <div id="mainContent" class="mt-6 hidden space-y-6">
      <div class="rounded-xl border border-gray-200 bg-white p-3 shadow-sm">
        <div class="flex flex-wrap gap-2">
          <button data-tab="applications" class="tab-btn rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white">Join Us Applications</button>
          <button data-tab="events" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Event Proposals</button>
          <button data-tab="articles" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Article Approvals</button>
          <button data-tab="archive" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Newspaper Archive</button>
        </div>
      </div>

      <section id="applicationsTab" class="space-y-4"></section>
      <section id="eventsTab" class="hidden space-y-4"></section>
      <section id="articlesTab" class="hidden space-y-4"></section>
      <section id="archiveTab" class="hidden space-y-4"></section>
    </div>
  </section>

  <AdminNotificationPanel
    locale="en"
    panelId="notifPanel"
    listId="notifList"
    closeButtonId="notifCloseBtn"
    markAllButtonId="notifMarkAllBtn"
    deleteSelectedButtonId="notifDeleteSelectedBtn"
  />

  <div id="detailModal" class="fixed inset-0 z-40 hidden items-end justify-center bg-black/60 p-3 sm:items-center sm:p-4">
    <div class="flex max-h-[88vh] w-[min(94vw,40rem)] flex-col overflow-hidden rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-gray-200 px-4 py-3 sm:px-5 sm:py-4">
        <h3 id="detailTitle" class="text-xl font-black text-gray-900 sm:text-2xl">Details</h3>
        <button id="detailCloseBtn" class="rounded-full bg-gray-100 px-3 py-1 text-sm font-bold text-gray-600 transition hover:bg-gray-200">Close</button>
      </div>
      <div id="detailBody" class="min-h-0 flex-1 space-y-3 overflow-y-auto break-words px-4 py-4 text-sm text-gray-700 sm:px-5"></div>
      <div id="detailActions" class="flex flex-wrap gap-3 border-t border-gray-200 px-4 py-3 sm:px-5 sm:py-4"></div>
    </div>
  </div>

  <script is:inline src="/admin-ui.js"></script>
  <script>
    const authBox = document.getElementById('authBox');
    const mainContent = document.getElementById('mainContent');
    const applicationsTab = document.getElementById('applicationsTab');
    const eventsTab = document.getElementById('eventsTab');
    const articlesTab = document.getElementById('articlesTab');
    const archiveTab = document.getElementById('archiveTab');
    const tabButtons = document.querySelectorAll('.tab-btn');
    const notifToggleBtn = document.getElementById('notifToggleBtn');
    const notifPanel = document.getElementById('notifPanel');
    const notifList = document.getElementById('notifList');
    const notifBadge = document.getElementById('notifBadge');
    const notifCloseBtn = document.getElementById('notifCloseBtn');
    const notifMarkAllBtn = document.getElementById('notifMarkAllBtn');
    const notifDeleteSelectedBtn = document.getElementById('notifDeleteSelectedBtn');
    const detailModal = document.getElementById('detailModal');
    const detailTitle = document.getElementById('detailTitle');
    const detailBody = document.getElementById('detailBody');
    const detailActions = document.getElementById('detailActions');
    const detailCloseBtn = document.getElementById('detailCloseBtn');

    let adminUser = null;
    const ui = window.AdminUi?.create({ locale: 'en' });

    function showToast(message, type = 'info') {
      if (ui) {
        ui.toast(message, type);
        return;
      }
      console.log(message);
    }

    async function askText(message, placeholder = '') {
      if (ui) {
        return ui.prompt(message, 'Input required', placeholder);
      }
      return null;
    }
    let eventCache = [];
    let applicationCache = [];
    let articleCache = [];
    let archiveCache = [];
    let archiveAllCache = [];
    let activeTab = 'applications';

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function getTokenExpiryMs(token) {
      try {
        const payload = JSON.parse(atob(String(token).split('.')[1] || ''));
        if (payload?.exp) return Number(payload.exp) * 1000;
      } catch {}
      return null;
    }

    function clearAdminSession() {
      sessionStorage.removeItem('admin_auth_token');
      sessionStorage.removeItem('admin_auth_user');
      sessionStorage.removeItem('admin_auth_expires_at');
      localStorage.removeItem('admin_auth_token');
      localStorage.removeItem('admin_auth_user');
    }

    function setActiveTab(tabName) {
      activeTab = tabName;
      const isApplications = tabName === 'applications';
      const isEvents = tabName === 'events';
      const isArticles = tabName === 'articles';
      const isArchive = tabName === 'archive';
      applicationsTab.classList.toggle('hidden', !isApplications);
      eventsTab.classList.toggle('hidden', !isEvents);
      articlesTab.classList.toggle('hidden', !isArticles);
      archiveTab.classList.toggle('hidden', !isArchive);
      tabButtons.forEach((button) => {
        const active = button.dataset.tab === tabName;
        button.classList.toggle('bg-purple-600', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('bg-gray-100', !active);
        button.classList.toggle('text-gray-700', !active);
      });
    }

    function showModal(title, bodyHtml, actionsHtml = '') {
      detailTitle.textContent = title;
      detailBody.innerHTML = bodyHtml;
      detailActions.innerHTML = actionsHtml;
      detailActions.classList.toggle('hidden', !String(actionsHtml || '').trim());
      detailModal.classList.remove('hidden');
      detailModal.classList.add('flex');
    }

    function closeModal() {
      detailModal.classList.add('hidden');
      detailModal.classList.remove('flex');
    }

    async function loadNotifications() {
      if (!adminUser?.email) return;
      try {
        const response = await fetch(`/api/admin/notifications?adminEmail=${encodeURIComponent(adminUser.email)}&limit=40`);
        const data = await response.json();
        if (!data.success) return;

        const unreadCount = Number(data.unreadCount || 0);
        notifBadge.textContent = unreadCount;
        notifBadge.classList.toggle('hidden', unreadCount === 0);

        if (!data.notifications.length) {
          notifList.innerHTML = '<p class="rounded-lg bg-gray-50 p-3 text-sm text-gray-500">No notifications.</p>';
          return;
        }

        notifList.innerHTML = data.notifications
          .map(
            (item) => `
              <label class="block rounded-xl border p-3 ${item.is_read ? 'border-slate-200 bg-white' : 'border-purple-200 bg-purple-50'}">
                <div class="flex items-start gap-3">
                  <input type="checkbox" class="notif-select mt-1" value="${item.id}" />
                  <div class="flex-1">
                    <p class="text-xs font-bold uppercase tracking-wide ${item.is_read ? 'text-gray-500' : 'text-purple-700'}">${escapeHtml(item.type)}</p>
                    <p class="mt-1 text-sm font-semibold text-slate-900">${escapeHtml(item.title || 'Notification')}</p>
                    <p class="mt-1 text-xs text-slate-600">${escapeHtml(item.message || '')}</p>
                  </div>
                </div>
              </label>
            `
          )
          .join('');
      } catch (error) {
        notifList.innerHTML = '<p class="rounded-lg bg-red-50 p-3 text-sm text-red-700">Notifications could not be loaded.</p>';
      }
    }

    async function loadApplications() {
      applicationsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Loading applications...</p>';
      try {
        const response = await fetch('/api/admin/applications');
        const data = await response.json();
        applicationCache = Array.isArray(data) ? data : [];

        if (!applicationCache.length) {
          applicationsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">No applications found.</p>';
          return;
        }

        applicationsTab.innerHTML = applicationCache.map((app) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(app.full_name)}</h3>
                <p class="text-sm text-gray-600">${escapeHtml(app.email)} • ${escapeHtml(app.province)}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-purple-700">${escapeHtml(app.status)}</p>
              </div>
              <div class="shrink-0 flex flex-nowrap items-center gap-2 overflow-x-auto whitespace-nowrap pb-1">
                <button data-id="${app.id}" class="app-detail-btn rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white hover:bg-purple-700">Details</button>
              </div>
            </div>
          </article>
        `).join('');

        applicationsTab.querySelectorAll('.app-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const appId = Number(button.dataset.id);
            const app = applicationCache.find((item) => Number(item.id) === appId);
            if (app) showApplicationDetail(app);
          });
        });
      } catch (error) {
        applicationsTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Applications could not be loaded.</p>';
      }
    }

    async function loadEventProposals() {
      eventsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Loading event proposals...</p>';
      try {
        const response = await fetch('/api/admin/event-proposals');
        const data = await response.json();
        eventCache = Array.isArray(data) ? data : [];

        if (!eventCache.length) {
          eventsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">No event proposals found.</p>';
          return;
        }

        eventsTab.innerHTML = eventCache.map((event) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(event.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(event.proposed_by)} • ${escapeHtml(event.email)}</p>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(event.province || '-')} • ${escapeHtml(event.category || '-')}</p>
                <p class="mt-2 text-sm text-gray-700">${escapeHtml((event.description || '').slice(0, 180))}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Status: ${escapeHtml(event.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Approval: ${event.approval_summary?.approvedCount || 0}/${event.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Reject: ${event.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="shrink-0 flex flex-nowrap items-center gap-2 overflow-x-auto whitespace-nowrap pb-1">
                <button data-id="${event.id}" class="event-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Details</button>
                <button data-id="${event.id}" class="event-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
                <button data-id="${event.id}" class="event-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
              </div>
            </div>
          </article>
        `).join('');

        eventsTab.querySelectorAll('.event-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const proposal = eventCache.find((item) => Number(item.id) === Number(button.dataset.id));
            if (proposal) showEventDetail(proposal);
          });
        });

        eventsTab.querySelectorAll('.event-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const proposalId = Number(button.dataset.id);
            await submitEventDecision(proposalId, 'approve');
          });
        });

        eventsTab.querySelectorAll('.event-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const proposalId = Number(button.dataset.id);
            await submitEventDecision(proposalId, 'reject');
          });
        });
      } catch (error) {
        eventsTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Event proposals could not be loaded.</p>';
      }
    }

    async function loadArticleSubmissions() {
      articlesTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Loading article approvals...</p>';
      try {
        const response = await fetch('/api/admin/articles');
        const payload = await response.json();
        const allArticles = payload?.success && Array.isArray(payload.data) ? payload.data : [];
        articleCache = allArticles;
        const pendingArticles = allArticles.filter((item) => ['pending_approval', 'rejected'].includes(String(item.status)));

        if (!pendingArticles.length) {
          articlesTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">No articles pending review.</p>';
          return;
        }

        articlesTab.innerHTML = pendingArticles.map((item) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(item.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.category || 'No category')} - /${escapeHtml(item.slug)}</p>
                <p class="mt-2 text-sm text-gray-700 line-clamp-2">${escapeHtml(item.excerpt || '')}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Status: ${escapeHtml(item.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Approval: ${item.approval_summary?.approvedCount || 0}/${item.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Reject: ${item.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="shrink-0 flex flex-nowrap items-center gap-2 overflow-x-auto whitespace-nowrap pb-1">
                <button data-id="${item.id}" class="article-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Details</button>
                <button data-id="${item.id}" class="article-comment-btn rounded-lg bg-amber-500 px-3 py-2 text-sm font-bold text-white hover:bg-amber-600">Comment</button>
                <button data-id="${item.id}" class="article-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
                <button data-id="${item.id}" class="article-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
              </div>
            </div>
          </article>
        `).join('');

        articlesTab.querySelectorAll('.article-detail-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const id = Number(button.dataset.id);
            const result = await fetch(`/api/admin/articles?id=${id}`).then((r) => r.json());
            if (result.success && result.data) showArticleDetail(result.data);
          });
        });

        articlesTab.querySelectorAll('.article-comment-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const id = Number(button.dataset.id);
            await submitArticleComment(id);
          });
        });

        articlesTab.querySelectorAll('.article-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArticleDecision(Number(button.dataset.id), 'approve');
          });
        });

        articlesTab.querySelectorAll('.article-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArticleDecision(Number(button.dataset.id), 'reject');
          });
        });
      } catch (error) {
        articlesTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Article approvals could not be loaded.</p>';
      }
    }

    async function loadArchiveSubmissions() {
      archiveTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Loading archive records...</p>';
      try {
        const response = await fetch('/api/admin/archive');
        const payload = await response.json();
        const allArchiveRows = payload?.success && Array.isArray(payload.data) ? payload.data : [];
        archiveAllCache = allArchiveRows;
        archiveCache = allArchiveRows.filter((item) => ['pending', 'reviewed'].includes(String(item.status)));

        if (!archiveCache.length) {
          archiveTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">No archive records pending review.</p>';
          return;
        }

        archiveTab.innerHTML = archiveCache.map((item) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(item.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.publication_name)} • ${escapeHtml(item.publication_year)}</p>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.focus_topic || 'General agenda')}</p>
                <p class="mt-2 text-sm text-gray-700 line-clamp-2">${escapeHtml(item.summary || '')}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Status: ${escapeHtml(item.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Approval: ${item.approval_summary?.approvedCount || 0}/${item.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Reject: ${item.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="shrink-0 flex flex-nowrap items-center gap-2 overflow-x-auto whitespace-nowrap pb-1">
                <button data-id="${item.id}" class="archive-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Details</button>
                <button data-id="${item.id}" class="archive-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
                <button data-id="${item.id}" class="archive-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
              </div>
            </div>
          </article>
        `).join('');

        archiveTab.querySelectorAll('.archive-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const item = archiveCache.find((entry) => Number(entry.id) === Number(button.dataset.id));
            if (item) showArchiveDetail(item);
          });
        });

        archiveTab.querySelectorAll('.archive-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArchiveDecision(Number(button.dataset.id), 'approve');
          });
        });

        archiveTab.querySelectorAll('.archive-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArchiveDecision(Number(button.dataset.id), 'reject');
          });
        });
      } catch (error) {
        archiveTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Archive records could not be loaded.</p>';
      }
    }

    function showArchiveDetail(item) {
      const approvalItems = (item.approvals || []).map((entry) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(entry.admin_email)}</strong> • ${escapeHtml(entry.decision)} • ${escapeHtml(entry.comment || '-')}
        </li>
      `).join('');

      showModal(
        `${item.publication_name} - Archive Record`,
        `
          <p><strong>Title:</strong> ${escapeHtml(item.title)}</p>
          <p><strong>Year:</strong> ${escapeHtml(item.publication_year)} (${escapeHtml(item.decade || '-')})</p>
          <p><strong>Focus:</strong> ${escapeHtml(item.focus_topic || '-')}</p>
          <p><strong>Status:</strong> ${escapeHtml(item.status)}</p>
          <p><strong>Summary:</strong> ${escapeHtml(item.summary || '-')}</p>
          <p><strong>PDF:</strong> ${item.pdf_url ? `<a class="text-purple-700 underline" href="${escapeHtml(item.pdf_url)}" download>Download PDF</a>` : '-'}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin decision history</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">No decisions yet.</li>'}</ul>
          </div>
        `,
        `
          <button id="archiveApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
          <button id="archiveRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
        `
      );

      document.getElementById('archiveApproveBtn')?.addEventListener('click', () => submitArchiveDecision(item.id, 'approve'));
      document.getElementById('archiveRejectBtn')?.addEventListener('click', () => submitArchiveDecision(item.id, 'reject'));
    }

    function showApplicationDetail(app) {
      showModal(
        `${app.full_name} - Application`,
        `
          <p><strong>Email:</strong> ${escapeHtml(app.email)}</p>
          <p><strong>Phone:</strong> ${escapeHtml(app.phone || '-')}</p>
          <p><strong>City:</strong> ${escapeHtml(app.province)}</p>
          <p><strong>Organization:</strong> ${escapeHtml(app.organization || '-')}</p>
          <p><strong>Message:</strong> ${escapeHtml(app.message || '-')}</p>
          <p><strong>Status:</strong> ${escapeHtml(app.status)}</p>
        `,
        `
          <button id="appApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
          <button id="appRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
        `
      );

      document.getElementById('appApproveBtn')?.addEventListener('click', () => updateApplicationStatus(app.id, 'approved'));
      document.getElementById('appRejectBtn')?.addEventListener('click', () => updateApplicationStatus(app.id, 'rejected'));
    }

    function showEventDetail(event) {
      const approvalItems = (event.approvals || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> • ${escapeHtml(item.decision)} • ${escapeHtml(item.comment || '-')}
        </li>
      `).join('');

      showModal(
        `${event.title} - Event Proposal`,
        `
          <p><strong>Proposed by:</strong> ${escapeHtml(event.proposed_by)} (${escapeHtml(event.email)})</p>
          <p><strong>City:</strong> ${escapeHtml(event.province || '-')}</p>
          <p><strong>Category:</strong> ${escapeHtml(event.category || '-')}</p>
          <p><strong>Phone:</strong> ${escapeHtml(event.organizer_phone || '-')}</p>
          <p><strong>Status:</strong> ${escapeHtml(event.status)}</p>
          <p><strong>Description:</strong> ${escapeHtml(event.description || '-')}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin decision history</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">No decisions yet.</li>'}</ul>
          </div>
        `,
        `
          <button id="eventApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
          <button id="eventRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
        `
      );

      document.getElementById('eventApproveBtn')?.addEventListener('click', () => submitEventDecision(event.id, 'approve'));
      document.getElementById('eventRejectBtn')?.addEventListener('click', () => submitEventDecision(event.id, 'reject'));
    }

    function showArticleDetail(article) {
      const approvalItems = (article.approvals || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> - ${escapeHtml(item.decision)} - ${escapeHtml(item.comment || '-')}
        </li>
      `).join('');

      const commentItems = (article.comments || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> - ${escapeHtml(item.comment)} - ${new Date(item.created_at).toLocaleString('en-US')}
        </li>
      `).join('');

      showModal(
        `${article.title} - Article Approval`,
        `
          <p><strong>Category:</strong> ${escapeHtml(article.category || '-')}</p>
          <p><strong>Slug:</strong> /${escapeHtml(article.slug || '-')}</p>
          <p><strong>Status:</strong> ${escapeHtml(article.status)}</p>
          <p><strong>Short text:</strong> ${escapeHtml(article.excerpt || '-')}</p>
          <p><strong>Long text:</strong> ${escapeHtml(String(article.body || '').slice(0, 600))}${String(article.body || '').length > 600 ? '...' : ''}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin decision history</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">No decisions yet.</li>'}</ul>
          </div>
          <div class="mt-3">
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin comments</p>
            <ul class="space-y-1">${commentItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">No comments yet.</li>'}</ul>
          </div>
        `,
        `
          <button id="articleCommentBtn" class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-bold text-white hover:bg-amber-600">Add Comment</button>
          <button id="articleApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Approve</button>
          <button id="articleRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reject</button>
        `
      );

      document.getElementById('articleCommentBtn')?.addEventListener('click', () => submitArticleComment(article.id));
      document.getElementById('articleApproveBtn')?.addEventListener('click', () => submitArticleDecision(article.id, 'approve'));
      document.getElementById('articleRejectBtn')?.addEventListener('click', () => submitArticleDecision(article.id, 'reject'));
    }

    async function updateApplicationStatus(id, status) {
      const notes = (await askText('Optional admin note:', 'Add a note if needed')) || null;
      await fetch('/api/admin/applications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id,
          status,
          notes,
          reviewedBy: adminUser?.email || 'admin',
        }),
      });
      closeModal();
      showToast('Application status updated.', 'success');
      await loadApplications();
      await loadNotifications();
    }

    async function submitEventDecision(proposalId, action) {
      const comment = (await askText(action === 'approve' ? 'Approval note (optional):' : 'Rejection reason (optional):', 'Add a note if needed')) || null;
      const endpoint = `/api/admin/event-proposals/${proposalId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        showToast(data.error || 'Operation failed', 'error');
        return;
      }

      closeModal();
      showToast(action === 'approve' ? 'Event approved.' : 'Event rejected.', 'success');
      await loadEventProposals();
      await loadNotifications();
    }

    async function submitArticleDecision(articleId, action) {
      const comment = (await askText(action === 'approve' ? 'Approval note (optional):' : 'Rejection reason (optional):', 'Add a note if needed')) || null;
      const endpoint = `/api/admin/articles/${articleId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        showToast(data.error || 'Operation failed', 'error');
        return;
      }

      closeModal();
      showToast(action === 'approve' ? 'Article approved.' : 'Article rejected.', 'success');
      await loadArticleSubmissions();
      await loadNotifications();
    }

    async function submitArticleComment(articleId) {
      const comment = await askText('Admin comment:', 'Write your comment');
      if (!comment || !comment.trim()) return;

      const response = await fetch('/api/admin/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'comment',
          articleId,
          adminEmail: adminUser?.email,
          comment: comment.trim(),
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        showToast(data.error || 'Comment could not be saved', 'error');
        return;
      }

      showToast('Comment saved.', 'success');
      await loadArticleSubmissions();
      await loadNotifications();
    }

    async function submitArchiveDecision(archiveId, action) {
      const comment = (await askText(action === 'approve' ? 'Approval note (optional):' : 'Rejection reason (optional):', 'Add a note if needed')) || null;
      const endpoint = `/api/admin/archive/${archiveId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        showToast(data.error || 'Operation failed', 'error');
        return;
      }

      closeModal();
      showToast(action === 'approve' ? 'Archive record approved.' : 'Archive record rejected.', 'success');
      await loadArchiveSubmissions();
      await loadNotifications();
    }

    function initAuth() {
      const token = sessionStorage.getItem('admin_auth_token');
      const rawUser = sessionStorage.getItem('admin_auth_user');
      const expiresAtRaw = sessionStorage.getItem('admin_auth_expires_at');
      if (!token || !rawUser) {
        clearAdminSession();
        authBox.innerHTML = 'Access not found. <a class="font-semibold text-purple-700 underline" href="/en/admin/login-email">Sign in</a>.';
        setTimeout(() => window.location.replace('/en/admin/login-email'), 600);
        return false;
      }

      const expiresAt = Number(expiresAtRaw || '0');
      const tokenExpiry = getTokenExpiryMs(token);
      const effectiveExpiry = tokenExpiry ? Math.min(expiresAt || tokenExpiry, tokenExpiry) : expiresAt;
      if (!effectiveExpiry || Date.now() >= effectiveExpiry) {
        clearAdminSession();
        authBox.innerHTML = 'Session expired. <a class="font-semibold text-purple-700 underline" href="/en/admin/login-email">Sign in again</a>.';
        setTimeout(() => window.location.replace('/en/admin/login-email'), 600);
        return false;
      }

      try {
        adminUser = JSON.parse(rawUser);
      } catch {
        clearAdminSession();
        authBox.textContent = 'Session data could not be read.';
        return false;
      }

      authBox.innerHTML = `<span class="font-semibold text-gray-900">${escapeHtml(adminUser.email || 'admin')}</span> signed in.`;
      mainContent.classList.remove('hidden');
      return true;
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => setActiveTab(button.dataset.tab));
    });

    detailCloseBtn?.addEventListener('click', closeModal);
    detailModal?.addEventListener('click', (event) => {
      if (event.target === detailModal) closeModal();
    });

    notifToggleBtn?.addEventListener('click', () => {
      notifPanel.classList.toggle('hidden');
    });

    notifCloseBtn?.addEventListener('click', () => {
      notifPanel.classList.add('hidden');
    });

    notifMarkAllBtn?.addEventListener('click', async () => {
      await fetch('/api/admin/notifications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ adminEmail: adminUser?.email, markAll: true }),
      });
      await loadNotifications();
    });

    notifDeleteSelectedBtn?.addEventListener('click', async () => {
      const ids = Array.from(document.querySelectorAll('.notif-select:checked')).map((el) => Number(el.value));
      if (!ids.length) {
        showToast('Please select notifications to delete.', 'warning');
        return;
      }
      await fetch('/api/admin/notifications', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ adminEmail: adminUser?.email, notificationIds: ids }),
      });
      await loadNotifications();
    });

    document.addEventListener('click', (event) => {
      if (!notifPanel.contains(event.target) && !notifToggleBtn.contains(event.target)) {
        notifPanel.classList.add('hidden');
      }
    });

    if (initAuth()) {
      setActiveTab('applications');
      loadApplications();
      loadEventProposals();
      loadArticleSubmissions();
      loadArchiveSubmissions();
      loadNotifications();
    }
  </script>
</MainLayout>

