---
import MainLayout from '../../../layouts/MainLayout.astro';
import AdminNotificationPanel from '../../../components/AdminNotificationPanel.astro';
import fs from 'node:fs';
import path from 'node:path';
import { getCategoryDefinitions } from '../../../utils/articleCategories';

const articlesDir = path.join(process.cwd(), 'content', 'articles');
const eventsDir = path.join(process.cwd(), 'content', 'events');
const articleCount = fs.existsSync(articlesDir) ? fs.readdirSync(articlesDir).filter((item) => item.endsWith('.md') || item.endsWith('.mdx')).length : 0;
const eventCount = fs.existsSync(eventsDir) ? fs.readdirSync(eventsDir).filter((item) => item.endsWith('.md') || item.endsWith('.mdx')).length : 0;
const archiveCount = 0;
const articleCategories = getCategoryDefinitions();
---

<MainLayout title="Admin Panel - Campus Witches" currentLang="en">
  <section class="mx-auto max-w-6xl">
    <div id="admin-loading" class="rounded-[1.75rem] bg-gradient-to-br from-purple-700 to-pink-600 p-8 text-white shadow-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-purple-100">Dashboard</p>
      <h1 class="app-h1 mt-3 text-4xl font-black">Opening Digital HQ</h1>
      <p class="mt-4 max-w-2xl text-white/85">Verifying identity and loading admin workspace.</p>
    </div>

    <div id="admin-panel" class="hidden">
      <section class="rounded-[1.75rem] bg-gradient-to-br from-purple-700 to-pink-600 p-8 text-white shadow-2xl">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-purple-100">Main dashboard</p>
            <h1 class="app-h1 mt-3 text-4xl font-black">Welcome, <span id="admin-name">admin</span></h1>
            <p class="mt-4 max-w-2xl text-white/85">Manage content cards and admin notifications from this dashboard.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <button id="notif-toggle-btn" class="relative rounded-full border border-white/40 bg-white/15 px-5 py-3 font-bold text-white transition hover:bg-white/25">
              Notifications
              <span id="notif-badge" class="ml-2 hidden rounded-full bg-amber-300 px-2 py-0.5 text-xs font-bold text-amber-900">0</span>
            </button>
            <button id="logout-button" class="rounded-full bg-white px-6 py-3 font-bold text-purple-700 transition hover:bg-amber-100">Log out</button>
          </div>
        </div>
      </section>

      <section class="mt-8 grid gap-4 md:grid-cols-4">
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Session</p>
          <p id="admin-email" class="mt-3 text-lg font-black text-slate-900"></p>
          <p id="admin-role" class="mt-1 text-sm text-slate-600"></p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-purple-700">Total articles</p>
          <p id="stat-articles" class="mt-3 text-4xl font-black text-slate-900">{articleCount}</p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-amber-700">Total archive records</p>
          <p id="stat-archive" class="mt-3 text-4xl font-black text-slate-900">{archiveCount}</p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-rose-600">Total events</p>
          <p id="stat-events" class="mt-3 text-4xl font-black text-slate-900">{eventCount}</p>
        </article>
      </section>

      <section class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <div class="grid gap-6">
          <article class="rounded-[1.75rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.2em] text-fuchsia-700">Content Management</p>
                <p class="mt-1 text-sm text-slate-600">Create a new article card, fill all fields, and save.</p>
              </div>
              <button id="article-add-btn" class="rounded-full bg-fuchsia-600 px-4 py-2 font-bold text-white hover:bg-fuchsia-700">New Article Card</button>
            </div>
            <div id="article-list" class="mt-5 space-y-3"></div>
          </article>
        </div>

        <div class="grid gap-6">
          <article class="rounded-[1.75rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-rose-600">Quick access</p>
            <div class="mt-5 grid gap-3">
              <a href="/en/articles" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Go to article archive</a>
              <a href="/en/archive" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Open newspaper archive</a>
              <a href="/en/events" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Open event calendar</a>
              <a href="/en/admin/submissions" class="rounded-2xl bg-purple-100 px-4 py-4 font-semibold text-purple-800 transition hover:bg-purple-200">-> Submissions and approval workflows</a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </section>

  <AdminNotificationPanel locale="en" />

  <div id="article-modal" class="fixed inset-0 z-50 hidden items-end justify-center bg-black/60 p-3 sm:items-center sm:p-4">
    <div class="flex max-h-[88vh] w-[min(94vw,56rem)] flex-col overflow-hidden rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3 sm:px-6 sm:py-4">
        <h3 id="article-modal-title" class="text-2xl font-black text-slate-900">New Article</h3>
        <button id="article-modal-close" class="rounded-full bg-slate-100 px-3 py-1 text-sm font-bold text-slate-600">Close</button>
      </div>
      <form id="article-form" class="grid max-h-[72vh] gap-4 overflow-y-auto px-4 py-4 sm:max-h-[74vh] sm:px-6 sm:py-5 md:grid-cols-2">
        <input type="hidden" name="id" />
        <div>
          <label class="text-sm font-semibold text-slate-700">Title</label>
          <input name="title" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" />
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Image URL</label>
          <input name="image_url" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" placeholder="https://..." />
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Slug (URL)</label>
          <input name="slug" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" placeholder="article-title" />
          <p class="mt-1 text-xs text-slate-500">Slug is the SEO-friendly short identifier used in the article URL.</p>
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Category</label>
          <select name="category" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2">
            {articleCategories.map((category) => (
              <option value={category.tr}>{category.en}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Status</label>
          <select name="status" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2">
            <option value="draft">Draft</option>
            <option value="pending_approval">Pending admin approval</option>
            <option value="published">Published</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="text-sm font-semibold text-slate-700">Content (Short text)</label>
          <textarea name="excerpt" rows="3" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2"></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="text-sm font-semibold text-slate-700">Long text</label>
          <textarea name="body" rows="8" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2"></textarea>
        </div>
        <div class="md:col-span-2 flex justify-end gap-3">
          <button id="article-modal-cancel" type="button" class="rounded-xl border border-slate-300 px-4 py-2 font-semibold text-slate-700">Cancel</button>
          <button type="submit" class="rounded-xl bg-fuchsia-600 px-4 py-2 font-semibold text-white hover:bg-fuchsia-700">Save</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline src="/admin-ui.js"></script>
  <script>
    const loadingBox = document.getElementById('admin-loading');
    const panel = document.getElementById('admin-panel');
    const adminName = document.getElementById('admin-name');
    const adminEmail = document.getElementById('admin-email');
    const adminRole = document.getElementById('admin-role');
    const logoutButton = document.getElementById('logout-button');
    const articleList = document.getElementById('article-list');
    const articleAddBtn = document.getElementById('article-add-btn');
    const articleModal = document.getElementById('article-modal');
    const articleModalTitle = document.getElementById('article-modal-title');
    const articleModalClose = document.getElementById('article-modal-close');
    const articleModalCancel = document.getElementById('article-modal-cancel');
    const articleForm = document.getElementById('article-form');
    const notifToggleBtn = document.getElementById('notif-toggle-btn');
    const notifBadge = document.getElementById('notif-badge');
    const notifPanel = document.getElementById('notif-panel');
    const notifList = document.getElementById('notif-list');
    const notifCloseBtn = document.getElementById('notif-close-btn');
    const notifMarkAllBtn = document.getElementById('notif-mark-all-btn');
    const notifDeleteSelectedBtn = document.getElementById('notif-delete-selected-btn');
    const statArticles = document.getElementById('stat-articles');
    const statArchive = document.getElementById('stat-archive');
    const statEvents = document.getElementById('stat-events');

    let currentAdmin = null;
    const ui = window.AdminUi?.create({ locale: 'en' });

    function showToast(message, type = 'info') {
      if (ui) {
        ui.toast(message, type);
        return;
      }
      console.log(message);
    }

    async function askText(message, placeholder = '') {
      if (ui) {
        return ui.prompt(message, 'Input required', placeholder);
      }
      return null;
    }

    async function askConfirm(message) {
      if (ui) {
        return ui.confirm(message, 'Confirmation required', 'Yes', 'Cancel');
      }
      return false;
    }

    async function showDetails(message, title = 'Details') {
      if (ui) {
        await ui.details(message, title);
        return;
      }
      console.log(message);
    }

    function escapeHtml(value) {
      return String(value || '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;');
    }

    function getTokenExpiryMs(token) {
      try {
        const payload = JSON.parse(atob(String(token).split('.')[1] || ''));
        if (payload?.exp) return Number(payload.exp) * 1000;
      } catch {}
      return null;
    }

    function clearAdminSession() {
      sessionStorage.removeItem('admin_auth_token');
      sessionStorage.removeItem('admin_auth_user');
      sessionStorage.removeItem('admin_auth_expires_at');
      localStorage.removeItem('admin_auth_token');
      localStorage.removeItem('admin_auth_user');
    }

    function openModal(node) {
      node?.classList.remove('hidden');
      node?.classList.add('flex');
    }

    function closeModal(node) {
      node?.classList.add('hidden');
      node?.classList.remove('flex');
    }

    function bootAdminPanel() {
      const token = sessionStorage.getItem('admin_auth_token');
      const userRaw = sessionStorage.getItem('admin_auth_user');
      const expiresAtRaw = sessionStorage.getItem('admin_auth_expires_at');
      if (!token || !userRaw) {
        clearAdminSession();
        return window.location.replace('/en/admin/login-email');
      }

      const expiresAt = Number(expiresAtRaw || '0');
      const tokenExpiry = getTokenExpiryMs(token);
      const effectiveExpiry = tokenExpiry ? Math.min(expiresAt || tokenExpiry, tokenExpiry) : expiresAt;
      if (!effectiveExpiry || Date.now() >= effectiveExpiry) {
        clearAdminSession();
        return window.location.replace('/en/admin/login-email');
      }

      try {
        currentAdmin = JSON.parse(userRaw);
      } catch {
        clearAdminSession();
        return window.location.replace('/en/admin/login-email');
      }

      adminName.textContent = currentAdmin.username || 'admin';
      adminEmail.textContent = currentAdmin.email || '';
      adminRole.textContent = `Role: ${currentAdmin.role || 'editor'}`;
      loadingBox.classList.add('hidden');
      panel.classList.remove('hidden');
    }

    logoutButton?.addEventListener('click', async () => {
      clearAdminSession();
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.replace('/en/admin/login-email');
    });

    async function loadStats() {
      try {
        const res = await fetch('/api/admin/stats');
        const json = await res.json();
        if (!json.success) return;
        if (statArticles) statArticles.textContent = json.articles ?? statArticles.textContent;
        if (statArchive) statArchive.textContent = json.archive?.total ?? statArchive.textContent;
        if (statEvents) statEvents.textContent = json.proposals?.total ?? statEvents.textContent;
      } catch {}
    }

    async function loadNotifications() {
      if (!currentAdmin?.email) return;
      const res = await fetch(`/api/admin/notifications?adminEmail=${encodeURIComponent(currentAdmin.email)}&limit=40`);
      const json = await res.json();
      if (!json.success) return;

      const unread = Number(json.unreadCount || 0);
      notifBadge.textContent = unread;
      notifBadge.classList.toggle('hidden', unread === 0);

      if (!json.notifications.length) {
        notifList.innerHTML = '<p class="rounded-lg bg-gray-50 p-3 text-sm text-gray-500">No notifications.</p>';
        return;
      }

      notifList.innerHTML = json.notifications
        .map(
          (item) => `
            <label class="block rounded-xl border p-3 ${item.is_read ? 'border-slate-200 bg-white' : 'border-purple-200 bg-purple-50'}">
              <div class="flex items-start gap-3">
                <input type="checkbox" class="notif-select mt-1" value="${item.id}" />
                <div class="flex-1">
                  <p class="text-xs font-bold uppercase tracking-wide">${escapeHtml(item.type)}</p>
                  <p class="mt-1 text-sm font-semibold text-slate-900">${escapeHtml(item.title || 'Notification')}</p>
                  <p class="mt-1 text-xs text-slate-600">${escapeHtml(item.message || '')}</p>
                </div>
              </div>
            </label>
          `
        )
        .join('');
    }

    notifToggleBtn?.addEventListener('click', () => notifPanel.classList.toggle('hidden'));
    notifCloseBtn?.addEventListener('click', () => notifPanel.classList.add('hidden'));
    notifMarkAllBtn?.addEventListener('click', async () => {
      await fetch('/api/admin/notifications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ adminEmail: currentAdmin?.email, markAll: true }),
      });
      loadNotifications();
    });
    notifDeleteSelectedBtn?.addEventListener('click', async () => {
      const ids = Array.from(document.querySelectorAll('.notif-select:checked')).map((el) => Number(el.value));
      if (!ids.length) {
        showToast('Please select notifications to delete.', 'warning');
        return;
      }
      await fetch('/api/admin/notifications', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ adminEmail: currentAdmin?.email, notificationIds: ids }),
      });
      loadNotifications();
    });

    async function loadArticles() {
      articleList.innerHTML = '<div class="text-sm text-gray-500">Loading...</div>';
      const res = await fetch('/api/admin/articles');
      const json = await res.json();
      if (!json.success) {
        articleList.innerHTML = `<div class="text-sm text-red-600">${escapeHtml(json.error || 'Error')}</div>`;
        return;
      }
      if (!json.data.length) {
        articleList.innerHTML = '<div class="text-sm text-gray-500">No articles yet.</div>';
        return;
      }

      articleList.innerHTML = json.data
        .map(
          (a) => `
            <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0 flex-1">
                  <p class="font-bold text-slate-900">${escapeHtml(a.title)}</p>
                  <p class="mt-1 text-xs text-slate-500">/${escapeHtml(a.slug)} - ${escapeHtml(a.status)}</p>
                  <p class="text-xs text-slate-500">${escapeHtml(a.category || 'No category')}</p>
                  <p class="mt-1 text-[11px] font-semibold text-slate-500">Approval: ${a.approval_summary?.approvedCount || 0}/${a.approval_summary?.adminCount || 0} - Reject: ${a.approval_summary?.rejectedCount || 0}</p>
                </div>
                <div class="shrink-0 flex flex-nowrap items-center gap-2 overflow-x-auto whitespace-nowrap pb-1">
                  <button data-id="${a.id}" class="article-detail rounded border border-slate-300 bg-white px-3 py-1 text-xs font-bold text-slate-700">Details</button>
                  <button data-id="${a.id}" class="article-comment rounded bg-amber-100 px-3 py-1 text-xs font-bold text-amber-800">Comment</button>
                  <button data-id="${a.id}" class="article-approve rounded bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-800">Approve</button>
                  <button data-id="${a.id}" class="article-reject rounded bg-rose-100 px-3 py-1 text-xs font-bold text-rose-800">Reject</button>
                  <button data-id="${a.id}" class="article-edit rounded bg-slate-100 px-3 py-1 text-xs font-bold text-slate-700">Edit</button>
                  <button data-id="${a.id}" class="article-del rounded bg-red-100 px-3 py-1 text-xs font-bold text-red-700">Delete</button>
                </div>
              </div>
            </article>
          `
        )
        .join('');

      articleList.querySelectorAll('.article-detail').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const detail = await fetch(`/api/admin/articles?id=${btn.dataset.id}`).then((r) => r.json());
          if (!detail.success || !detail.data) return;
          const item = detail.data;
          const approvals =
            (item.approvals || [])
              .map((entry) => `${entry.admin_email}: ${entry.decision}${entry.comment ? ` (${entry.comment})` : ''}`)
              .join('\n') || 'No decisions yet';
          const comments = (item.comments || []).map((entry) => `${entry.admin_email}: ${entry.comment}`).join('\n') || 'No comments yet';
          await showDetails(
            `Article: ${item.title}\nStatus: ${item.status}\nSlug: /${item.slug}\n\nAdmin decisions:\n${approvals}\n\nAdmin comments:\n${comments}`,
            'Article details'
          );
        });
      });

      articleList.querySelectorAll('.article-comment').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = await askText('Admin comment:', 'Write your comment');
          if (!comment || !comment.trim()) return;
          const response = await fetch('/api/admin/articles', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              action: 'comment',
              articleId: Number(btn.dataset.id),
              adminEmail: currentAdmin?.email,
              comment: comment.trim(),
            }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Comment could not be added', 'error');
            return;
          }
          showToast('Comment added.', 'success');
          loadArticles();
          loadNotifications();
        });
      });

      articleList.querySelectorAll('.article-approve').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = (await askText('Approval note (optional):', 'Write approval note')) || null;
          const response = await fetch(`/api/admin/articles/${btn.dataset.id}/approve`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ adminEmail: currentAdmin?.email, comment }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Approval failed', 'error');
            return;
          }
          showToast('Approval saved.', 'success');
          loadArticles();
          loadNotifications();
          loadStats();
        });
      });

      articleList.querySelectorAll('.article-reject').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = (await askText('Rejection reason (optional):', 'Write rejection reason')) || null;
          const response = await fetch(`/api/admin/articles/${btn.dataset.id}/reject`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ adminEmail: currentAdmin?.email, comment }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Rejection failed', 'error');
            return;
          }
          showToast('Rejection saved.', 'success');
          loadArticles();
          loadNotifications();
          loadStats();
        });
      });

      articleList.querySelectorAll('.article-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
          const article = json.data.find((row) => Number(row.id) === Number(btn.dataset.id));
          if (!article) return;
          articleModalTitle.textContent = 'Edit Article';
          articleForm.elements.id.value = article.id;
          articleForm.elements.title.value = article.title || '';
          articleForm.elements.image_url.value = article.image_url || '';
          articleForm.elements.slug.value = article.slug || '';
          articleForm.elements.category.value = article.category || '';
          articleForm.elements.status.value = article.status === 'published' ? 'pending_approval' : article.status || 'draft';
          articleForm.elements.excerpt.value = article.excerpt || '';
          articleForm.elements.body.value = article.body || '';
          openModal(articleModal);
        });
      });

      articleList.querySelectorAll('.article-del').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const confirmed = await askConfirm('Do you want to delete this article?');
          if (!confirmed) return;
          await fetch('/api/admin/articles', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: Number(btn.dataset.id) }),
          });
          showToast('Article deleted.', 'success');
          loadArticles();
          loadStats();
        });
      });
    }

    articleAddBtn?.addEventListener('click', () => {
      articleModalTitle.textContent = 'New Article';
      articleForm.reset();
      articleForm.elements.id.value = '';
      articleForm.elements.status.value = 'pending_approval';
      openModal(articleModal);
    });

    function closeArticleModal() {
      closeModal(articleModal);
    }

    articleModalClose?.addEventListener('click', closeArticleModal);
    articleModalCancel?.addEventListener('click', closeArticleModal);

    articleForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const payload = {
        id: articleForm.elements.id.value ? Number(articleForm.elements.id.value) : undefined,
        title: articleForm.elements.title.value,
        image_url: articleForm.elements.image_url.value,
        slug: articleForm.elements.slug.value,
        category: articleForm.elements.category.value,
        status: articleForm.elements.status.value,
        excerpt: articleForm.elements.excerpt.value,
        body: articleForm.elements.body.value,
        adminEmail: currentAdmin?.email,
      };

      const res = await fetch('/api/admin/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (!res.ok || !json.success) {
        showToast(json.error || 'Article could not be saved', 'error');
        return;
      }
      showToast('Article saved.', 'success');
      closeArticleModal();
      loadArticles();
      loadStats();
    });

    [articleModal].forEach((node) => {
      node?.addEventListener('click', (event) => {
        if (event.target === node) closeModal(node);
      });
    });

    bootAdminPanel();
    loadStats();
    loadArticles();
    loadNotifications();
  </script>
</MainLayout>

