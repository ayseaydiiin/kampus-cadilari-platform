---
import MainLayout from '../layouts/MainLayout.astro';
import { getPublishedArticles } from '../utils/db.js';
import { getCategoryDefinitions, getCategoryLabel, getCategorySlug } from '../utils/articleCategories';

export const prerender = false;

const allArticles = getPublishedArticles();
const baseCategories = getCategoryDefinitions().map((item) => ({
  name: item.tr,
  slug: item.slug,
  count: 0,
}));

const categoryMap = new Map(baseCategories.map((item) => [item.slug, item]));

for (const article of allArticles) {
  const categoryName = article.category || 'Gundem ve Politika';
  const key = getCategorySlug(categoryName);
  const current = categoryMap.get(key) || { name: getCategoryLabel(categoryName, 'tr'), slug: key, count: 0 };
  current.count += 1;
  categoryMap.set(key, current);
}

const categories = Array.from(categoryMap.values()).sort((a, b) => a.name.localeCompare(b.name, 'tr'));
---

<MainLayout title="Yazilar - Kampus Cadilari" description="Admin onayli yazilar ve kategori bazli filtreleme" currentLang="tr">
  <section class="mx-auto max-w-6xl">
    <header class="rounded-[2rem] bg-gradient-to-br from-purple-700 via-fuchsia-700 to-rose-600 p-8 text-white shadow-xl">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-purple-100">Yazilar</p>
      <h1 class="mt-3 text-4xl font-black leading-tight text-white md:text-5xl">Admin Onayli Icerik Arsivi</h1>
      <p class="mt-4 max-w-3xl text-white/90">
        Kategoriye gore filtrele ve slug bazli detay sayfaya git.
      </p>

      <form id="article-filter-form" class="mt-6 grid gap-3 md:grid-cols-[1fr_1fr_auto]">
        <input
          id="article-search-input"
          type="text"
          placeholder="Baslik veya metinde ara..."
          class="rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm text-white placeholder:text-white/70"
        />
        <select id="article-category-select" class="rounded-xl border border-white/30 bg-white/10 px-4 py-2.5 text-sm text-white">
          <option value="all" class="text-slate-900">Tum kategoriler</option>
          {categories.map((category) => (
            <option value={category.slug} class="text-slate-900">
              {category.name} ({category.count})
            </option>
          ))}
        </select>
        <button type="submit" class="rounded-xl bg-white px-4 py-2.5 text-sm font-bold text-purple-700 hover:bg-purple-100">
          Filtrele
        </button>
      </form>
    </header>

    <section class="mt-8">
      {allArticles.length === 0 ? (
        <div class="rounded-2xl border border-amber-200 bg-amber-50 p-8 text-center">
          <p class="text-lg font-bold text-amber-900">Henuz yayinlanmis yazi bulunmuyor.</p>
        </div>
      ) : (
        <>
          <div id="article-empty-warning" class="mb-4 hidden rounded-2xl border border-amber-200 bg-amber-50 p-6 text-center">
            <p id="article-empty-warning-text" class="text-lg font-bold text-amber-900">Bu kategoriye ait henuz bir yazi bulunmamaktadir.</p>
          </div>

          <div id="article-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
            {allArticles.map((article) => (
              <article
                class="article-card flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"
                data-category={getCategorySlug(article.category || 'Gundem ve Politika')}
                data-search={`${article.title || ''} ${(article.excerpt || '')} ${(article.body || '')}`.toLowerCase()}
              >
                {article.image_url ? (
                  <img src={article.image_url} alt={article.title || 'Yazi gorseli'} class="mb-4 h-44 w-full rounded-xl object-cover" loading="lazy" />
                ) : null}
                <p class="text-xs font-bold uppercase tracking-wide text-purple-700">{getCategoryLabel(article.category || 'Gundem ve Politika', 'tr')}</p>
                <h2 class="mt-2 line-clamp-2 text-xl font-black text-slate-900">{article.title}</h2>
                <p class="mt-2 text-xs text-slate-500">
                  {new Date(article.created_at || Date.now()).toLocaleDateString('tr-TR')}
                </p>
                <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">
                  {article.excerpt || String(article.body || '').slice(0, 180)}
                </p>
                <a
                  href={`/articles/${getCategorySlug(article.category || 'Gundem ve Politika')}/${article.slug}`}
                  class="mt-auto inline-flex pt-4 text-sm font-bold text-purple-700 hover:text-purple-900"
                >
                  Detay sayfaya git ->
                </a>
              </article>
            ))}
          </div>
          <div id="article-pagination" class="mt-6 flex flex-wrap items-center justify-center gap-2"></div>
        </>
      )}
    </section>
  </section>

  <script>
    const form = document.getElementById('article-filter-form');
    const searchInput = document.getElementById('article-search-input');
    const categorySelect = document.getElementById('article-category-select');
    const warning = document.getElementById('article-empty-warning');
    const warningText = document.getElementById('article-empty-warning-text');
    const cards = Array.from(document.querySelectorAll('.article-card'));
    const pagination = document.getElementById('article-pagination');
    const ITEMS_PER_PAGE = 6;
    let currentPage = 1;

    function applyFilters(updateUrl = true) {
      const selectedCategory = categorySelect?.value || 'all';
      const search = (searchInput?.value || '').trim().toLowerCase();
      const filteredCards = [];

      cards.forEach((card) => {
        const cardCategory = card.getAttribute('data-category') || '';
        const cardSearch = card.getAttribute('data-search') || '';
        const categoryMatch = selectedCategory === 'all' || cardCategory === selectedCategory;
        const searchMatch = !search || cardSearch.includes(search);
        if (categoryMatch && searchMatch) {
          filteredCards.push(card);
        }
      });

      const visibleCount = filteredCards.length;
      const totalPages = Math.max(1, Math.ceil(visibleCount / ITEMS_PER_PAGE));
      currentPage = Math.min(Math.max(currentPage, 1), totalPages);
      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const end = start + ITEMS_PER_PAGE;

      cards.forEach((card) => card.classList.add('hidden'));
      filteredCards.slice(start, end).forEach((card) => card.classList.remove('hidden'));

      if (warning) {
        warning.classList.toggle('hidden', visibleCount > 0);
      }

      if (warningText) {
        warningText.textContent = selectedCategory !== 'all'
          ? 'Bu kategoriye ait henuz bir yazi bulunmamaktadir.'
          : 'Filtreye uygun yazi bulunamadi.';
      }

      if (pagination) {
        if (visibleCount <= ITEMS_PER_PAGE) {
          pagination.innerHTML = '';
        } else {
          pagination.innerHTML = Array.from({ length: totalPages }, (_, idx) => {
            const page = idx + 1;
            const active = page === currentPage;
            return `<button type="button" class="article-page-btn rounded-lg border px-3 py-1 text-sm font-bold ${active ? 'border-purple-700 bg-purple-700 text-white' : 'border-slate-300 bg-white text-slate-700'}" data-page="${page}">${page}</button>`;
          }).join('');
          pagination.querySelectorAll('.article-page-btn').forEach((button) => {
            button.addEventListener('click', () => {
              currentPage = Number(button.dataset.page || '1');
              applyFilters(false);
            });
          });
        }
      }

      if (updateUrl) {
        const params = new URLSearchParams(window.location.search);
        if (selectedCategory !== 'all') params.set('category', selectedCategory);
        else params.delete('category');
        if (search) params.set('search', search);
        else params.delete('search');
        const next = `${window.location.pathname}${params.toString() ? `?${params.toString()}` : ''}`;
        window.history.replaceState({}, '', next);
      }
    }

    function initFromUrl() {
      const params = new URLSearchParams(window.location.search);
      const category = params.get('category');
      const search = params.get('search');
      if (category && categorySelect?.querySelector(`option[value=\"${category}\"]`)) {
        categorySelect.value = category;
      }
      if (search && searchInput) searchInput.value = search;
      applyFilters(false);
    }

    form?.addEventListener('submit', (event) => {
      event.preventDefault();
      currentPage = 1;
      applyFilters(true);
    });
    categorySelect?.addEventListener('change', () => {
      currentPage = 1;
      applyFilters(true);
    });
    searchInput?.addEventListener('input', () => {
      currentPage = 1;
      applyFilters(true);
    });

    initFromUrl();
  </script>
</MainLayout>
