---
import MainLayout from '../layouts/MainLayout.astro';
import { getCategoryLabel, getCategorySlug } from '../utils/articleCategories';
import { getApprovedArchiveEntries, getPublishedArticles } from '../utils/db.js';

const publishedArticles = getPublishedArticles();
const homeArticles = publishedArticles.map((article) => ({
  id: article.slug,
  slug: article.slug,
  title: article.title,
  category: article.category || 'Gundem ve Politika',
  excerpt: article.excerpt || String(article.body || '').slice(0, 180),
  date: article.created_at,
}));

const writingsFeed = [...homeArticles]
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map((article) => ({
    ...article,
    href: `/articles/${getCategorySlug(article.category || 'Gundem ve Politika')}/${article.slug}`,
    categoryLabel: getCategoryLabel(article.category || 'Gundem ve Politika', 'tr'),
    dateLabel: new Date(article.date).toLocaleDateString('tr-TR', { day: '2-digit', month: 'long', year: 'numeric' }),
  }));
const latestArticles = writingsFeed.slice(0, 3);

const featuredArchiveItems = getApprovedArchiveEntries({ limit: 3 });

const homeLinks = [
  { href: '/archive', eyebrow: 'Arşiv', title: 'İsyan Kayıtları', copy: 'Yayına alınmış arşiv kayıtlarını incele.' },
  { href: '#perspektif-section', eyebrow: 'Perspektif', title: 'Cadı Merceği', copy: 'Feminist perspektifi ve editoryal yönü oku.' },
  { href: '/articles', eyebrow: 'Yazılar', title: 'Kazandan Taşanlar', copy: 'Yayındaki yazılara hızlı geçiş yap.' },
  { href: '/map', eyebrow: 'Bize Katıl', title: 'Cadıol', copy: 'Topluluğa katılmak için başvuru akışını aç.' },
];
---

<MainLayout title="Kampüs Cadıları - Feminist Dayanışma Ağı" description="Feminist gündem, arşiv ve topluluk akışını bir araya getiren platform.">
  <section class="mx-auto max-w-6xl rounded-[2rem] border border-[rgba(123,55,148,0.14)] bg-[linear-gradient(135deg,rgba(123,55,148,0.96),rgba(92,36,114,0.94)_54%,rgba(237,28,36,0.9))] px-6 py-8 text-white shadow-[0_28px_70px_rgba(61,18,79,0.18)] md:px-10 md:py-10">
    <div class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr]">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.24em] text-white/75">Kampüs Cadıları</p>
        <h2 class="mt-3 text-4xl font-black leading-tight text-white md:text-5xl">Feminist içerik, arşiv ve topluluk akışı tek yerde.</h2>
        <p class="mt-5 max-w-2xl text-base leading-8 text-white/88 md:text-lg">
          İsyanın hafızasını, güncel yazıları ve topluluk bağlarını aynı ekranda buluşturan dijital karargah.
          Sağ taraftaki takvimden işaretli günleri seçerek etkinlik adı ve il bilgisini anında görebilirsin.
        </p>

        <div class="mt-8 grid gap-3 sm:grid-cols-2">
          {homeLinks.map((item) => (
            <a href={item.href} class="brand-chip rounded-[1.4rem] p-4 text-slate-900 transition hover:-translate-y-0.5 hover:shadow-xl">
              <p class="text-[11px] font-black uppercase tracking-[0.22em] text-[var(--color-red-accent)]">{item.eyebrow}</p>
              <h3 class="mt-2 text-2xl font-black text-[var(--color-purple-primary)]">{item.title}</h3>
              <p class="mt-2 text-sm leading-6 text-slate-600">{item.copy}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-[1.75rem] bg-[rgba(255,250,247,0.96)] p-5 text-slate-900 shadow-[0_18px_40px_rgba(35,12,45,0.12)] lg:sticky lg:top-28 lg:self-start">
        <div class="flex items-center justify-between gap-4">
          <div>
            <p class="text-xs font-black uppercase tracking-[0.22em] text-[var(--color-red-accent)]">Takvim</p>
            <h3 class="mt-2 text-2xl font-black text-[var(--color-purple-primary)]">Etkinlik Ajandası</h3>
          </div>
          <a href="/events" class="text-sm font-bold text-[var(--color-purple-primary)] hover:text-[var(--color-red-accent)]">Tüm takvim</a>
        </div>

        <div class="mt-5 rounded-[1.5rem] border border-[rgba(123,55,148,0.12)] bg-white p-4">
          <div class="mb-4 flex items-center justify-between">
            <button id="homePrevMonthBtn" class="rounded-full border border-slate-200 px-3 py-1.5 text-sm font-bold text-slate-600 hover:bg-slate-50">&larr;</button>
            <h4 id="homeCalendarMonthLabel" class="text-sm font-black uppercase tracking-[0.18em] text-[var(--color-purple-primary)]"></h4>
            <button id="homeNextMonthBtn" class="rounded-full border border-slate-200 px-3 py-1.5 text-sm font-bold text-slate-600 hover:bg-slate-50">&rarr;</button>
          </div>

          <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-black uppercase tracking-wide text-slate-400">
            <span>Pzt</span>
            <span>Sal</span>
            <span>Çar</span>
            <span>Per</span>
            <span>Cum</span>
            <span>Cmt</span>
            <span>Paz</span>
          </div>

          <div id="homeCalendarGrid" class="mt-2 grid grid-cols-7 gap-1"></div>
        </div>

        <div class="mt-4 rounded-[1.5rem] border border-[rgba(237,28,36,0.12)] bg-[var(--color-cream-soft)] p-4">
          <p class="text-xs font-black uppercase tracking-[0.2em] text-[var(--color-red-accent)]">Seçili Gün</p>
          <h4 id="homeSelectedDateTitle" class="mt-2 text-lg font-black text-slate-900">Bir gün seç</h4>
          <div id="homeSelectedDateEvents" class="mt-3 space-y-3 text-sm text-slate-700">
            <p class="rounded-xl bg-white px-4 py-3 text-slate-500">İşaretli bir tarih seçildiğinde burada sadece etkinlik adı ve il bilgisi listelenir.</p>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section id="archive-section" class="mx-auto mt-14 max-w-5xl">
    <div class="mb-5 flex items-center justify-between gap-3">
      <h3 class="text-3xl font-black text-slate-900">İsyan Kayıtları</h3>
      <a href="/archive" class="text-sm font-bold text-[var(--color-purple-primary)] hover:text-[var(--color-red-accent)]">Tüm arşivi gör</a>
    </div>

    <div class="grid items-stretch gap-4 md:grid-cols-3">
      {featuredArchiveItems.map((item) => (
        <article class="group flex h-full flex-col overflow-hidden rounded-2xl border border-[#e6d8c3] bg-[#fff9f1] shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
          <div class="relative">
            <img src={item.cover_image_url || '/archive/placeholder-cover.svg'} alt={`${item.publication_name} kapak`} class="h-44 w-full object-cover" loading="lazy" />
            <span class="absolute left-3 top-3 rounded-full border border-[rgba(237,28,36,0.18)] bg-white/95 px-2.5 py-1 text-[11px] font-bold text-[var(--color-red-accent)]">Yayında</span>
          </div>
          <div class="flex flex-1 flex-col p-4">
            <p class="text-xs font-bold uppercase tracking-wide text-[var(--color-purple-primary)]">{item.decade} - {item.publication_year}</p>
            <h4 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">{item.title}</h4>
            <p class="mt-2 text-sm font-semibold text-slate-700">{item.publication_name}</p>
            <a href={`/archive/${item.id}`} class="mt-auto inline-flex pt-4 text-sm font-bold text-[var(--color-purple-primary)] transition group-hover:text-[var(--color-red-accent)]">
              Arşiv kaydını incele ->
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="perspektif-section" class="mx-auto mt-14 max-w-5xl">
    <h3 class="text-3xl font-black text-slate-900">Cadı Merceği</h3>
    <p class="mt-4 max-w-4xl text-base leading-8 text-slate-600">
      Kampüs Cadıları, feminist perspektiften güncel sosyal konuları ele alan, topluluk tarafından üretilen bir içerik ve dayanışma alanı kuruyor.
      Arşivden güncel yazılara, katılım kanallarından etkinlik akışına kadar her bölüm ortak bir editoryal bakışın parçası olarak kurgulanıyor.
    </p>
    <a href="https://docs.google.com/forms/d/e/1FAIpQLSc4YtEELBG3XF3VuH0t37alzBNFGwteBTS1Fn6IbBqghFtYeA/viewform" target="_blank" rel="noreferrer" class="mt-5 inline-flex rounded-xl bg-[#5b2c84] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#4a236c]">
      Cadı formunu doldur
    </a>
  </section>

  <section id="writings-section" class="mx-auto mt-14 max-w-5xl">
    <div class="mb-5 flex items-center justify-between gap-3">
      <h3 class="text-3xl font-black text-slate-900">Kazandan Taşanlar</h3>
      <a href="/articles" class="text-sm font-bold text-[var(--color-purple-primary)] hover:text-[var(--color-red-accent)]">Tümünü gör</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {latestArticles.map((article) => (
        <article class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">{article.dateLabel}</p>
          <h4 class="mt-2 text-xl font-bold leading-tight text-slate-900">{article.title}</h4>
          <p class="mt-2 text-xs font-bold uppercase tracking-wide text-[var(--color-purple-primary)]">{article.categoryLabel}</p>
          <p class="mt-3 line-clamp-3 text-sm leading-6 text-slate-600">{article.excerpt}</p>
          <a href={article.href} class="mt-auto inline-flex pt-4 text-sm font-bold text-[var(--color-purple-primary)] hover:text-[var(--color-red-accent)]">
            Yazıyı oku ->
          </a>
        </article>
      ))}
    </div>
  </section>

  <script>
    const monthLabelNode = document.getElementById('homeCalendarMonthLabel');
    const calendarGridNode = document.getElementById('homeCalendarGrid');
    const selectedDateTitleNode = document.getElementById('homeSelectedDateTitle');
    const selectedDateEventsNode = document.getElementById('homeSelectedDateEvents');
    const prevMonthBtn = document.getElementById('homePrevMonthBtn');
    const nextMonthBtn = document.getElementById('homeNextMonthBtn');

    let activeMonth = new Date();
    activeMonth.setDate(1);
    let eventsByDate = new Map();
    let selectedDateKey = null;

    function pad(value) {
      return String(value).padStart(2, '0');
    }

    function formatDateKey(date) {
      return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
    }

    function parseEventDateKey(event) {
      const candidate = String(event?.date_suggested || event?.created_at || '').trim();
      if (!candidate) return null;
      if (/^\d{4}-\d{2}-\d{2}$/.test(candidate)) return candidate;
      const parsed = new Date(candidate);
      if (Number.isNaN(parsed.getTime())) return null;
      return formatDateKey(parsed);
    }

    function formatMonthLabel(date) {
      return new Intl.DateTimeFormat('tr-TR', { month: 'long', year: 'numeric' }).format(date);
    }

    function formatReadableDate(dateKey) {
      const [year, month, day] = String(dateKey).split('-').map(Number);
      if (!year || !month || !day) return 'Bir gün seç';
      return new Intl.DateTimeFormat('tr-TR', { day: 'numeric', month: 'long', weekday: 'long' }).format(new Date(year, month - 1, day));
    }

    function renderSelectedDay() {
      if (!selectedDateKey) {
        selectedDateTitleNode.textContent = 'Bir gün seç';
        selectedDateEventsNode.innerHTML = '<p class="rounded-xl bg-white px-4 py-3 text-slate-500">İşaretli bir tarih seçildiğinde burada sadece etkinlik adı ve il bilgisi listelenir.</p>';
        return;
      }

      const events = eventsByDate.get(selectedDateKey) || [];
      selectedDateTitleNode.textContent = formatReadableDate(selectedDateKey);

      if (!events.length) {
        selectedDateEventsNode.innerHTML = '<p class="rounded-xl bg-white px-4 py-3 text-slate-500">Bu gün için etkinlik yok.</p>';
        return;
      }

      selectedDateEventsNode.innerHTML = events.map((event) => `
        <article class="rounded-xl border border-[rgba(123,55,148,0.14)] bg-white px-4 py-3">
          <p class="font-bold text-slate-900">${event.title || 'Etkinlik'}</p>
          <p class="mt-1 text-xs font-bold uppercase tracking-wide text-[var(--color-purple-primary)]">${event.province || '-'}</p>
        </article>
      `).join('');
    }

    function renderCalendar() {
      monthLabelNode.textContent = formatMonthLabel(activeMonth);
      const year = activeMonth.getFullYear();
      const month = activeMonth.getMonth();
      const firstDay = new Date(year, month, 1);
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const mondayOffset = (firstDay.getDay() + 6) % 7;
      const cells = [];

      for (let i = 0; i < mondayOffset; i += 1) {
        cells.push('<div class="h-12 rounded-lg bg-slate-50"></div>');
      }

      for (let day = 1; day <= daysInMonth; day += 1) {
        const key = `${year}-${pad(month + 1)}-${pad(day)}`;
        const dayEvents = eventsByDate.get(key) || [];
        const hasEvents = dayEvents.length > 0;
        const isSelected = key === selectedDateKey;
        const className = isSelected
          ? 'border-[var(--color-red-accent)] bg-[rgba(237,28,36,0.08)] text-[var(--color-red-accent)]'
          : hasEvents
            ? 'border-[rgba(123,55,148,0.18)] bg-[rgba(123,55,148,0.06)] text-slate-900'
            : 'border-slate-200 bg-white text-slate-500';

        cells.push(`
          <button data-date-key="${key}" class="home-calendar-day flex h-12 flex-col items-start justify-between rounded-lg border px-2 py-2 text-left transition hover:-translate-y-0.5 ${className}">
            <span class="text-xs font-black">${day}</span>
            ${hasEvents ? '<span class="h-2.5 w-2.5 rounded-full bg-[var(--color-purple-primary)]"></span>' : ''}
          </button>
        `);
      }

      while (cells.length % 7 !== 0) {
        cells.push('<div class="h-12 rounded-lg bg-slate-50"></div>');
      }

      calendarGridNode.innerHTML = cells.join('');
      calendarGridNode.querySelectorAll('.home-calendar-day').forEach((btn) => {
        btn.addEventListener('click', () => {
          selectedDateKey = btn.dataset.dateKey;
          renderCalendar();
          renderSelectedDay();
        });
      });
    }

    async function loadEventsCalendar() {
      try {
        const response = await fetch('/api/events/list');
        const data = await response.json();
        const events = Array.isArray(data?.events) ? data.events : [];

        eventsByDate = new Map();
        events.forEach((event) => {
          const key = parseEventDateKey(event);
          if (!key) return;
          if (!eventsByDate.has(key)) eventsByDate.set(key, []);
          eventsByDate.get(key).push(event);
        });

        const today = new Date();
        selectedDateKey = formatDateKey(today);
        activeMonth = new Date(today.getFullYear(), today.getMonth(), 1);

        renderCalendar();
        renderSelectedDay();
      } catch (error) {
        monthLabelNode.textContent = 'Takvim yüklenemedi';
        calendarGridNode.innerHTML = '<p class="col-span-7 rounded-lg bg-red-50 p-3 text-center text-xs text-red-700">Takvim verisi alınamadı.</p>';
        selectedDateEventsNode.innerHTML = '<p class="rounded-xl bg-white px-4 py-3 text-red-700">Etkinlik listesi yüklenemedi.</p>';
        console.error(error);
      }
    }


    prevMonthBtn?.addEventListener('click', () => {
      activeMonth = new Date(activeMonth.getFullYear(), activeMonth.getMonth() - 1, 1);
      renderCalendar();
    });

    nextMonthBtn?.addEventListener('click', () => {
      activeMonth = new Date(activeMonth.getFullYear(), activeMonth.getMonth() + 1, 1);
      renderCalendar();
    });

    document.addEventListener('DOMContentLoaded', () => {
      loadEventsCalendar();
    });
  </script>
</MainLayout>

