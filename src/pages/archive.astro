---
import MainLayout from '../layouts/MainLayout.astro';
import { getApprovedArchiveEntries } from '../utils/db.js';

const allApproved = getApprovedArchiveEntries();
const initialItems = allApproved.slice(0, 6);
const decades = [...new Set(allApproved.map((item) => item.decade).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'tr'));
const focusTopics = [...new Set(allApproved.map((item) => item.focus_topic).filter(Boolean))].sort((a, b) => a.localeCompare(b, 'tr'));
---

<MainLayout title="Gazete Arşivi - Kampüs Cadıları" description="Admin onayından geçmiş feminist gazete arşivi">
  <section class="relative overflow-hidden rounded-[2rem] border border-[#5b2c84]/20 bg-gradient-to-br from-[#4b1f6f] via-[#5b2c84] to-[#2f264d] px-6 py-12 text-white shadow-2xl md:px-10 md:py-14">
    <div class="absolute -left-16 top-0 h-44 w-44 rounded-full bg-amber-200/15 blur-3xl"></div>
    <div class="absolute -bottom-10 right-0 h-56 w-56 rounded-full bg-fuchsia-100/10 blur-3xl"></div>
    <div class="relative max-w-4xl">
      <p class="inline-flex rounded-full border border-white/20 bg-white/10 px-4 py-1 text-xs font-bold uppercase tracking-[0.18em]">Arşiv bölümü</p>
      <h1 class="mt-3 text-4xl font-black leading-tight text-white md:text-5xl">Gazete Arşiv Bölümü</h1>
      <p class="mt-4 max-w-3xl text-base leading-8 text-white/95 md:text-lg">
        Feminist gazetelerin admin onayindan gecmis surumlerini kurumsal bir akisla listeliyoruz.
      </p>
    </div>
  </section>

  <section class="mt-8 rounded-[1.5rem] border border-[#d7c8b2] bg-[#f6f0e4] p-5 shadow-sm">
    <div class="grid gap-4 md:grid-cols-3">
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Donem filtrele
        <select id="archive-decade" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none">
          <option value="all">Tum donemler</option>
          {decades.map((decade) => <option value={decade}>{decade}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Odak noktasi
        <select id="archive-focus" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none">
          <option value="all">Tum basliklar</option>
          {focusTopics.map((topic) => <option value={topic}>{topic}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Arsivde ara
        <input id="archive-search" type="search" placeholder="Gazete adi, tema, yil..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
    </div>
  </section>

  <section class="mt-8">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-2xl font-black text-slate-900">Admin Onayli Gazeteler</h2>
      <p id="archive-count" class="text-sm font-semibold text-slate-600">{initialItems.length} kayit gosteriliyor</p>
    </div>

    <div id="archive-list" class="grid items-stretch gap-6 md:grid-cols-2 xl:grid-cols-3">
      {initialItems.map((item) => (
        <article class="group relative flex h-full flex-col overflow-hidden rounded-[1.4rem] border border-[#d5c6ac] bg-[#fdf8ef] shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl">
          <div class="relative">
            <img src={item.cover_image_url || '/archive/placeholder-cover.svg'} alt={`${item.publication_name} kapak`} class="h-56 w-full object-cover" loading="lazy" />
            <div class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full border border-amber-300/70 bg-amber-100/95 px-3 py-1 text-xs font-bold text-amber-900">
              <span>OK</span>
              <span>Admin Onayli</span>
            </div>
          </div>

          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs font-bold uppercase tracking-wide text-[#5b2c84]">{item.decade} - {item.publication_year}</p>
            <h3 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">{item.title}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-700">{item.publication_name}</p>
            <p class="mt-2 line-clamp-2 text-sm text-slate-600">Odak: {item.focus_topic || 'Genel feminist gundem'}</p>

            <div class="mt-auto grid grid-cols-3 gap-2 pt-4 text-xs font-bold">
              <a href={`/archive/${item.id}`} class="rounded-lg bg-[#5b2c84] px-2 py-2 text-center text-white transition hover:bg-[#4a236c]">Detay</a>
              <a href={`/api/archive/${item.id}/export-pdf?lang=tr`} download class="rounded-lg border border-[#5b2c84] px-2 py-2 text-center text-[#5b2c84] transition hover:bg-[#efe5f7]">PDF İndir</a>
              <button data-link={`/archive/${item.id}`} class="archive-copy-btn rounded-lg border border-amber-400 bg-amber-50 px-2 py-2 text-amber-900 transition hover:bg-amber-100">Bağlantıyı Kopyala</button>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div id="archive-pagination" class="mt-6 flex flex-wrap items-center justify-center gap-2"></div>
  </section>

  <section class="mt-10 rounded-[1.6rem] border border-[#d5c6ac] bg-[#fdf8ef] p-6 shadow-sm md:p-8">
    <div class="mb-5">
      <h2 class="text-2xl font-black text-slate-900">Arsive Gazete Oner</h2>
      <p class="mt-2 text-sm leading-6 text-slate-600">
        Gonderilen kayitlar once admin panelinde inceleme bekliyor durumuna duser. Tek bir admin onayi ile arsivde yayina alinir.
      </p>
    </div>

    <form id="archive-submit-form" class="grid gap-4 md:grid-cols-2">
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Gazete adi
        <input name="publication_name" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Yayin basligi
        <input name="title" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Basim yili
        <input name="publication_year" type="number" min="1800" max="2100" required class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Odak noktasi
        <input name="focus_topic" list="archive-focus-suggestions" placeholder="Secme hakki, isci haklari..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 md:col-span-2">
        Kisa ozet
        <textarea name="summary" rows="3" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none"></textarea>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700 md:col-span-2">
        Detayli metin
        <textarea name="quote_text" rows="6" placeholder="Sayinin onemi, uzun aciklama veya dikkat ceken bolum..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none"></textarea>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Kapak gorseli URL
        <input name="cover_image_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
        <span class="text-xs font-normal text-slate-500">Kartta ve detay sayfasinda gosterilecek kapak gorseli baglantisi.</span>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        PDF URL
        <input name="pdf_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
        <span class="text-xs font-normal text-slate-500">Orijinal PDF kaynagi; sistem PDF ciktisi bundan bagimsiz olarak olusturulur.</span>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Kaynak URL
        <input name="source_url" type="url" placeholder="https://..." class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
        <span class="text-xs font-normal text-slate-500">Icerigin alindigi referans sayfa veya arsiv kaynagi baglantisi.</span>
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        Gonderen ad
        <input name="submitted_by" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <label class="flex flex-col gap-2 text-sm font-semibold text-slate-700">
        E-posta
        <input name="submitted_email" type="email" class="rounded-xl border border-[#cdbba0] bg-white px-3 py-2 text-sm text-slate-800 focus:border-[#5b2c84] focus:outline-none" />
      </label>
      <div class="md:col-span-2">
        <button id="archive-submit-btn" type="submit" class="rounded-xl bg-[#5b2c84] px-5 py-2.5 text-sm font-bold text-white transition hover:bg-[#4a236c]">Incelemeye Gonder</button>
        <p id="archive-submit-feedback" class="mt-2 text-sm font-semibold text-slate-600"></p>
      </div>
    </form>
    <datalist id="archive-focus-suggestions">
      {focusTopics.map((topic) => <option value={topic}></option>)}
    </datalist>
  </section>

  <script define:vars={{ initialItems }}>
    const decadeSelect = document.getElementById('archive-decade');
    const focusSelect = document.getElementById('archive-focus');
    const searchInput = document.getElementById('archive-search');
    const listEl = document.getElementById('archive-list');
    const countEl = document.getElementById('archive-count');
    const paginationEl = document.getElementById('archive-pagination');
    const submitForm = document.getElementById('archive-submit-form');
    const submitButton = document.getElementById('archive-submit-btn');
    const submitFeedback = document.getElementById('archive-submit-feedback');
    const ITEMS_PER_PAGE = 6;
    let filteredItems = [];
    let currentPage = 1;

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function cardTemplate(item) {
      const cover = item.cover_image_url || '/archive/placeholder-cover.svg';
      const pdfUrl = `/api/archive/${item.id}/export-pdf?lang=tr`;

      return `
        <article class="group relative flex h-full flex-col overflow-hidden rounded-[1.4rem] border border-[#d5c6ac] bg-[#fdf8ef] shadow-sm transition hover:-translate-y-0.5 hover:shadow-xl">
          <div class="relative">
            <img src="${escapeHtml(cover)}" alt="${escapeHtml(item.publication_name)} kapak" class="h-56 w-full object-cover" loading="lazy" />
            <div class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full border border-amber-300/70 bg-amber-100/95 px-3 py-1 text-xs font-bold text-amber-900">
              <span>OK</span>
              <span>Admin Onayli</span>
            </div>
          </div>

          <div class="flex flex-1 flex-col p-5">
            <p class="text-xs font-bold uppercase tracking-wide text-[#5b2c84]">${escapeHtml(item.decade || '')} - ${escapeHtml(item.publication_year || '')}</p>
            <h3 class="mt-2 line-clamp-2 text-lg font-black leading-snug text-slate-900">${escapeHtml(item.title)}</h3>
            <p class="mt-2 text-sm font-semibold text-slate-700">${escapeHtml(item.publication_name)}</p>
            <p class="mt-2 line-clamp-2 text-sm text-slate-600">Odak: ${escapeHtml(item.focus_topic || 'Genel feminist gundem')}</p>

            <div class="mt-auto grid grid-cols-3 gap-2 pt-4 text-xs font-bold">
              <a href="/archive/${item.id}" class="rounded-lg bg-[#5b2c84] px-2 py-2 text-center text-white transition hover:bg-[#4a236c]">Detay</a>
              <a href="${escapeHtml(pdfUrl)}" download class="rounded-lg border border-[#5b2c84] px-2 py-2 text-center text-[#5b2c84] transition hover:bg-[#efe5f7]">PDF İndir</a>
              <button data-link="/archive/${item.id}" class="archive-copy-btn rounded-lg border border-amber-400 bg-amber-50 px-2 py-2 text-amber-900 transition hover:bg-amber-100">Bağlantıyı Kopyala</button>
            </div>
          </div>
        </article>
      `;
    }

    function renderPagination(totalPages) {
      if (!paginationEl) return;
      if (totalPages <= 1) {
        paginationEl.innerHTML = '';
        return;
      }

      const buttons = [];
      for (let page = 1; page <= totalPages; page += 1) {
        const activeClass = page === currentPage
          ? 'bg-[#5b2c84] text-white border-[#5b2c84]'
          : 'bg-white text-[#5b2c84] border-[#d5c6ac] hover:bg-[#efe5f7]';
        buttons.push(`<button type="button" data-page="${page}" class="archive-page-btn rounded-lg border px-3 py-1.5 text-sm font-bold transition ${activeClass}">${page}</button>`);
      }
      paginationEl.innerHTML = buttons.join('');

      paginationEl.querySelectorAll('.archive-page-btn').forEach((button) => {
        button.addEventListener('click', () => {
          const nextPage = Number(button.dataset.page || '1');
          if (!Number.isFinite(nextPage)) return;
          currentPage = nextPage;
          renderCurrentPage();
        });
      });
    }

    function renderCurrentPage() {
      const totalItems = filteredItems.length;
      if (!totalItems) {
        listEl.innerHTML = '<div class="col-span-full rounded-2xl border border-slate-200 bg-white p-8 text-center text-sm text-slate-500">Filtreye uygun kayit bulunamadi.</div>';
        if (countEl) countEl.textContent = '0 kayit gosteriliyor';
        renderPagination(0);
        return;
      }

      const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE);
      if (currentPage > totalPages) currentPage = totalPages;
      if (currentPage < 1) currentPage = 1;

      const start = (currentPage - 1) * ITEMS_PER_PAGE;
      const pageItems = filteredItems.slice(start, start + ITEMS_PER_PAGE);
      listEl.innerHTML = pageItems.map(cardTemplate).join('');
      if (countEl) {
        const end = Math.min(start + ITEMS_PER_PAGE, totalItems);
        countEl.textContent = `${start + 1}-${end} / ${totalItems} kayit`;
      }
      bindCopyButtons();
      renderPagination(totalPages);
    }

    async function copyToClipboard(text) {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const helper = document.createElement('textarea');
      helper.value = text;
      helper.setAttribute('readonly', '');
      helper.style.position = 'fixed';
      helper.style.left = '-9999px';
      document.body.appendChild(helper);
      helper.focus();
      helper.select();
      helper.setSelectionRange(0, text.length);
      const copied = document.execCommand('copy');
      document.body.removeChild(helper);
      if (copied) return true;

      window.prompt('Bağlantıyı manuel kopyalayın:', text);
      return false;
    }

    function bindCopyButtons() {
      document.querySelectorAll('.archive-copy-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const pageLink = `${window.location.origin}${button.dataset.link || '/archive'}`;
          try {
            const copied = await copyToClipboard(pageLink);
            const oldText = button.textContent;
            button.textContent = copied ? 'Kopyalandı' : 'Elle Kopyala';
            setTimeout(() => {
              button.textContent = oldText;
            }, 1200);
          } catch {
            button.textContent = 'Başarısız';
            setTimeout(() => {
              button.textContent = 'Bağlantıyı Kopyala';
            }, 1200);
          }
        });
      });
    }

    async function loadArchive() {
      const params = new URLSearchParams();
      const decade = decadeSelect?.value || 'all';
      const focus = focusSelect?.value || 'all';
      const search = searchInput?.value?.trim() || '';

      if (decade !== 'all') params.set('decade', decade);
      if (focus !== 'all') params.set('focus', focus);
      if (search) params.set('search', search);

      try {
        const response = await fetch(`/api/archive/list?${params.toString()}`);
        const data = await response.json();
        if (!response.ok || !data.success) throw new Error(data.error || 'Arsiv yuklenemedi');

        filteredItems = Array.isArray(data.items) ? data.items : [];
        currentPage = 1;
        renderCurrentPage();
      } catch (error) {
        listEl.innerHTML = `<div class="col-span-full rounded-2xl border border-red-200 bg-red-50 p-8 text-center text-sm text-red-700">${escapeHtml(error.message)}</div>`;
        if (paginationEl) paginationEl.innerHTML = '';
      }
    }

    let searchTimer;
    searchInput?.addEventListener('input', () => {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(loadArchive, 280);
    });

    decadeSelect?.addEventListener('change', loadArchive);
    focusSelect?.addEventListener('change', loadArchive);

    submitForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(submitForm);
      const payload = Object.fromEntries(formData.entries());

      submitButton.disabled = true;
      submitFeedback.textContent = 'Gonderiliyor...';

      try {
        const response = await fetch('/api/archive/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json();
        if (!response.ok || !result.success) throw new Error(result.error || 'Gonderim basarisiz');
        submitForm.reset();
        submitFeedback.textContent = 'Kayit incelemeye alindi. Tek bir admin onayi sonrasi arsive eklenecek.';
      } catch (error) {
        submitFeedback.textContent = error.message || 'Gonderim basarisiz';
      } finally {
        submitButton.disabled = false;
      }
    });

    filteredItems = Array.isArray(initialItems) ? initialItems : [];
    renderCurrentPage();
    loadArchive();
  </script>
</MainLayout>
