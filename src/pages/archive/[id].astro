---
import MainLayout from '../../layouts/MainLayout.astro';
import { getArchiveById } from '../../utils/db.js';

export const prerender = false;

const archiveId = Number(Astro.params.id);
const item = Number.isFinite(archiveId) ? getArchiveById(archiveId) : null;

if (!item || item.status !== 'approved') {
  Astro.response.status = 404;
  Astro.response.statusText = 'Not Found';
}

const exportFileName = `${String(item?.publication_name || 'arsiv').replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}-${String(item?.title || archiveId).replace(/[^a-zA-Z0-9]+/g, '-').toLowerCase()}.pdf`;
const exportFallbackUrl = `/api/archive/${archiveId}/export-pdf?lang=tr`;
---

<MainLayout title={item?.title ? `${item.title} - Gazete Arsivi` : 'Gazete Arsivi'} description="Admin onayli gazete arsiv detayi" currentLang="tr">
  {(!item || item.status !== 'approved') ? (
    <section class="mx-auto max-w-3xl rounded-2xl border border-red-200 bg-red-50 p-8 text-center">
      <h1 class="app-h1 text-3xl font-black text-red-800">Kayit bulunamadi</h1>
      <p class="mt-3 text-sm text-red-700">Talep ettiginiz arsiv girdisi yayinda degil.</p>
      <a href="/archive" class="mt-6 inline-flex rounded-lg bg-red-700 px-4 py-2 text-sm font-bold text-white hover:bg-red-800">Arsive don</a>
    </section>
  ) : (
    <section class="mx-auto max-w-6xl">
      <a href="/archive" class="inline-flex items-center gap-2 text-sm font-bold text-purple-700 hover:text-purple-900">Arsive geri don</a>

      <article id="archive-export-content" class="mt-4 rounded-[1.75rem] border border-[#d5c6ac] bg-[#fdf8ef] p-5 shadow-lg md:p-8">
        <div>
          <figure class="mb-5 w-full overflow-hidden rounded-[1.25rem] border border-[#e0d3bd] bg-white shadow-sm md:float-left md:mb-4 md:mr-6 md:w-[19rem]">
            <img src={item.cover_image_url || '/archive/placeholder-cover.svg'} alt={`${item.publication_name} kapak`} class="h-full w-full object-cover" />
          </figure>

          <div class="md:overflow-hidden">
            <div class="inline-flex items-center gap-2 rounded-full border border-amber-300 bg-amber-100 px-3 py-1 text-xs font-bold text-amber-900">
              <span>Onayli</span>
              <span>Arsiv Kaydi</span>
            </div>

            <h1 class="app-h1 mt-4 text-3xl font-black leading-tight text-slate-900 md:text-4xl">{item.title}</h1>
            <p class="mt-2 text-base font-semibold text-slate-700">{item.publication_name}</p>

            <div class="mt-6 grid gap-3 text-sm md:grid-cols-2">
              <div class="rounded-xl bg-white/80 p-3">
                <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Yayin yili</p>
                <p class="mt-1 font-semibold text-slate-900">{item.publication_year}</p>
              </div>
              <div class="rounded-xl bg-white/80 p-3">
                <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Donem</p>
                <p class="mt-1 font-semibold text-slate-900">{item.decade}</p>
              </div>
              <div class="rounded-xl bg-white/80 p-3 md:col-span-2">
                <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Odak noktasi</p>
                <p class="mt-1 font-semibold text-slate-900">{item.focus_topic || 'Genel feminist gundem'}</p>
              </div>
            </div>

            <section class="mt-6 max-w-[900px]">
              <h2 class="text-lg font-black text-slate-900">Kisa Ozet</h2>
              <p class="mt-3 text-sm leading-7 text-slate-700">{item.summary || 'Bu arsiv kaydi icin ozet metin henuz eklenmemis.'}</p>
            </section>

            <section class="mt-6 max-w-[900px]">
              <h2 class="text-lg font-black text-slate-900">Haber İçeriği</h2>
              <p class="mt-3 whitespace-pre-wrap text-sm leading-7 text-slate-700">{item.quote_text || item.summary || 'Bu arsiv kaydi icin detayli haber icerigi henuz eklenmemis.'}</p>
            </section>

            <section class="mt-6 max-w-[900px]">
              <h3 class="text-sm font-black uppercase tracking-wide text-slate-700">Hizli Bilgiler</h3>
              <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-7 text-slate-700">
                {item.source_url ? <li>Kaynak: <a href={item.source_url} target="_blank" rel="noreferrer" class="font-semibold text-purple-700 underline">Baglantiyi ac</a></li> : null}
                <li>Giris durumu: Admin onayi ile arsivde yayinlandi.</li>
                <li>Paylaşım: Link kopyala veya PDF olarak kaydet aksiyonları ile paylaşabilirsiniz.</li>
              </ul>
            </section>
          </div>
        </div>
      </article>

      <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <h2 class="text-base font-black text-slate-900">Paylasim ve Cikti</h2>
        <div class="mt-3 flex flex-wrap gap-3 text-sm font-bold">
          <a id="export-pdf-btn" href={exportFallbackUrl} data-file-name={exportFileName} class="rounded-lg border border-slate-700 px-4 py-2 text-slate-800 transition hover:bg-slate-100">
            Arşiv Kaydını PDF Olarak İndir
          </a>
          <button id="copy-link-btn" class="rounded-lg border border-[#5b2c84] px-4 py-2 text-[#5b2c84] transition hover:bg-[#efe5f7]">
            Bağlantıyı Kopyala
          </button>
        </div>
        <p id="copy-link-state" class="mt-2 text-xs font-semibold text-emerald-700"></p>
      </section>
    </section>
  )}

  <script type="module">
    const copyButton = document.getElementById('copy-link-btn');
    const copyState = document.getElementById('copy-link-state');
    const exportPdfButton = document.getElementById('export-pdf-btn');

    function updateButtonText(button, text, fallback) {
      if (!button) return;
      const previous = button.textContent;
      button.textContent = text;
      setTimeout(() => {
        button.textContent = fallback || previous;
      }, 1400);
    }

    copyButton?.addEventListener('click', async () => {
      const currentUrl = window.location.href;
      try {
        if (navigator.clipboard?.writeText) {
          await navigator.clipboard.writeText(currentUrl);
        } else {
          const helper = document.createElement('textarea');
          helper.value = currentUrl;
          helper.setAttribute('readonly', '');
          helper.style.position = 'absolute';
          helper.style.left = '-9999px';
          document.body.appendChild(helper);
          helper.focus();
          helper.select();
          helper.setSelectionRange(0, currentUrl.length);
          const copied = document.execCommand('copy');
          document.body.removeChild(helper);
          if (!copied) {
            window.prompt('Baglantiyi manuel kopyalayin:', currentUrl);
          }
        }
        updateButtonText(copyButton, 'Kopyalandı', 'Bağlantıyı Kopyala');
        if (copyState) {
          copyState.textContent = 'Bağlantı panoya kopyalandı.';
        }
      } catch {
        window.prompt('Bağlantıyı manuel kopyalayın:', currentUrl);
        updateButtonText(copyButton, 'Başarısız', 'Bağlantıyı Kopyala');
        if (copyState) {
          copyState.textContent = 'Kopyalama başarısız. Bağlantıyı manuel kopyalayın.';
        }
      }
      setTimeout(() => {
        if (copyState) copyState.textContent = '';
      }, 1800);
    });

    exportPdfButton?.addEventListener('click', () => {
      updateButtonText(exportPdfButton, 'PDF İndiriliyor...', 'Arşiv Kaydını PDF Olarak İndir');
    });

    document.addEventListener('DOMContentLoaded', () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get('export') === '1') {
        if (exportPdfButton?.href) {
          window.location.href = exportPdfButton.href;
        }
      }
    });
  </script>
</MainLayout>
