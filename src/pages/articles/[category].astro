---
import MainLayout from '../../layouts/MainLayout.astro';
import { getPublishedArticles } from '../../utils/db.js';
import { getCategoryLabel, getCategoryLabelBySlug, getCategorySlug } from '../../utils/articleCategories';

export const prerender = false;

const categorySlug = String(Astro.params.category || '').trim();
if (!categorySlug) {
  return Astro.redirect('/articles');
}

const allArticles = getPublishedArticles();
const categoryArticles = allArticles.filter((article) => getCategorySlug(article.category || 'Gundem ve Politika') === categorySlug);
const categoryName = categoryArticles.length
  ? getCategoryLabel(categoryArticles[0]?.category || 'Gundem ve Politika', 'tr')
  : getCategoryLabelBySlug(categorySlug, 'tr');
---

<MainLayout
  title={`${categoryName} - Kampus Cadilari`}
  description={`${categoryName} kategorisindeki admin onayli yazilar`}
  currentLang="tr"
>
  <section class="mx-auto max-w-5xl">
    <nav class="mb-6 text-sm text-slate-600">
      <a href="/articles" class="font-semibold text-purple-700 hover:text-purple-900">Yazilar</a>
      <span class="mx-2">/</span>
      <span>{categoryName}</span>
    </nav>

    <header class="rounded-2xl bg-white p-6 shadow ring-1 ring-slate-200">
      <p class="text-xs font-bold uppercase tracking-[0.16em] text-purple-700">Kategori yazilari</p>
      <h1 class="app-h1 mt-2 text-3xl font-black text-slate-900">{categoryName}</h1>
      <p class="mt-2 text-sm text-slate-600">{categoryArticles.length} yazi bulundu</p>
    </header>

    <section class="mt-6">
      {categoryArticles.length === 0 ? (
        <div class="rounded-2xl border border-amber-200 bg-amber-50 p-8 text-center">
          <p class="text-lg font-bold text-amber-900">Bu bolume henuz yazi eklenmemistir.</p>
          <a href="/articles" class="mt-4 inline-flex rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white hover:bg-purple-700">
            Tum yazilara don
          </a>
        </div>
      ) : (
        <div class="space-y-4">
          {categoryArticles.map((article) => (
            <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
              {article.image_url ? (
                <img src={article.image_url} alt={article.title || 'Yazi gorseli'} class="mb-4 h-48 w-full rounded-xl object-cover" loading="lazy" />
              ) : null}
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                {new Date(article.created_at || Date.now()).toLocaleDateString('tr-TR')}
              </p>
              <p class="mt-2 text-xs font-bold uppercase tracking-wide text-purple-700">{getCategoryLabel(article.category || 'Gundem ve Politika', 'tr')}</p>
              <h2 class="mt-2 text-2xl font-black text-slate-900">{article.title}</h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">{article.excerpt || String(article.body || '').slice(0, 220)}</p>
              <div class="mt-4 flex items-center justify-end text-xs text-slate-500">
                <a href={`/articles/${categorySlug}/${article.slug}`} class="font-bold text-purple-700 hover:text-purple-900">
                  Detay sayfaya git ->
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </section>
  </section>
</MainLayout>
