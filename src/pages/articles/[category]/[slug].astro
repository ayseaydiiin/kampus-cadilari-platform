---
import MainLayout from '../../../layouts/MainLayout.astro';
import { getArticleBySlug } from '../../../utils/db.js';
import { getCategoryLabel, getCategorySlug } from '../../../utils/articleCategories';

export const prerender = false;

const categorySlug = String(Astro.params.category || '').trim();
const slug = String(Astro.params.slug || '').trim();
const article = getArticleBySlug(slug, { publishedOnly: true });

if (!article) {
  return Astro.redirect('/articles');
}

const expectedCategory = getCategorySlug(article.category || 'Gundem ve Politika');
if (categorySlug !== expectedCategory) {
  return Astro.redirect(`/articles/${expectedCategory}/${article.slug}`);
}

const bodyParagraphs = String(article.body || '')
  .split(/\r?\n\r?\n/)
  .map((item) => item.trim())
  .filter(Boolean);

const pageUrl = `${Astro.url.origin}/articles/${expectedCategory}/${article.slug}`;
---

<MainLayout title={`${article.title} - Kampus Cadilari`} description={article.excerpt || String(article.body || '').slice(0, 160)} currentLang="tr">
  <section class="mx-auto max-w-6xl">
    <a href={`/articles/${expectedCategory}`} class="inline-flex items-center gap-2 text-sm font-bold text-purple-700 hover:text-purple-900">Kategoriye geri don</a>

    <article id="archive-export-content" class="mt-4 rounded-[1.75rem] border border-[#d5c6ac] bg-[#fdf8ef] p-5 shadow-lg md:p-8">
      <div>
        <figure class="mb-5 overflow-hidden rounded-[1.25rem] border border-[#e0d3bd] bg-white shadow-sm md:float-left md:mb-4 md:mr-6 md:w-[41%] lg:w-[38%]">
          <img src={article.image_url || '/archive/placeholder-cover.svg'} alt={`${article.title} kapak`} class="h-full w-full object-cover" />
        </figure>

        <div class="md:overflow-hidden">
          <div class="inline-flex items-center gap-2 rounded-full border border-amber-300 bg-amber-100 px-3 py-1 text-xs font-bold text-amber-900">
            <span>Onayli</span>
            <span>Yazi Kaydi</span>
          </div>

          <h1 class="app-h1 mt-4 text-3xl font-black leading-tight text-slate-900 md:text-4xl">{article.title}</h1>
          <p class="mt-2 text-base font-semibold text-slate-700">{getCategoryLabel(article.category || 'Gundem ve Politika', 'tr')}</p>

          <div class="mt-6 grid gap-3 text-sm md:grid-cols-2">
            <div class="rounded-xl bg-white/80 p-3">
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Yayin tarihi</p>
              <p class="mt-1 font-semibold text-slate-900">{new Date(article.created_at || Date.now()).toLocaleDateString('tr-TR')}</p>
            </div>
            <div class="rounded-xl bg-white/80 p-3">
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Kategori slug</p>
              <p class="mt-1 font-semibold text-slate-900">{expectedCategory}</p>
            </div>
            <div class="rounded-xl bg-white/80 p-3 md:col-span-2">
              <p class="text-xs font-bold uppercase tracking-wide text-slate-500">Kisa Ozet</p>
              <p class="mt-1 font-semibold text-slate-900">{article.excerpt || 'Bu yazi icin ozet bulunmuyor.'}</p>
            </div>
          </div>

          <section class="mt-6 max-w-[900px]">
            <h2 class="text-lg font-black text-slate-900">Yazi Icerigi</h2>
            {bodyParagraphs.length ? (
              <div class="mt-3 space-y-4 text-sm leading-7 text-slate-700">
                {bodyParagraphs.map((paragraph) => <p class="whitespace-pre-wrap">{paragraph}</p>)}
              </div>
            ) : (
              <p class="mt-3 whitespace-pre-wrap text-sm leading-7 text-slate-700">{article.body || 'Icerik bulunamadi.'}</p>
            )}
          </section>

          <section class="mt-6 max-w-[900px]">
            <h3 class="text-sm font-black uppercase tracking-wide text-slate-700">Hizli Bilgiler</h3>
            <ul class="mt-2 list-disc space-y-1 pl-5 text-sm leading-7 text-slate-700">
              <li>Giris durumu: Admin onayi ile yayinda.</li>
              <li>Paylasim: Link kopyala aksiyonu ile bu sayfayi paylasabilirsiniz.</li>
            </ul>
          </section>
        </div>
      </div>
    </article>

    <section class="mt-6 rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-base font-black text-slate-900">Paylasim</h2>
      <div class="mt-3 flex flex-wrap gap-3 text-sm font-bold">
        <a
          href={`https://wa.me/?text=${encodeURIComponent(`${article.title} ${pageUrl}`)}`}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700"
        >
          WhatsApp
        </a>
        <a
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(article.title)}&url=${encodeURIComponent(pageUrl)}`}
          target="_blank"
          rel="noreferrer"
          class="rounded-lg bg-sky-500 px-4 py-2 text-sm font-bold text-white hover:bg-sky-600"
        >
          X/Twitter
        </a>
        <button id="copy-link-btn" class="rounded-lg border border-[#5b2c84] px-4 py-2 text-[#5b2c84] transition hover:bg-[#efe5f7]">Baglantiyi Kopyala</button>
      </div>
      <p id="copy-link-state" class="mt-2 text-xs font-semibold text-emerald-700"></p>
    </section>
  </section>

  <script define:vars={{ slug }}>
    const copyBtn = document.getElementById('copy-link-btn');
    const copyState = document.getElementById('copy-link-state');

    async function trackView() {
      try {
        const response = await fetch('/api/articles/view', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ slug }),
        });
        await response.json();
      } catch (error) {
        console.error('view tracking failed', error);
      }
    }

    async function copyToClipboard(text) {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(text);
        return true;
      }

      const helper = document.createElement('textarea');
      helper.value = text;
      helper.setAttribute('readonly', '');
      helper.style.position = 'fixed';
      helper.style.left = '-9999px';
      document.body.appendChild(helper);
      helper.focus();
      helper.select();
      helper.setSelectionRange(0, text.length);
      const copied = document.execCommand('copy');
      document.body.removeChild(helper);
      if (copied) return true;

      window.prompt('Baglantiyi manuel kopyalayin:', text);
      return false;
    }

    copyBtn?.addEventListener('click', async () => {
      try {
        const copied = await copyToClipboard(window.location.href);
        if (copyState) copyState.textContent = copied ? 'Baglanti kopyalandi.' : 'Baglantiyi elle kopyalayin.';
      } catch {
        if (copyState) copyState.textContent = 'Kopyalama basarisiz.';
      }
      setTimeout(() => {
        if (copyState) copyState.textContent = '';
      }, 1500);
    });

    document.addEventListener('DOMContentLoaded', trackView);
  </script>
</MainLayout>
