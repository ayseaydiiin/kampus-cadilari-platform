---
import MainLayout from '../../layouts/MainLayout.astro';
---

<MainLayout title="Admin Submissions - Kampus Cadilari" currentLang="tr">
  <section class="mx-auto max-w-6xl px-4 py-8">
    <header class="rounded-2xl bg-gradient-to-r from-purple-700 to-pink-600 p-8 text-white shadow-xl">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-purple-100">Admin workflow</p>
          <h1 class="mt-2 text-3xl font-black">Basvurular ve Etkinlik Onerileri</h1>
          <p class="mt-3 text-sm text-white/90">Tum admin onayina dayali karar akisini buradan yonet.</p>
        </div>
        <button id="notifToggleBtn" class="relative rounded-full bg-white px-5 py-2 font-bold text-purple-700 hover:bg-purple-50">
          Bildirimler
          <span id="notifBadge" class="ml-2 hidden rounded-full bg-rose-600 px-2 py-0.5 text-xs text-white">0</span>
        </button>
      </div>
    </header>

    <div id="authBox" class="mt-6 rounded-xl border border-gray-200 bg-white p-5 text-sm text-gray-600 shadow-sm">
      Oturum kontrol ediliyor...
    </div>

    <div id="mainContent" class="mt-6 hidden space-y-6">
      <div class="rounded-xl border border-gray-200 bg-white p-3 shadow-sm">
        <div class="flex flex-wrap gap-2">
          <button data-tab="applications" class="tab-btn rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white">Bize Katil Basvurulari</button>
          <button data-tab="events" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Etkinlik Onerileri</button>
          <button data-tab="articles" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Yazi Onaylari</button>
          <button data-tab="archive" class="tab-btn rounded-lg bg-gray-100 px-4 py-2 text-sm font-bold text-gray-700">Gazete Arsivi</button>
        </div>
      </div>

      <section id="applicationsTab" class="space-y-4"></section>
      <section id="eventsTab" class="hidden space-y-4"></section>
      <section id="articlesTab" class="hidden space-y-4"></section>
      <section id="archiveTab" class="hidden space-y-4"></section>
    </div>
  </section>

  <aside id="notifPanel" class="fixed right-4 top-20 z-50 hidden w-full max-w-md rounded-2xl border border-gray-200 bg-white p-4 shadow-2xl">
    <div class="mb-3 flex items-center justify-between">
      <h2 class="text-lg font-black text-gray-900">Admin Bildirimleri</h2>
      <button id="notifMarkAllBtn" class="text-xs font-semibold text-purple-700 hover:underline">Tumunu okundu yap</button>
    </div>
    <div id="notifList" class="max-h-[60vh] space-y-2 overflow-auto"></div>
  </aside>

  <div id="detailModal" class="fixed inset-0 z-40 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-2xl rounded-2xl bg-white p-6 shadow-2xl">
      <div class="mb-4 flex items-center justify-between">
        <h3 id="detailTitle" class="text-2xl font-black text-gray-900">Detay</h3>
        <button id="detailCloseBtn" class="text-2xl text-gray-400 hover:text-gray-700">x</button>
      </div>
      <div id="detailBody" class="space-y-3 text-sm text-gray-700"></div>
      <div id="detailActions" class="mt-6 flex flex-wrap gap-3"></div>
    </div>
  </div>

  <script>
    const authBox = document.getElementById('authBox');
    const mainContent = document.getElementById('mainContent');
    const applicationsTab = document.getElementById('applicationsTab');
    const eventsTab = document.getElementById('eventsTab');
    const articlesTab = document.getElementById('articlesTab');
    const archiveTab = document.getElementById('archiveTab');
    const tabButtons = document.querySelectorAll('.tab-btn');
    const notifToggleBtn = document.getElementById('notifToggleBtn');
    const notifPanel = document.getElementById('notifPanel');
    const notifList = document.getElementById('notifList');
    const notifBadge = document.getElementById('notifBadge');
    const notifMarkAllBtn = document.getElementById('notifMarkAllBtn');
    const detailModal = document.getElementById('detailModal');
    const detailTitle = document.getElementById('detailTitle');
    const detailBody = document.getElementById('detailBody');
    const detailActions = document.getElementById('detailActions');
    const detailCloseBtn = document.getElementById('detailCloseBtn');

    let adminUser = null;
    let eventCache = [];
    let applicationCache = [];
    let articleCache = [];
    let archiveCache = [];
    let archiveAllCache = [];
    let activeTab = 'applications';

    function escapeHtml(value) {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function setActiveTab(tabName) {
      activeTab = tabName;
      const isApplications = tabName === 'applications';
      const isEvents = tabName === 'events';
      const isArticles = tabName === 'articles';
      const isArchive = tabName === 'archive';
      applicationsTab.classList.toggle('hidden', !isApplications);
      eventsTab.classList.toggle('hidden', !isEvents);
      articlesTab.classList.toggle('hidden', !isArticles);
      archiveTab.classList.toggle('hidden', !isArchive);
      tabButtons.forEach((button) => {
        const active = button.dataset.tab === tabName;
        button.classList.toggle('bg-purple-600', active);
        button.classList.toggle('text-white', active);
        button.classList.toggle('bg-gray-100', !active);
        button.classList.toggle('text-gray-700', !active);
      });
    }

    function showModal(title, bodyHtml, actionsHtml = '') {
      detailTitle.textContent = title;
      detailBody.innerHTML = bodyHtml;
      detailActions.innerHTML = actionsHtml;
      detailModal.classList.remove('hidden');
      detailModal.classList.add('flex');
    }

    function closeModal() {
      detailModal.classList.add('hidden');
      detailModal.classList.remove('flex');
    }

    async function loadNotifications() {
      if (!adminUser?.email) return;
      try {
        const response = await fetch(`/api/admin/notifications?adminEmail=${encodeURIComponent(adminUser.email)}&limit=40`);
        const data = await response.json();
        if (!data.success) return;

        const unreadCount = Number(data.unreadCount || 0);
        notifBadge.textContent = unreadCount;
        notifBadge.classList.toggle('hidden', unreadCount === 0);

        if (!data.notifications.length) {
          notifList.innerHTML = '<p class="rounded-lg bg-gray-50 p-3 text-sm text-gray-500">Bildirim yok.</p>';
          return;
        }

        notifList.innerHTML = data.notifications.map((item) => `
          <button data-id="${item.id}" data-related-id="${item.related_id || ''}" data-related-table="${item.related_table || ''}" class="notif-item block w-full rounded-xl border p-3 text-left transition hover:bg-gray-50 ${item.is_read ? 'border-gray-200 bg-white' : 'border-purple-200 bg-purple-50'}">
            <p class="text-xs font-bold uppercase tracking-wide ${item.is_read ? 'text-gray-500' : 'text-purple-700'}">${escapeHtml(item.type)}</p>
            <p class="mt-1 text-sm font-semibold text-gray-900">${escapeHtml(item.title || 'Bildirim')}</p>
            <p class="mt-1 text-xs text-gray-600">${escapeHtml(item.message || '')}</p>
          </button>
        `).join('');

        notifList.querySelectorAll('.notif-item').forEach((button) => {
          button.addEventListener('click', async () => {
            const notificationId = Number(button.dataset.id);
            const relatedTable = button.dataset.relatedTable;
            const relatedId = Number(button.dataset.relatedId);

            await fetch('/api/admin/notifications', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ adminEmail: adminUser.email, notificationId }),
            });
            await loadNotifications();

            if (relatedTable === 'event_proposals' && relatedId) {
              setActiveTab('events');
              const proposal = eventCache.find((item) => Number(item.id) === relatedId);
              if (proposal) showEventDetail(proposal);
            }
            if (relatedTable === 'articles' && relatedId) {
              setActiveTab('articles');
              const article = articleCache.find((item) => Number(item.id) === relatedId);
              if (article) showArticleDetail(article);
            }
            if (relatedTable === 'applications' && relatedId) {
              setActiveTab('applications');
              const app = applicationCache.find((item) => Number(item.id) === relatedId);
              if (app) showApplicationDetail(app);
            }
            if (relatedTable === 'newspaper_archives' && relatedId) {
              setActiveTab('archive');
              const archive =
                archiveAllCache.find((item) => Number(item.id) === relatedId) ||
                archiveCache.find((item) => Number(item.id) === relatedId);
              if (archive) showArchiveDetail(archive);
            }
          });
        });
      } catch (error) {
        notifList.innerHTML = '<p class="rounded-lg bg-red-50 p-3 text-sm text-red-700">Bildirimler yuklenemedi.</p>';
      }
    }

    async function loadApplications() {
      applicationsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Basvurular yukleniyor...</p>';
      try {
        const response = await fetch('/api/admin/applications');
        const data = await response.json();
        applicationCache = Array.isArray(data) ? data : [];

        if (!applicationCache.length) {
          applicationsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Basvuru bulunamadi.</p>';
          return;
        }

        applicationsTab.innerHTML = applicationCache.map((app) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(app.full_name)}</h3>
                <p class="text-sm text-gray-600">${escapeHtml(app.email)} • ${escapeHtml(app.province)}</p>
                <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-purple-700">${escapeHtml(app.status)}</p>
              </div>
              <button data-id="${app.id}" class="app-detail-btn rounded-lg bg-purple-600 px-4 py-2 text-sm font-bold text-white hover:bg-purple-700">Detay</button>
            </div>
          </article>
        `).join('');

        applicationsTab.querySelectorAll('.app-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const appId = Number(button.dataset.id);
            const app = applicationCache.find((item) => Number(item.id) === appId);
            if (app) showApplicationDetail(app);
          });
        });
      } catch (error) {
        applicationsTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Basvurular yuklenemedi.</p>';
      }
    }

    async function loadEventProposals() {
      eventsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Etkinlik onerileri yukleniyor...</p>';
      try {
        const response = await fetch('/api/admin/event-proposals');
        const data = await response.json();
        eventCache = Array.isArray(data) ? data : [];

        if (!eventCache.length) {
          eventsTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Etkinlik onerisi bulunamadi.</p>';
          return;
        }

        eventsTab.innerHTML = eventCache.map((event) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="max-w-3xl">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(event.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(event.proposed_by)} • ${escapeHtml(event.email)}</p>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(event.province || '-')} • ${escapeHtml(event.category || '-')}</p>
                <p class="mt-2 text-sm text-gray-700">${escapeHtml((event.description || '').slice(0, 180))}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Durum: ${escapeHtml(event.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Onay: ${event.approval_summary?.approvedCount || 0}/${event.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Red: ${event.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="flex flex-wrap gap-2">
                <button data-id="${event.id}" class="event-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Detay</button>
                <button data-id="${event.id}" class="event-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
                <button data-id="${event.id}" class="event-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
              </div>
            </div>
          </article>
        `).join('');

        eventsTab.querySelectorAll('.event-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const proposal = eventCache.find((item) => Number(item.id) === Number(button.dataset.id));
            if (proposal) showEventDetail(proposal);
          });
        });

        eventsTab.querySelectorAll('.event-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const proposalId = Number(button.dataset.id);
            await submitEventDecision(proposalId, 'approve');
          });
        });

        eventsTab.querySelectorAll('.event-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const proposalId = Number(button.dataset.id);
            await submitEventDecision(proposalId, 'reject');
          });
        });
      } catch (error) {
        eventsTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Etkinlik onerileri yuklenemedi.</p>';
      }
    }

    async function loadArticleSubmissions() {
      articlesTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Yazi onaylari yukleniyor...</p>';
      try {
        const response = await fetch('/api/admin/articles');
        const payload = await response.json();
        const allArticles = payload?.success && Array.isArray(payload.data) ? payload.data : [];
        articleCache = allArticles;
        const pendingArticles = allArticles.filter((item) => ['pending_approval', 'rejected'].includes(String(item.status)));

        if (!pendingArticles.length) {
          articlesTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Inceleme bekleyen yazi yok.</p>';
          return;
        }

        articlesTab.innerHTML = pendingArticles.map((item) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="max-w-3xl">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(item.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.category || 'Kategori yok')} - /${escapeHtml(item.slug)}</p>
                <p class="mt-2 text-sm text-gray-700 line-clamp-2">${escapeHtml(item.excerpt || '')}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Durum: ${escapeHtml(item.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Onay: ${item.approval_summary?.approvedCount || 0}/${item.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Red: ${item.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="flex flex-wrap gap-2">
                <button data-id="${item.id}" class="article-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Detay</button>
                <button data-id="${item.id}" class="article-comment-btn rounded-lg bg-amber-500 px-3 py-2 text-sm font-bold text-white hover:bg-amber-600">Yorum</button>
                <button data-id="${item.id}" class="article-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
                <button data-id="${item.id}" class="article-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
              </div>
            </div>
          </article>
        `).join('');

        articlesTab.querySelectorAll('.article-detail-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const id = Number(button.dataset.id);
            const result = await fetch(`/api/admin/articles?id=${id}`).then((r) => r.json());
            if (result.success && result.data) showArticleDetail(result.data);
          });
        });

        articlesTab.querySelectorAll('.article-comment-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            const id = Number(button.dataset.id);
            await submitArticleComment(id);
          });
        });

        articlesTab.querySelectorAll('.article-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArticleDecision(Number(button.dataset.id), 'approve');
          });
        });

        articlesTab.querySelectorAll('.article-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArticleDecision(Number(button.dataset.id), 'reject');
          });
        });
      } catch (error) {
        articlesTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Yazi onaylari yuklenemedi.</p>';
      }
    }

    async function loadArchiveSubmissions() {
      archiveTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Arsiv kayitlari yukleniyor...</p>';
      try {
        const response = await fetch('/api/admin/archive');
        const payload = await response.json();
        const allArchiveRows = payload?.success && Array.isArray(payload.data) ? payload.data : [];
        archiveAllCache = allArchiveRows;
        archiveCache = allArchiveRows.filter((item) => ['pending', 'reviewed'].includes(String(item.status)));

        if (!archiveCache.length) {
          archiveTab.innerHTML = '<p class="rounded-xl border border-gray-200 bg-white p-4 text-sm text-gray-500">Inceleme bekleyen arsiv kaydi bulunamadi.</p>';
          return;
        }

        archiveTab.innerHTML = archiveCache.map((item) => `
          <article class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="max-w-3xl">
                <h3 class="text-lg font-bold text-gray-900">${escapeHtml(item.title)}</h3>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.publication_name)} • ${escapeHtml(item.publication_year)}</p>
                <p class="mt-1 text-sm text-gray-600">${escapeHtml(item.focus_topic || 'Genel gundem')}</p>
                <p class="mt-2 text-sm text-gray-700 line-clamp-2">${escapeHtml(item.summary || '')}</p>
                <div class="mt-2 flex flex-wrap gap-2 text-xs">
                  <span class="rounded-full bg-purple-100 px-3 py-1 font-semibold text-purple-700">Durum: ${escapeHtml(item.status)}</span>
                  <span class="rounded-full bg-gray-100 px-3 py-1 font-semibold text-gray-700">Onay: ${item.approval_summary?.approvedCount || 0}/${item.approval_summary?.adminCount || 0}</span>
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-semibold text-rose-700">Red: ${item.approval_summary?.rejectedCount || 0}</span>
                </div>
              </div>
              <div class="flex flex-wrap gap-2">
                <button data-id="${item.id}" class="archive-detail-btn rounded-lg border border-gray-300 px-3 py-2 text-sm font-bold text-gray-700 hover:bg-gray-50">Detay</button>
                <button data-id="${item.id}" class="archive-approve-btn rounded-lg bg-emerald-600 px-3 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
                <button data-id="${item.id}" class="archive-reject-btn rounded-lg bg-rose-600 px-3 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
              </div>
            </div>
          </article>
        `).join('');

        archiveTab.querySelectorAll('.archive-detail-btn').forEach((button) => {
          button.addEventListener('click', () => {
            const item = archiveCache.find((entry) => Number(entry.id) === Number(button.dataset.id));
            if (item) showArchiveDetail(item);
          });
        });

        archiveTab.querySelectorAll('.archive-approve-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArchiveDecision(Number(button.dataset.id), 'approve');
          });
        });

        archiveTab.querySelectorAll('.archive-reject-btn').forEach((button) => {
          button.addEventListener('click', async () => {
            await submitArchiveDecision(Number(button.dataset.id), 'reject');
          });
        });
      } catch (error) {
        archiveTab.innerHTML = '<p class="rounded-xl border border-red-200 bg-red-50 p-4 text-sm text-red-700">Arsiv kayitlari yuklenemedi.</p>';
      }
    }

    function showArchiveDetail(item) {
      const approvalItems = (item.approvals || []).map((entry) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(entry.admin_email)}</strong> • ${escapeHtml(entry.decision)} • ${escapeHtml(entry.comment || '-')}
        </li>
      `).join('');

      showModal(
        `${item.publication_name} - Arsiv Kaydi`,
        `
          <p><strong>Baslik:</strong> ${escapeHtml(item.title)}</p>
          <p><strong>Yil:</strong> ${escapeHtml(item.publication_year)} (${escapeHtml(item.decade || '-')})</p>
          <p><strong>Odak:</strong> ${escapeHtml(item.focus_topic || '-')}</p>
          <p><strong>Durum:</strong> ${escapeHtml(item.status)}</p>
          <p><strong>Ozet:</strong> ${escapeHtml(item.summary || '-')}</p>
          <p><strong>PDF:</strong> ${item.pdf_url ? `<a class="text-purple-700 underline" href="${escapeHtml(item.pdf_url)}" download>PDF indir</a>` : '-'}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin karar gecmisi</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">Henuz karar yok.</li>'}</ul>
          </div>
        `,
        `
          <button id="archiveApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
          <button id="archiveRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
        `
      );

      document.getElementById('archiveApproveBtn')?.addEventListener('click', () => submitArchiveDecision(item.id, 'approve'));
      document.getElementById('archiveRejectBtn')?.addEventListener('click', () => submitArchiveDecision(item.id, 'reject'));
    }

    function showApplicationDetail(app) {
      showModal(
        `${app.full_name} - Basvuru`,
        `
          <p><strong>E-posta:</strong> ${escapeHtml(app.email)}</p>
          <p><strong>Telefon:</strong> ${escapeHtml(app.phone || '-')}</p>
          <p><strong>Sehir:</strong> ${escapeHtml(app.province)}</p>
          <p><strong>Kurum:</strong> ${escapeHtml(app.organization || '-')}</p>
          <p><strong>Mesaj:</strong> ${escapeHtml(app.message || '-')}</p>
          <p><strong>Durum:</strong> ${escapeHtml(app.status)}</p>
        `,
        `
          <button id="appApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
          <button id="appRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
        `
      );

      document.getElementById('appApproveBtn')?.addEventListener('click', () => updateApplicationStatus(app.id, 'approved'));
      document.getElementById('appRejectBtn')?.addEventListener('click', () => updateApplicationStatus(app.id, 'rejected'));
    }

    function showEventDetail(event) {
      const approvalItems = (event.approvals || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> • ${escapeHtml(item.decision)} • ${escapeHtml(item.comment || '-')}
        </li>
      `).join('');

      showModal(
        `${event.title} - Etkinlik Onerisi`,
        `
          <p><strong>Oneren:</strong> ${escapeHtml(event.proposed_by)} (${escapeHtml(event.email)})</p>
          <p><strong>Sehir:</strong> ${escapeHtml(event.province || '-')}</p>
          <p><strong>Kategori:</strong> ${escapeHtml(event.category || '-')}</p>
          <p><strong>Telefon:</strong> ${escapeHtml(event.organizer_phone || '-')}</p>
          <p><strong>Durum:</strong> ${escapeHtml(event.status)}</p>
          <p><strong>Aciklama:</strong> ${escapeHtml(event.description || '-')}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin karar gecmisi</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">Henuz karar yok.</li>'}</ul>
          </div>
        `,
        `
          <button id="eventApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
          <button id="eventRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
        `
      );

      document.getElementById('eventApproveBtn')?.addEventListener('click', () => submitEventDecision(event.id, 'approve'));
      document.getElementById('eventRejectBtn')?.addEventListener('click', () => submitEventDecision(event.id, 'reject'));
    }

    function showArticleDetail(article) {
      const approvalItems = (article.approvals || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> - ${escapeHtml(item.decision)} - ${escapeHtml(item.comment || '-')}
        </li>
      `).join('');

      const commentItems = (article.comments || []).map((item) => `
        <li class="rounded-lg bg-gray-50 p-2 text-xs">
          <strong>${escapeHtml(item.admin_email)}</strong> - ${escapeHtml(item.comment)} - ${new Date(item.created_at).toLocaleString('tr-TR')}
        </li>
      `).join('');

      showModal(
        `${article.title} - Yazi Onayi`,
        `
          <p><strong>Kategori:</strong> ${escapeHtml(article.category || '-')}</p>
          <p><strong>Slug:</strong> /${escapeHtml(article.slug || '-')}</p>
          <p><strong>Durum:</strong> ${escapeHtml(article.status)}</p>
          <p><strong>Kisa metin:</strong> ${escapeHtml(article.excerpt || '-')}</p>
          <p><strong>Uzun metin:</strong> ${escapeHtml(String(article.body || '').slice(0, 600))}${String(article.body || '').length > 600 ? '...' : ''}</p>
          <div>
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin karar gecmisi</p>
            <ul class="space-y-1">${approvalItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">Henuz karar yok.</li>'}</ul>
          </div>
          <div class="mt-3">
            <p class="mb-1 text-xs font-bold uppercase tracking-wide text-gray-500">Admin yorumlari</p>
            <ul class="space-y-1">${commentItems || '<li class="rounded-lg bg-gray-50 p-2 text-xs">Henuz yorum yok.</li>'}</ul>
          </div>
        `,
        `
          <button id="articleCommentBtn" class="rounded-lg bg-amber-500 px-4 py-2 text-sm font-bold text-white hover:bg-amber-600">Yorum Ekle</button>
          <button id="articleApproveBtn" class="rounded-lg bg-emerald-600 px-4 py-2 text-sm font-bold text-white hover:bg-emerald-700">Onayla</button>
          <button id="articleRejectBtn" class="rounded-lg bg-rose-600 px-4 py-2 text-sm font-bold text-white hover:bg-rose-700">Reddet</button>
        `
      );

      document.getElementById('articleCommentBtn')?.addEventListener('click', () => submitArticleComment(article.id));
      document.getElementById('articleApproveBtn')?.addEventListener('click', () => submitArticleDecision(article.id, 'approve'));
      document.getElementById('articleRejectBtn')?.addEventListener('click', () => submitArticleDecision(article.id, 'reject'));
    }

    async function updateApplicationStatus(id, status) {
      const notes = window.prompt('Opsiyonel admin notu:') || null;
      await fetch('/api/admin/applications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id,
          status,
          notes,
          reviewedBy: adminUser?.email || 'admin',
        }),
      });
      closeModal();
      await loadApplications();
      await loadNotifications();
    }

    async function submitEventDecision(proposalId, action) {
      const comment = window.prompt(action === 'approve' ? 'Onay notu (opsiyonel):' : 'Red sebebi (opsiyonel):') || null;
      const endpoint = `/api/admin/event-proposals/${proposalId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        window.alert(data.error || 'Islem basarisiz');
        return;
      }

      closeModal();
      await loadEventProposals();
      await loadNotifications();
    }

    async function submitArticleDecision(articleId, action) {
      const comment = window.prompt(action === 'approve' ? 'Onay notu (opsiyonel):' : 'Red sebebi (opsiyonel):') || null;
      const endpoint = `/api/admin/articles/${articleId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        window.alert(data.error || 'Islem basarisiz');
        return;
      }

      closeModal();
      await loadArticleSubmissions();
      await loadNotifications();
    }

    async function submitArticleComment(articleId) {
      const comment = window.prompt('Admin yorumu:');
      if (!comment || !comment.trim()) return;

      const response = await fetch('/api/admin/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          action: 'comment',
          articleId,
          adminEmail: adminUser?.email,
          comment: comment.trim(),
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        window.alert(data.error || 'Yorum kaydedilemedi');
        return;
      }

      await loadArticleSubmissions();
      await loadNotifications();
    }

    async function submitArchiveDecision(archiveId, action) {
      const comment = window.prompt(action === 'approve' ? 'Onay notu (opsiyonel):' : 'Red sebebi (opsiyonel):') || null;
      const endpoint = `/api/admin/archive/${archiveId}/${action}`;
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          adminEmail: adminUser?.email,
          comment,
        }),
      });

      const data = await response.json();
      if (!response.ok || !data.success) {
        window.alert(data.error || 'Islem basarisiz');
        return;
      }

      closeModal();
      await loadArchiveSubmissions();
      await loadNotifications();
    }

    function initAuth() {
      const token = localStorage.getItem('admin_auth_token');
      const rawUser = localStorage.getItem('admin_auth_user');
      if (!token || !rawUser) {
        authBox.innerHTML = 'Yetki bulunamadi. <a class="font-semibold text-purple-700 underline" href="/admin/login-email">Giris yap</a>.';
        setTimeout(() => window.location.replace('/admin/login-email'), 600);
        return false;
      }

      try {
        adminUser = JSON.parse(rawUser);
      } catch {
        authBox.textContent = 'Oturum verisi okunamadi.';
        return false;
      }

      authBox.innerHTML = `<span class="font-semibold text-gray-900">${escapeHtml(adminUser.email || 'admin')}</span> ile giris yapildi.`;
      mainContent.classList.remove('hidden');
      return true;
    }

    tabButtons.forEach((button) => {
      button.addEventListener('click', () => setActiveTab(button.dataset.tab));
    });

    detailCloseBtn?.addEventListener('click', closeModal);
    detailModal?.addEventListener('click', (event) => {
      if (event.target === detailModal) closeModal();
    });

    notifToggleBtn?.addEventListener('click', () => {
      notifPanel.classList.toggle('hidden');
    });

    notifMarkAllBtn?.addEventListener('click', async () => {
      await fetch('/api/admin/notifications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ adminEmail: adminUser?.email, markAll: true }),
      });
      await loadNotifications();
    });

    document.addEventListener('click', (event) => {
      if (!notifPanel.contains(event.target) && !notifToggleBtn.contains(event.target)) {
        notifPanel.classList.add('hidden');
      }
    });

    if (initAuth()) {
      setActiveTab('applications');
      loadApplications();
      loadEventProposals();
      loadArticleSubmissions();
      loadArchiveSubmissions();
      loadNotifications();
    }
  </script>
</MainLayout>
