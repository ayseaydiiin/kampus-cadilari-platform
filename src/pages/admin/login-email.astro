---
import MainLayout from '../../layouts/MainLayout.astro';

const SESSION_MAX_HOURS = 8;
---

<MainLayout title="Admin Giris - Kampus Cadilari" currentLang="tr">
  <section class="mx-auto flex min-h-[70vh] max-w-3xl items-center justify-center">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-xl">
      <div class="text-center">
        <div class="mx-auto grid h-14 w-14 place-items-center rounded-2xl bg-gradient-to-br from-purple-700 to-pink-600 text-sm font-black text-white">KM</div>
        <h1 class="app-h1 mt-4 text-3xl font-black text-slate-900">Admin Giris</h1>
        <p class="mt-2 text-sm text-slate-600">Yetkili paneline erismek icin e-posta ve parolanizi girin.</p>
      </div>

      <div id="message" class="hidden mt-5 rounded-xl p-4 text-sm font-semibold"></div>
      <div id="loading" class="mt-5 hidden rounded-xl bg-blue-100 p-4 text-sm font-semibold text-blue-800">Giris kontrol ediliyor...</div>

      <form id="login-form" class="mt-5 space-y-4">
        <label class="block">
          <span class="mb-2 block text-sm font-bold text-slate-700">E-posta</span>
          <input id="email" type="email" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 focus:border-purple-600 focus:outline-none" placeholder="admin@kampuscadilari.org" />
        </label>

        <label class="block">
          <span class="mb-2 block text-sm font-bold text-slate-700">Parola</span>
          <input id="password" type="password" required class="w-full rounded-xl border border-slate-300 px-4 py-3 text-slate-900 focus:border-purple-600 focus:outline-none" placeholder="********" />
        </label>

        <button id="submit-btn" type="submit" class="w-full rounded-xl bg-gradient-to-r from-purple-700 to-pink-600 py-3 text-sm font-bold text-white transition hover:opacity-90 disabled:opacity-50">
          Giris Yap
        </button>
      </form>
    </div>
  </section>

  <script define:vars={{ SESSION_MAX_HOURS }}>
    const form = document.getElementById('login-form');
    const emailInput = document.getElementById('email');
    const passwordInput = document.getElementById('password');
    const submitBtn = document.getElementById('submit-btn');
    const messageDiv = document.getElementById('message');
    const loadingDiv = document.getElementById('loading');
    const SESSION_MAX_MS = Number(SESSION_MAX_HOURS || 8) * 60 * 60 * 1000;

    localStorage.removeItem('admin_auth_token');
    localStorage.removeItem('admin_auth_user');

    function getTokenExpiryMs(token) {
      try {
        const payload = JSON.parse(atob(String(token).split('.')[1] || ''));
        if (payload?.exp) return Number(payload.exp) * 1000;
      } catch {}
      return null;
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      messageDiv.className = 'hidden mt-5 rounded-xl p-4 text-sm font-semibold';
      loadingDiv.classList.remove('hidden');
      submitBtn.disabled = true;

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: emailInput.value,
            password: passwordInput.value,
          }),
        });

        const raw = await response.text();
        let data = null;

        try {
          data = raw ? JSON.parse(raw) : null;
        } catch {
          data = { success: false, error: raw || `Beklenmeyen yanit (HTTP ${response.status})` };
        }

        if (response.ok && data?.success) {
          const tokenExpiry = getTokenExpiryMs(data.token);
          const clientExpiry = Date.now() + SESSION_MAX_MS;
          const expiryMs = tokenExpiry ? Math.min(tokenExpiry, clientExpiry) : clientExpiry;

          sessionStorage.setItem('admin_auth_token', data.token);
          sessionStorage.setItem('admin_auth_user', JSON.stringify(data.user));
          sessionStorage.setItem('admin_auth_expires_at', String(expiryMs));

          messageDiv.className = 'mt-5 rounded-xl border border-green-300 bg-green-50 p-4 text-sm font-semibold text-green-700';
          messageDiv.textContent = 'Giris basarili. Panel aciliyor...';
          setTimeout(() => window.location.replace('/admin/'), 400);
          return;
        }

        messageDiv.className = 'mt-5 rounded-xl border border-red-300 bg-red-50 p-4 text-sm font-semibold text-red-700';
        messageDiv.textContent = data?.error || `Giris basarisiz (HTTP ${response.status})`;
        passwordInput.value = '';
        passwordInput.focus();
      } catch {
        messageDiv.className = 'mt-5 rounded-xl border border-red-300 bg-red-50 p-4 text-sm font-semibold text-red-700';
        messageDiv.textContent = 'Baglanti hatasi. Lutfen tekrar deneyin.';
      } finally {
        loadingDiv.classList.add('hidden');
        submitBtn.disabled = false;
      }
    });
  </script>
</MainLayout>
