---
import MainLayout from '../../layouts/MainLayout.astro';
import AdminNotificationPanel from '../../components/AdminNotificationPanel.astro';
import fs from 'node:fs';
import path from 'node:path';
import { getCategoryDefinitions } from '../../utils/articleCategories';

const articlesDir = path.join(process.cwd(), 'content', 'articles');
const eventsDir = path.join(process.cwd(), 'content', 'events');
const articleCount = fs.existsSync(articlesDir) ? fs.readdirSync(articlesDir).filter((item) => item.endsWith('.md') || item.endsWith('.mdx')).length : 0;
const eventCount = fs.existsSync(eventsDir) ? fs.readdirSync(eventsDir).filter((item) => item.endsWith('.md') || item.endsWith('.mdx')).length : 0;
const archiveCount = 0;
const articleCategories = getCategoryDefinitions();
---

<MainLayout title="Admin Paneli - Kampus Cadilari" currentLang="tr">
  <section class="mx-auto max-w-6xl">
    <div id="admin-loading" class="rounded-[1.75rem] border border-[rgba(225,6,0,0.16)] bg-[linear-gradient(135deg,rgba(110,44,138,0.98),rgba(87,33,111,0.96)_58%,rgba(225,6,0,0.9))] p-8 text-white shadow-2xl">
      <p class="text-sm font-bold uppercase tracking-[0.2em] text-white/75">Dashboard</p>
      <h1 class="app-h1 mt-3 text-4xl font-black">Dijital Karargah aciliyor</h1>
      <p class="mt-4 max-w-2xl text-white/85">Kimlik dogrulaniyor, yonetim paneli yukleniyor.</p>
    </div>

    <div id="admin-panel" class="hidden">
      <section class="rounded-[1.75rem] border border-[rgba(225,6,0,0.16)] bg-[linear-gradient(135deg,rgba(110,44,138,0.98),rgba(87,33,111,0.96)_58%,rgba(225,6,0,0.9))] p-8 text-white shadow-2xl">
        <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="text-sm font-bold uppercase tracking-[0.22em] text-white/75">Ana dashboard</p>
            <h1 class="app-h1 mt-3 text-4xl font-black">Hos geldin, <span id="admin-name">admin</span></h1>
            <p class="mt-4 max-w-2xl text-white/85">Icerik kutucuklari ve admin bildirimlerini buradan yonet.</p>
          </div>
          <div class="flex flex-wrap gap-3">
            <button id="notif-toggle-btn" class="relative rounded-full border border-white/35 bg-white/12 px-5 py-3 font-bold text-white transition hover:bg-white/22">
              Bildirimler
              <span id="notif-badge" class="ml-2 hidden rounded-full bg-[var(--color-red-accent)] px-2 py-0.5 text-xs font-bold text-white">0</span>
            </button>
            <button id="logout-button" class="rounded-full bg-white px-6 py-3 font-bold text-[var(--color-purple-primary)] transition hover:bg-white/90">Cikis yap</button>
          </div>
        </div>
      </section>

      <section class="mt-8 grid gap-4 md:grid-cols-4">
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-slate-500">Oturum</p>
          <p id="admin-email" class="mt-3 text-lg font-black text-slate-900"></p>
          <p id="admin-role" class="mt-1 text-sm text-slate-600"></p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-purple-700">Toplam yazi</p>
          <p id="stat-articles" class="mt-3 text-4xl font-black text-slate-900">{articleCount}</p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-purple-700">Toplam arsiv kaydi</p>
          <p id="stat-archive" class="mt-3 text-4xl font-black text-slate-900">{archiveCount}</p>
        </article>
        <article class="rounded-[1.5rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
          <p class="text-xs font-bold uppercase tracking-[0.18em] text-[var(--color-red-accent)]">Toplam etkinlik</p>
          <p id="stat-events" class="mt-3 text-4xl font-black text-slate-900">{eventCount}</p>
        </article>
      </section>

      <section class="mt-8 grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
        <div class="grid gap-6">
          <article class="rounded-[1.75rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-sm font-bold uppercase tracking-[0.2em] text-purple-700">Icerik Yonetimi</p>
                <p class="mt-1 text-sm text-slate-600">Yeni yazi icin kutucuk ac, tum alanlari doldur ve kaydet.</p>
              </div>
              <button id="article-add-btn" class="rounded-full bg-purple-600 px-4 py-2 font-bold text-white hover:bg-purple-700">Yeni Yazi Kutucugu</button>
            </div>
            <div id="article-list" class="mt-5 space-y-3"></div>
          </article>
        </div>

        <div class="grid gap-6">
          <article class="rounded-[1.75rem] bg-white p-6 shadow-lg ring-1 ring-slate-200">
            <p class="text-sm font-bold uppercase tracking-[0.2em] text-[var(--color-red-accent)]">Hizli erisim</p>
            <div class="mt-5 grid gap-3">
              <a href="/articles" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Icerik arsivine git</a>
              <a href="/archive" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Gazete arsivini ac</a>
              <a href="/events" class="rounded-2xl bg-slate-50 px-4 py-4 font-semibold text-slate-800 transition hover:bg-purple-50">Etkinlik takvimini ac</a>
              <button id="password-open-btn" type="button" class="rounded-2xl bg-slate-50 px-4 py-4 text-left font-semibold text-slate-800 transition hover:bg-purple-50">Sifre Degistir</button>
              <a href="/admin/submissions" class="rounded-2xl bg-purple-100 px-4 py-4 font-semibold text-purple-800 transition hover:bg-purple-200">-> Basvurular ve onay akislari</a>
            </div>
          </article>
        </div>
      </section>
    </div>
  </section>

  <AdminNotificationPanel locale="tr" />

  <div id="article-modal" class="fixed inset-0 z-50 hidden items-end justify-center bg-black/60 p-3 sm:items-center sm:p-4">
    <div class="flex max-h-[88vh] w-[min(94vw,56rem)] flex-col overflow-hidden rounded-2xl bg-white shadow-2xl">
      <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3 sm:px-6 sm:py-4">
        <h3 id="article-modal-title" class="text-2xl font-black text-slate-900">Yeni Yazi</h3>
        <button id="article-modal-close" class="rounded-full bg-slate-100 px-3 py-1 text-sm font-bold text-slate-600">Kapat</button>
      </div>
      <form id="article-form" class="grid max-h-[72vh] gap-4 overflow-y-auto px-4 py-4 sm:max-h-[74vh] sm:px-6 sm:py-5 md:grid-cols-2">
        <input type="hidden" name="id" />
        <div>
          <label class="text-sm font-semibold text-slate-700">Baslik</label>
          <input name="title" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" />
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Fotograf URL</label>
          <input name="image_url" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" placeholder="https://..." />
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Slug (URL)</label>
          <input name="slug" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2" placeholder="yazi-basligi" />
          <p class="mt-1 text-xs text-slate-500">Slug, yazinin adresinde gorunen SEO dostu kisa kimliktir.</p>
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Kategori</label>
          <select name="category" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2">
            {articleCategories.map((category) => (
              <option value={category.tr}>{category.tr}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="text-sm font-semibold text-slate-700">Durum</label>
          <select name="status" class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2">
            <option value="draft">Taslak</option>
            <option value="pending_approval">Admin onayi bekliyor</option>
            <option value="published">Yayinda</option>
          </select>
        </div>
        <div class="md:col-span-2">
          <label class="text-sm font-semibold text-slate-700">Icerik (Kisa metin)</label>
          <textarea name="excerpt" rows="3" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2"></textarea>
        </div>
        <div class="md:col-span-2">
          <label class="text-sm font-semibold text-slate-700">Uzun metin</label>
          <textarea name="body" rows="8" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2"></textarea>
        </div>
        <div class="md:col-span-2 flex justify-end gap-3">
          <button id="article-modal-cancel" type="button" class="rounded-xl border border-slate-300 px-4 py-2 font-semibold text-slate-700">Vazgec</button>
          <button type="submit" class="rounded-xl bg-purple-600 px-4 py-2 font-semibold text-white hover:bg-purple-700">Kaydet</button>
        </div>
      </form>
    </div>
  </div>

  <div id="password-modal" class="fixed inset-0 z-50 hidden items-end justify-center bg-black/60 p-3 sm:items-center sm:p-4">
    <div class="w-[min(94vw,30rem)] rounded-2xl bg-white p-5 shadow-2xl sm:p-6">
      <div class="flex items-center justify-between">
        <h3 class="text-xl font-black text-slate-900">Sifre Degistir</h3>
        <button id="password-close-btn" type="button" class="rounded-full bg-slate-100 px-3 py-1 text-xs font-bold text-slate-600">Kapat</button>
      </div>
      <form id="password-form" class="mt-4 space-y-3">
        <div>
          <label for="password-current" class="text-xs font-bold uppercase tracking-wide text-slate-500">Mevcut sifre</label>
          <input id="password-current" type="password" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2 text-sm" />
        </div>
        <div>
          <label for="password-new" class="text-xs font-bold uppercase tracking-wide text-slate-500">Yeni sifre</label>
          <input id="password-new" type="password" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2 text-sm" />
          <p id="password-policy-error" class="mt-1 hidden text-xs font-semibold text-red-600">Yeni sifrede en az 1 buyuk harf, 1 rakam ve 1 ozel karakter (+ gibi) olmali.</p>
        </div>
        <div>
          <label for="password-confirm" class="text-xs font-bold uppercase tracking-wide text-slate-500">Yeni sifre tekrar</label>
          <input id="password-confirm" type="password" required class="mt-1 w-full rounded-xl border border-slate-300 px-4 py-2 text-sm" />
          <p id="password-match-error" class="mt-1 hidden text-xs font-semibold text-red-600">Girdigin sifreler birbiriyle ayni degil.</p>
          <p id="password-old-error" class="mt-1 hidden text-xs font-semibold text-red-600">Eski sifreyi tekrar kullanamazsin.</p>
        </div>
        <div class="pt-2">
          <button id="password-submit-btn" type="submit" class="rounded-xl bg-purple-700 px-4 py-2 text-sm font-bold text-white hover:bg-purple-800">Sifreyi Guncelle</button>
        </div>
        <p id="password-api-error" class="hidden text-xs font-semibold text-red-600"></p>
      </form>
    </div>
  </div>

  <script is:inline src="/admin-ui.js"></script>
  <script>
    const loadingBox = document.getElementById('admin-loading');
    const panel = document.getElementById('admin-panel');
    const adminName = document.getElementById('admin-name');
    const adminEmail = document.getElementById('admin-email');
    const adminRole = document.getElementById('admin-role');
    const logoutButton = document.getElementById('logout-button');
    const articleList = document.getElementById('article-list');
    const articleAddBtn = document.getElementById('article-add-btn');
    const articleModal = document.getElementById('article-modal');
    const articleModalTitle = document.getElementById('article-modal-title');
    const articleModalClose = document.getElementById('article-modal-close');
    const articleModalCancel = document.getElementById('article-modal-cancel');
    const articleForm = document.getElementById('article-form');
    const notifToggleBtn = document.getElementById('notif-toggle-btn');
    const notifBadge = document.getElementById('notif-badge');
    const notifPanel = document.getElementById('notif-panel');
    const notifList = document.getElementById('notif-list');
    const notifCloseBtn = document.getElementById('notif-close-btn');
    const notifMarkAllBtn = document.getElementById('notif-mark-all-btn');
    const notifDeleteSelectedBtn = document.getElementById('notif-delete-selected-btn');
    const statArticles = document.getElementById('stat-articles');
    const statArchive = document.getElementById('stat-archive');
    const statEvents = document.getElementById('stat-events');
    const passwordOpenBtn = document.getElementById('password-open-btn');
    const passwordModal = document.getElementById('password-modal');
    const passwordCloseBtn = document.getElementById('password-close-btn');
    const passwordForm = document.getElementById('password-form');
    const passwordCurrentInput = document.getElementById('password-current');
    const passwordNewInput = document.getElementById('password-new');
    const passwordConfirmInput = document.getElementById('password-confirm');
    const passwordPolicyError = document.getElementById('password-policy-error');
    const passwordMatchError = document.getElementById('password-match-error');
    const passwordOldError = document.getElementById('password-old-error');
    const passwordSubmitBtn = document.getElementById('password-submit-btn');
    const passwordApiError = document.getElementById('password-api-error');

    let currentAdmin = null;
    const ui = window.AdminUi?.create({ locale: 'tr' });

    function showToast(message, type = 'info') {
      if (ui) {
        ui.toast(message, type);
        return;
      }
      console.log(message);
    }

    async function askText(message, placeholder = '') {
      if (ui) {
        return ui.prompt(message, 'Girdi gerekli', placeholder);
      }
      return null;
    }

    async function askConfirm(message) {
      if (ui) {
        return ui.confirm(message, 'Onay gerekiyor', 'Evet', 'Iptal');
      }
      return false;
    }

    async function showDetails(message, title = 'Detay') {
      if (ui) {
        await ui.details(message, title);
        return;
      }
      console.log(message);
    }

    function escapeHtml(value) {
      return String(value || '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;');
    }

    function clearAdminSession() {
      try {
        sessionStorage.removeItem('admin_auth_token');
        sessionStorage.removeItem('admin_auth_user');
        sessionStorage.removeItem('admin_auth_expires_at');
      } catch {}
      try {
        localStorage.removeItem('admin_auth_token');
        localStorage.removeItem('admin_auth_user');
      } catch {}
    }

    function openModal(node) {
      node?.classList.remove('hidden');
      node?.classList.add('flex');
    }

    function closeModal(node) {
      node?.classList.add('hidden');
      node?.classList.remove('flex');
    }

    function isStrongPassword(value) {
      const hasUpper = /[A-Z]/.test(value);
      const hasNumber = /\d/.test(value);
      const hasSpecial = /[^A-Za-z0-9]/.test(value);
      return value.length >= 8 && hasUpper && hasNumber && hasSpecial;
    }

    function syncPasswordValidation() {
      const currentValue = String(passwordCurrentInput?.value || '');
      const newValue = String(passwordNewInput?.value || '');
      const confirmValue = String(passwordConfirmInput?.value || '');
      const strong = isStrongPassword(newValue);
      const match = !confirmValue || newValue === confirmValue;
      const oldReuse = !!newValue && newValue === currentValue;

      passwordPolicyError?.classList.toggle('hidden', strong || !newValue);
      passwordMatchError?.classList.toggle('hidden', match);
      passwordOldError?.classList.toggle('hidden', !oldReuse);

      return { strong, match, oldReuse };
    }

    function setPasswordFeedback(message = '', tone = 'error') {
      if (!passwordApiError) return;
      const isSuccess = tone === 'success';
      passwordApiError.textContent = message;
      passwordApiError.classList.toggle('hidden', !message);
      passwordApiError.classList.toggle('text-red-600', !isSuccess);
      passwordApiError.classList.toggle('text-emerald-600', isSuccess);
    }

    async function bootAdminPanel() {
      let userRaw = null;
      let expiresAtRaw = null;
      try {
        userRaw = sessionStorage.getItem('admin_auth_user');
        expiresAtRaw = sessionStorage.getItem('admin_auth_expires_at');
      } catch {}

      const expiresAt = Number(expiresAtRaw || '0');
      if (userRaw && expiresAt && Date.now() < expiresAt) {
        try {
          currentAdmin = JSON.parse(userRaw);
        } catch {
          currentAdmin = null;
        }
      }

      if (!currentAdmin) {
        try {
          const response = await fetch('/api/auth/me');
          const payload = await response.json();
          if (response.ok && payload?.authenticated && payload?.user) {
            currentAdmin = payload.user;
            try {
              sessionStorage.setItem('admin_auth_user', JSON.stringify(payload.user));
              sessionStorage.setItem('admin_auth_expires_at', String(Date.now() + 8 * 60 * 60 * 1000));
            } catch {}
          }
        } catch {}
      }

      if (!currentAdmin) {
        clearAdminSession();
        return window.location.replace('/admin/login-email');
      }

      adminName.textContent = currentAdmin.username || 'admin';
      adminEmail.textContent = currentAdmin.email || '';
      adminRole.textContent = `Rol: ${currentAdmin.role || 'editor'}`;
      loadingBox.classList.add('hidden');
      panel.classList.remove('hidden');
    }

    logoutButton?.addEventListener('click', async () => {
      clearAdminSession();
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.replace('/admin/login-email');
    });

    async function loadStats() {
      try {
        const res = await fetch('/api/admin/stats');
        const json = await res.json();
        if (!json.success) return;
        if (statArticles) statArticles.textContent = json.articles ?? statArticles.textContent;
        if (statArchive) statArchive.textContent = json.archive?.total ?? statArchive.textContent;
        if (statEvents) statEvents.textContent = json.proposals?.total ?? statEvents.textContent;
      } catch {}
    }

    async function loadNotifications() {
      if (!currentAdmin?.email) return;
      const res = await fetch('/api/admin/notifications?limit=40');
      const json = await res.json();
      if (!json.success) return;

      const unread = Number(json.unreadCount || 0);
      notifBadge.textContent = unread;
      notifBadge.classList.toggle('hidden', unread === 0);

      if (!json.notifications.length) {
        notifList.innerHTML = '<p class="rounded-lg bg-gray-50 p-3 text-sm text-gray-500">Bildirim yok.</p>';
        return;
      }

      notifList.innerHTML = json.notifications
        .map(
          (item) => `
            <label class="block rounded-xl border p-3 ${item.is_read ? 'border-slate-200 bg-white' : 'border-purple-200 bg-purple-50'}">
              <div class="flex items-start gap-3">
                <input type="checkbox" class="notif-select mt-1" value="${item.id}" />
                <button type="button" class="notif-open-btn flex-1 text-left" data-id="${item.id}" data-related-table="${escapeHtml(item.related_table || '')}" data-related-id="${Number(item.related_id || 0)}">
                  <p class="text-xs font-bold uppercase tracking-wide">${escapeHtml(item.type)}</p>
                  <p class="mt-1 text-sm font-semibold text-slate-900">${escapeHtml(item.title || 'Bildirim')}</p>
                  <p class="mt-1 text-xs text-slate-600">${escapeHtml(item.message || '')}</p>
                </button>
              </div>
            </label>
          `
        )
        .join('');

      notifList.querySelectorAll('.notif-open-btn').forEach((button) => {
        button.addEventListener('click', async () => {
          const notificationId = Number(button.dataset.id || '0');
          const relatedTable = String(button.dataset.relatedTable || '');
          const relatedId = Number(button.dataset.relatedId || '0');
          if (notificationId > 0) {
            await fetch('/api/admin/notifications', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ notificationId }),
            });
          }
          const targetTab = relatedTable === 'applications'
            ? 'applications'
            : relatedTable === 'event_proposals'
              ? 'events'
              : relatedTable === 'newspaper_archives'
                ? 'archive'
                : 'articles';
          window.location.href = `/admin/submissions?tab=${encodeURIComponent(targetTab)}&id=${encodeURIComponent(relatedId)}`;
        });
      });
    }

    notifToggleBtn?.addEventListener('click', () => notifPanel.classList.toggle('hidden'));
    notifCloseBtn?.addEventListener('click', () => notifPanel.classList.add('hidden'));
    notifMarkAllBtn?.addEventListener('click', async () => {
      await fetch('/api/admin/notifications', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ markAll: true }),
      });
      loadNotifications();
    });
    notifDeleteSelectedBtn?.addEventListener('click', async () => {
      const ids = Array.from(document.querySelectorAll('.notif-select:checked')).map((el) => Number(el.value));
      if (!ids.length) {
        showToast('Lutfen silmek icin bildirim sec.', 'warning');
        return;
      }
      await fetch('/api/admin/notifications', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notificationIds: ids }),
      });
      loadNotifications();
    });

    async function loadArticles() {
      articleList.innerHTML = '<div class="text-sm text-gray-500">Yukleniyor...</div>';
      const res = await fetch('/api/admin/articles');
      const json = await res.json();
      if (!json.success) {
        articleList.innerHTML = `<div class="text-sm text-red-600">${escapeHtml(json.error || 'Hata')}</div>`;
        return;
      }
      if (!json.data.length) {
        articleList.innerHTML = '<div class="text-sm text-gray-500">Henuz yazi yok.</div>';
        return;
      }

      articleList.innerHTML = json.data
        .map(
          (a) => `
            <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
              <div class="flex flex-col gap-3">
                <div class="flex flex-wrap items-center gap-2">
                  <button data-id="${a.id}" class="article-detail rounded border border-slate-300 bg-white px-3 py-1 text-xs font-bold text-slate-700">Detay</button>
                  <button data-id="${a.id}" class="article-comment rounded bg-amber-100 px-3 py-1 text-xs font-bold text-amber-800">Yorum</button>
                  <button data-id="${a.id}" class="article-approve rounded bg-emerald-100 px-3 py-1 text-xs font-bold text-emerald-800">Onayla</button>
                  <button data-id="${a.id}" class="article-reject rounded bg-rose-100 px-3 py-1 text-xs font-bold text-rose-800">Reddet</button>
                  <button data-id="${a.id}" class="article-edit rounded bg-slate-100 px-3 py-1 text-xs font-bold text-slate-700">Duzenle</button>
                  <button data-id="${a.id}" class="article-del rounded bg-red-100 px-3 py-1 text-xs font-bold text-red-700">Sil</button>
                </div>
                <div class="min-w-0">
                  <p class="text-base font-black leading-snug text-slate-900">${escapeHtml(a.title)}</p>
                  <p class="mt-1 text-xs text-slate-500">/${escapeHtml(a.slug)} - ${escapeHtml(a.status)}</p>
                  <p class="mt-1 text-xs text-slate-500">${escapeHtml(a.category || 'Kategori yok')}</p>
                  <p class="mt-1 text-[11px] font-semibold text-slate-500">Onay: ${a.approval_summary?.approvedCount || 0}/${a.approval_summary?.adminCount || 0} - Red: ${a.approval_summary?.rejectedCount || 0} - Okunma: ${a.tracked_view_count || 0}</p>
                </div>
              </div>
            </article>
          `
        )
        .join('');

      articleList.querySelectorAll('.article-detail').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const detail = await fetch(`/api/admin/articles?id=${btn.dataset.id}`).then((r) => r.json());
          if (!detail.success || !detail.data) return;
          const item = detail.data;
          const approvals =
            (item.approvals || [])
              .map((entry) => `${entry.admin_email}: ${entry.decision}${entry.comment ? ` (${entry.comment})` : ''}`)
              .join('\n') || 'Henuz karar yok';
          const comments = (item.comments || []).map((entry) => `${entry.admin_email}: ${entry.comment}`).join('\n') || 'Henuz yorum yok';
          await showDetails(
            `Yazi: ${item.title}\nDurum: ${item.status}\nSlug: /${item.slug}\nOkunma: ${item.tracked_view_count || 0}\n\nAdmin kararlari:\n${approvals}\n\nAdmin yorumlari:\n${comments}`,
            'Yazi detayi'
          );
        });
      });

      articleList.querySelectorAll('.article-comment').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = await askText('Admin yorumu:', 'Yorumunuzu yazin');
          if (!comment || !comment.trim()) return;
          const response = await fetch('/api/admin/articles', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                action: 'comment',
                articleId: Number(btn.dataset.id),
                comment: comment.trim(),
              }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Yorum eklenemedi', 'error');
            return;
          }
          showToast('Yorum eklendi.', 'success');
          loadArticles();
          loadNotifications();
        });
      });

      articleList.querySelectorAll('.article-approve').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = (await askText('Onay notu (opsiyonel):', 'Onay notunu yazin')) || null;
          const response = await fetch(`/api/admin/articles/${btn.dataset.id}/approve`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ comment }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Onay islemi basarisiz', 'error');
            return;
          }
          showToast('Onay islemi kaydedildi.', 'success');
          loadArticles();
          loadNotifications();
          loadStats();
        });
      });

      articleList.querySelectorAll('.article-reject').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const comment = (await askText('Red sebebi (opsiyonel):', 'Red nedenini yazin')) || null;
          const response = await fetch(`/api/admin/articles/${btn.dataset.id}/reject`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ comment }),
          });
          const payload = await response.json();
          if (!response.ok || !payload.success) {
            showToast(payload.error || 'Red islemi basarisiz', 'error');
            return;
          }
          showToast('Red islemi kaydedildi.', 'success');
          loadArticles();
          loadNotifications();
          loadStats();
        });
      });

      articleList.querySelectorAll('.article-edit').forEach((btn) => {
        btn.addEventListener('click', () => {
          const article = json.data.find((row) => Number(row.id) === Number(btn.dataset.id));
          if (!article) return;
          articleModalTitle.textContent = 'Yaziyi Duzenle';
          articleForm.elements.id.value = article.id;
          articleForm.elements.title.value = article.title || '';
          articleForm.elements.image_url.value = article.image_url || '';
          articleForm.elements.slug.value = article.slug || '';
          articleForm.elements.category.value = article.category || '';
          articleForm.elements.status.value = article.status === 'published' ? 'pending_approval' : article.status || 'draft';
          articleForm.elements.excerpt.value = article.excerpt || '';
          articleForm.elements.body.value = article.body || '';
          openModal(articleModal);
        });
      });

      articleList.querySelectorAll('.article-del').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const confirmed = await askConfirm('Bu yaziyi silmek istiyor musun?');
          if (!confirmed) return;
          const reason = await askText('Silinme sebebi:', 'Sebep yazin');
          if (!reason || !reason.trim()) {
            showToast('Silinme sebebi zorunlu.', 'warning');
            return;
          }
          await fetch('/api/admin/articles', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: Number(btn.dataset.id), reason: reason.trim() }),
          });
          showToast('Yazi listeden kaldirildi.', 'success');
          loadArticles();
          loadStats();
          loadNotifications();
        });
      });
    }

    articleAddBtn?.addEventListener('click', () => {
      articleModalTitle.textContent = 'Yeni Yazi';
      articleForm.reset();
      articleForm.elements.id.value = '';
      articleForm.elements.status.value = 'pending_approval';
      openModal(articleModal);
    });

    function closeArticleModal() {
      closeModal(articleModal);
    }

    articleModalClose?.addEventListener('click', closeArticleModal);
    articleModalCancel?.addEventListener('click', closeArticleModal);

    articleForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const payload = {
        id: articleForm.elements.id.value ? Number(articleForm.elements.id.value) : undefined,
        title: articleForm.elements.title.value,
        image_url: articleForm.elements.image_url.value,
        slug: articleForm.elements.slug.value,
        category: articleForm.elements.category.value,
        status: articleForm.elements.status.value,
        excerpt: articleForm.elements.excerpt.value,
        body: articleForm.elements.body.value,
      };

      const res = await fetch('/api/admin/articles', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (!res.ok || !json.success) {
        showToast(json.error || 'Yazi kaydedilemedi', 'error');
        return;
      }
      showToast('Yazi kaydedildi.', 'success');
      closeArticleModal();
      loadArticles();
      loadStats();
    });

    [articleModal].forEach((node) => {
      node?.addEventListener('click', (event) => {
        if (event.target === node) closeModal(node);
      });
    });

    passwordOpenBtn?.addEventListener('click', () => {
      passwordForm?.reset();
      setPasswordFeedback('');
      syncPasswordValidation();
      openModal(passwordModal);
    });
    passwordCloseBtn?.addEventListener('click', () => closeModal(passwordModal));
    passwordModal?.addEventListener('click', (event) => {
      if (event.target === passwordModal) closeModal(passwordModal);
    });

    passwordCurrentInput?.addEventListener('input', syncPasswordValidation);
    passwordNewInput?.addEventListener('input', syncPasswordValidation);
    passwordConfirmInput?.addEventListener('input', syncPasswordValidation);

    passwordForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const { strong, match, oldReuse } = syncPasswordValidation();
      if (!strong || !match || oldReuse) {
        showToast('Lutfen sifre kurallarini duzelt.', 'warning');
        return;
      }
      passwordSubmitBtn.disabled = true;
      try {
        const response = await fetch('/api/auth/change-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            currentPassword: passwordCurrentInput.value,
            newPassword: passwordNewInput.value,
            confirmPassword: passwordConfirmInput.value,
          }),
        });
        const payload = await response.json();
        if (!response.ok || !payload.success) {
          setPasswordFeedback(payload.error || 'Sifre guncellenemedi');
          showToast(payload.error || 'Sifre guncellenemedi', 'error');
          return;
        }
        setPasswordFeedback('Sifre guncellendi.', 'success');
        showToast('Sifre basariyla guncellendi.', 'success');
        window.setTimeout(() => {
          setPasswordFeedback('');
          closeModal(passwordModal);
        }, 900);
      } catch {
        setPasswordFeedback('Sifre guncellenirken baglanti hatasi olustu.');
        showToast('Sifre guncellenirken baglanti hatasi olustu.', 'error');
      } finally {
        passwordSubmitBtn.disabled = false;
      }
    });

    bootAdminPanel().then(() => {
      if (!currentAdmin) return;
      loadStats();
      loadArticles();
      loadNotifications();
    });
  </script>
</MainLayout>
