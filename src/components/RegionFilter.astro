// Sort by name
const sortedRegions = [...regions].sort((a, b) => a.name.localeCompare(b.name, 'tr'));
---

<select
  id={id}
  name={id}
  class="px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-transparent text-gray-900 bg-white hover:border-gray-400 transition"
>
  <option value="">{placeholder}</option>
  {sortedRegions.map((region) => (
    <option value={region.id} selected={region.id === selectedId}>
      {region.name}
    </option>
  ))}
</select>

<script>
  // Optional: Add filtering functionality
  window.getSelectedRegion = (selectId: string) => {
    const select = document.getElementById(selectId) as HTMLSelectElement;
    return {
      id: parseInt(select.value),
      name: select.options[select.selectedIndex].text,
    };
  };
</script>
