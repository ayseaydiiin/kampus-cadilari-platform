---
/**
 * Modal Component
 * Usage:
 *   <Modal id="confirmModal" title="Onayla" onConfirm="handleConfirm">
 *     <p>Bu işlemi yapmak istediğinizden emin misiniz?</p>
 *   </Modal>
 */
interface Props {
  id: string;
  title: string;
  confirmText?: string;
  cancelText?: string;
  onConfirm?: string;
  onCancel?: string;
}

const {
  id,
  title,
  confirmText = 'Onayla',
  cancelText = 'İptal',
  onConfirm,
  onCancel,
} = Astro.props as Props;
---

<div id={id} class="modal hidden fixed inset-0 z-50 flex items-center justify-center">
  <!-- Backdrop -->
  <div
    class="modal-backdrop absolute inset-0 bg-black bg-opacity-50"
    onclick={`document.getElementById('${id}').classList.add('hidden')`}
  ></div>
  
  <!-- Modal content -->
  <div class="modal-content bg-white rounded-lg shadow-xl max-w-md w-full mx-4 relative z-10">
    <!-- Header -->
    <div class="border-b px-6 py-4">
      <h2 class="text-xl font-semibold text-gray-900">{title}</h2>
    </div>
    
    <!-- Body -->
    <div class="px-6 py-4">
      <slot />
    </div>
    
    <!-- Footer -->
    <div class="border-t px-6 py-4 flex gap-3 justify-end">
      <button
        class="px-4 py-2 text-gray-700 bg-gray-100 rounded hover:bg-gray-200 transition"
        onclick={`document.getElementById('${id}').classList.add('hidden'); ${onCancel || ''}`}
      >
        {cancelText}
      </button>
      <button
        class="px-4 py-2 bg-purple-600 text-white rounded hover:bg-purple-700 transition"
        onclick={`document.getElementById('${id}').classList.add('hidden'); ${onConfirm || ''}`}
      >
        {confirmText}
      </button>
    </div>
  </div>
</div>

<!-- Utility styles -->
<style>
  .modal.hidden {
    display: none;
  }

  .modal {
    animation: fadeIn 0.2s ease-in-out;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>

<script define:vars={{ id }}>
  // Expose show/hide methods
  window.showModal = (modalId) => {
    document.getElementById(modalId)?.classList.remove('hidden');
  };

  window.hideModal = (modalId) => {
    document.getElementById(modalId)?.classList.add('hidden');
  };
</script>
