---
// src/components/LanguageSwitcher.astro
interface Props {
  currentLang?: 'tr' | 'en';
}

const { currentLang = 'tr' } = Astro.props;
---

<div class="fixed top-4 right-4 z-50 flex gap-2">
  <a 
    href="/" 
    class={`px-3 py-2 rounded font-semibold transition ${
      currentLang === 'tr' 
        ? 'bg-purple-600 text-white' 
        : 'bg-gray-200 text-gray-700 hover:bg-gray-300'
    }`}
    title="Türkçe"
  >
    🇹🇷 TR
  </a>
  <a 
    href="/en/" 
    class={`px-3 py-2 rounded font-semibold transition ${
      currentLang === 'en' 
        ? 'bg-purple-600 text-white' 
        : 'bg-gray-200 text-gray-700 hover:bg-gray-300'
    }`}
    title="English"
  >
    🇬🇧 EN
  </a>
</div>
