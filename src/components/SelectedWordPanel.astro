---
interface FeministWord {
  word: string;
}

interface Props {
  initialWord: FeministWord;
}

const { initialWord } = Astro.props as Props;

function normalizeWord(value: string) {
  return String(value || '')
    .replace(/([a-z])([A-Z])/g, '$1 $2')
    .replace(/\s+/g, ' ')
    .trim();
}

const displayWord = normalizeWord(initialWord?.word || 'Guvenli Alan') || 'Guvenli Alan';
---

<aside id="selected-word-panel" class="rounded-[1.5rem] border border-white/30 bg-white/12 p-6 text-white shadow-[0_18px_44px_-26px_rgba(15,23,42,0.6)] backdrop-blur md:p-7">
  <p class="text-xs font-bold uppercase tracking-[0.2em] text-fuchsia-100">Feminist Sozluk</p>
  <h3 class="mt-3 text-4xl font-black leading-tight text-white">{displayWord}</h3>
  <p class="mt-3 text-base font-medium leading-7 text-white/95">Siddetsiz ve kapsayici ortak mekan.</p>
</aside>
