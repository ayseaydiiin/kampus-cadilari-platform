---
/**
 * Toast Notification Component
 * Usage:
 *   <Toast id="successToast" type="success" message="Başarılı!" />
 * 
 * Types: success | error | warning | info
 */
interface Props {
  id: string;
  type?: 'success' | 'error' | 'warning' | 'info';
  message?: string;
  duration?: number;
}

const {
  id,
  type = 'info',
  message = '',
  duration = 3000,
} = Astro.props as Props;

const colors = {
  success: 'bg-green-500',
  error: 'bg-red-500',
  warning: 'bg-yellow-500',
  info: 'bg-blue-500',
};

const icons = {
  success: '✅',
  error: '❌',
  warning: '⚠️',
  info: 'ℹ️',
};
---

<div
  id={id}
  class={`toast fixed bottom-4 right-4 ${colors[type]} text-white px-4 py-3 rounded-lg shadow-lg flex items-center gap-3 hidden z-40 max-w-md animate-slide-in`}
>
  <span class="text-xl">{icons[type]}</span>
  <span id={`${id}-message`} class="flex-1">{message}</span>
  <button
    class="text-white hover:opacity-80 transition"
    onclick={`document.getElementById('${id}').classList.add('hidden')`}
  >
    ✕
  </button>
</div>

<style>
  .toast.hidden {
    display: none;
  }

  .toast {
    animation: slideIn 0.3s ease-in-out;
  }

  @keyframes slideIn {
    from {
      transform: translateX(400px);
      opacity: 0;
    }
    to {
      transform: translateX(0);
      opacity: 1;
    }
  }
</style>

<script define:vars={{ id, duration }}>
  // Expose toast methods
  window.showToast = (toastId, message) => {
    const toast = document.getElementById(toastId);
    if (toast) {
      document.getElementById(toastId + '-message').textContent = message;
      toast.classList.remove('hidden');
      
      // Auto-hide after duration
      setTimeout(() => {
        toast.classList.add('hidden');
      }, duration);
    }
  };

  window.hideToast = (toastId) => {
    document.getElementById(toastId)?.classList.add('hidden');
  };
</script>
