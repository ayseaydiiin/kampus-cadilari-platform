---
interface Props {
  locale?: 'tr' | 'en';
  panelId?: string;
  listId?: string;
  closeButtonId?: string;
  markAllButtonId?: string;
  deleteSelectedButtonId?: string;
}

const {
  locale = 'tr',
  panelId = 'notif-panel',
  listId = 'notif-list',
  closeButtonId = 'notif-close-btn',
  markAllButtonId = 'notif-mark-all-btn',
  deleteSelectedButtonId = 'notif-delete-selected-btn',
} = Astro.props as Props;

const isEn = locale === 'en';
---

<aside id={panelId} class="fixed right-4 top-20 z-50 hidden w-[min(92vw,26rem)] rounded-2xl border border-gray-200 bg-white p-4 shadow-2xl">
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-lg font-black text-gray-900">{isEn ? 'Admin Notifications' : 'Admin Bildirimleri'}</h2>
    <button id={closeButtonId} class="rounded-full bg-gray-100 px-3 py-1 text-xs font-bold text-gray-600 transition hover:bg-gray-200">
      {isEn ? 'Close' : 'Kapat'}
    </button>
  </div>
  <div class="mb-3 flex flex-wrap gap-2">
    <button id={markAllButtonId} class="rounded-lg bg-purple-100 px-3 py-1.5 text-xs font-bold text-purple-800 transition hover:bg-purple-200">
      {isEn ? 'Mark all as read' : 'Tumunu okundu yap'}
    </button>
    <button id={deleteSelectedButtonId} class="rounded-lg bg-rose-100 px-3 py-1.5 text-xs font-bold text-rose-800 transition hover:bg-rose-200">
      {isEn ? 'Select and delete' : 'Sec ve sil'}
    </button>
  </div>
  <div id={listId} class="max-h-[min(70vh,34rem)] space-y-2 overflow-auto"></div>
</aside>
