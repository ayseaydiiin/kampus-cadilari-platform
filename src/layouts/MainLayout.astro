---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
  currentLang?: 'tr' | 'en';
}

const { title, description, currentLang = 'tr' } = Astro.props;
const isEn = currentLang === 'en';

const siteName = 'Kampüs Cadıları';
const tagline = isEn ? 'FEMINIST SOLIDARITY NETWORK' : 'FEMINIST DAYANIŞMA AĞI';
const resolvedTitle = title || siteName;
const resolvedDescription = description || (isEn ? 'Strong women, strong future' : 'Guclu kadinlar, guclu gelecek');
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={resolvedDescription} />
    <title>{resolvedTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-light text-slate-dark" data-lang={currentLang}>
    <LanguageSwitcher currentLang={currentLang} />

    <div class="flex min-h-screen flex-col">
      <header class="sticky top-0 z-40 border-b border-[rgba(123,55,148,0.16)] bg-[rgba(255,250,247,0.94)] shadow-lg backdrop-blur-md">
        <div class="container mx-auto px-4">
          <div class="hidden items-center justify-end gap-4 border-b border-[rgba(123,55,148,0.12)] py-2 text-[11px] font-semibold uppercase tracking-wide text-slate-600 md:flex">
            <a href="https://www.instagram.com/kampus.cadilari/" target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-purple-primary)]">Instagram</a>
            <a href="https://x.com/kamps_cadilari" target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-purple-primary)]">Twitter</a>
            <a href="https://www.youtube.com/@kampuscadilari" target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-purple-primary)]">YouTube</a>
            <a href="https://www.tiktok.com/@kampuscadilari?_r=1&_t=ZS-94SwjFYpEGL" target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-purple-primary)]">TikTok</a>
            <a href="https://t.me/kampuscadilari" target="_blank" rel="noreferrer" class="transition hover:text-[var(--color-purple-primary)]">Telegram</a>
          </div>
          <nav class="flex items-center justify-between py-4">
            <a href={isEn ? '/en/' : '/'} class="group flex items-center gap-3 transition hover:opacity-80">
              <img src="/logo-kampus-cadilari.svg" alt="Kampüs Cadıları logosu" class="h-14 w-14 rounded-2xl bg-white/70 p-1.5 shadow-md ring-1 ring-[rgba(123,55,148,0.12)]" />
              <div class="min-w-0">
                <h1 class="max-w-[11.5rem] truncate text-2xl font-black leading-tight text-[var(--color-purple-primary)] sm:max-w-none sm:text-3xl md:text-4xl">{siteName}</h1>
                <p class="hidden text-xs font-bold text-[var(--color-red-accent)] sm:block">{tagline}</p>
              </div>
            </a>

            <ul class="hidden gap-8 text-sm font-bold uppercase tracking-wide lg:flex">
              <li><a href={isEn ? '/en/archive' : '/archive'} class="text-gray-700 transition hover:text-purple-600">{isEn ? 'Archive' : 'İsyan Kayıtları'}</a></li>
              <li><a href={isEn ? '/en/#perspective-section' : '/#perspektif-section'} class="text-gray-700 transition hover:text-purple-600">{isEn ? 'Perspective' : 'Cadı Merceği'}</a></li>
              <li><a href={isEn ? '/en/articles' : '/articles'} class="text-gray-700 transition hover:text-purple-600">{isEn ? 'Articles' : 'Kazandan Taşanlar'}</a></li>
              <li><a href={isEn ? '/en/map' : '/map'} class="text-gray-700 transition hover:text-purple-600">{isEn ? 'Join Us' : 'Cadıol'}</a></li>
            </ul>

            <div class="flex items-center gap-3">
              <div id="theme-toggle-container" class="relative inline-flex items-center rounded-full bg-gray-200 p-1">
                <button id="theme-toggle" class="theme-toggle-btn flex items-center gap-2 rounded-full px-3 py-1.5 text-sm font-semibold transition-all" title={isEn ? 'Change theme' : 'Temayi degistir'}>
                  <span id="theme-icon" class="inline-flex h-4 w-4 items-center justify-center" aria-hidden="true"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg></span>
                  <span id="theme-label" class="hidden sm:inline">{isEn ? 'Light' : 'Acik'}</span>
                </button>
              </div>
              <a href={isEn ? '/en/admin/' : '/admin/'} class="hidden rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 px-4 py-2 text-sm font-bold text-white transition hover:shadow-lg md:block">
                ADMIN
              </a>
              <button class="text-2xl text-purple-600 lg:hidden" id="menu-toggle" aria-label={isEn ? 'Menu' : 'Menu'}>=</button>
            </div>
          </nav>

          <div class="flex gap-2 overflow-x-auto pb-3 lg:hidden">
            <a href={isEn ? '/en/archive' : '/archive'} class="shrink-0 rounded-full border border-purple-200 bg-white px-3 py-1.5 text-xs font-bold text-purple-700">{isEn ? 'Archive' : 'İsyan Kayıtları'}</a>
            <a href={isEn ? '/en/#perspective-section' : '/#perspektif-section'} class="shrink-0 rounded-full border border-purple-200 bg-white px-3 py-1.5 text-xs font-bold text-purple-700">{isEn ? 'Perspective' : 'Cadı Merceği'}</a>
            <a href={isEn ? '/en/articles' : '/articles'} class="shrink-0 rounded-full border border-purple-200 bg-white px-3 py-1.5 text-xs font-bold text-purple-700">{isEn ? 'Articles' : 'Kazandan Taşanlar'}</a>
            <a href={isEn ? '/en/map' : '/map'} class="shrink-0 rounded-full border border-purple-200 bg-white px-3 py-1.5 text-xs font-bold text-purple-700">{isEn ? 'Join Us' : 'Cadıol'}</a>
          </div>

          <nav id="mobile-menu" class="hidden flex-col gap-3 border-t border-gray-200 pb-4">
            <a href={isEn ? '/en/archive' : '/archive'} class="rounded px-4 py-2 hover:bg-purple-50">{isEn ? 'Archive' : 'İsyan Kayıtları'}</a>
            <a href={isEn ? '/en/#perspective-section' : '/#perspektif-section'} class="rounded px-4 py-2 hover:bg-purple-50">{isEn ? 'Perspective' : 'Cadı Merceği'}</a>
            <a href={isEn ? '/en/articles' : '/articles'} class="rounded px-4 py-2 hover:bg-purple-50">{isEn ? 'Articles' : 'Kazandan Taşanlar'}</a>
            <a href={isEn ? '/en/map' : '/map'} class="rounded px-4 py-2 hover:bg-purple-50">{isEn ? 'Join Us' : 'Cadıol'}</a>
            <a href={isEn ? '/en/admin/' : '/admin/'} class="rounded bg-purple-600 px-4 py-2 font-bold text-white">Admin</a>
          </nav>
        </div>
      </header>

      <main class="container mx-auto flex-grow px-4 py-8 md:py-12">
        <slot />
      </main>

      <footer class="mt-16 bg-gradient-to-r from-purple-600 via-purple-700 to-pink-600 py-12 text-white md:py-16">
        <div class="container mx-auto px-4">
          <div class="mb-8 grid grid-cols-1 gap-8 md:grid-cols-4">
            <div>
              <h3 class="text-lg font-black">{siteName}</h3>
              <p class="mt-4 text-sm opacity-90">
                {isEn
                  ? 'Feminist resistance voice from campuses to the streets. Strong women, strong future.'
                  : 'Kampüslerden sokaklara feminist direnişin sesi. Güçlü kadınlar, güçlü gelecek.'}
              </p>
              <p class="mt-3 text-xs opacity-75">EST. 2018</p>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{isEn ? 'Pages' : 'Sayfalar'}</h4>
              <ul class="space-y-2 text-sm opacity-90">
                <li><a href={isEn ? '/en/archive' : '/archive'} class="hover:underline">{isEn ? 'Archive' : 'İsyan Kayıtları'}</a></li>
                <li><a href={isEn ? '/en/#perspective-section' : '/#perspektif-section'} class="hover:underline">{isEn ? 'Perspective' : 'Cadı Merceği'}</a></li>
                <li><a href={isEn ? '/en/articles' : '/articles'} class="hover:underline">{isEn ? 'Articles' : 'Kazandan Taşanlar'}</a></li>
                <li><a href={isEn ? '/en/map' : '/map'} class="hover:underline">{isEn ? 'Join Us' : 'Cadıol'}</a></li>
                <li><a href={isEn ? '/en/admin/login-email' : '/admin/login-email'} class="hover:underline">{isEn ? 'Admin Login' : 'Admin Giris'}</a></li>
              </ul>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{isEn ? 'Contact' : 'Iletisim'}</h4>
              <ul class="space-y-2 text-sm opacity-90">
                <li><a href="https://www.instagram.com/kampus.cadilari/" target="_blank" rel="noreferrer" class="hover:underline">Instagram</a></li>
                <li><a href="https://x.com/kamps_cadilari" target="_blank" rel="noreferrer" class="hover:underline">Twitter</a></li>
                <li><a href="https://www.youtube.com/@kampuscadilari" target="_blank" rel="noreferrer" class="hover:underline">YouTube</a></li>
                <li><a href="https://www.tiktok.com/@kampuscadilari?_r=1&_t=ZS-94SwjFYpEGL" target="_blank" rel="noreferrer" class="hover:underline">TikTok</a></li>
                <li><a href="https://t.me/kampuscadilari" target="_blank" rel="noreferrer" class="hover:underline">Telegram</a></li>
              </ul>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{isEn ? 'Values' : 'Degerler'}</h4>
              <p class="text-xs opacity-90">
                <strong>{isEn ? 'Freedom' : 'Ozgurluk'}</strong> | <strong>{isEn ? 'Solidarity' : 'Dayanisma'}</strong> | <strong>{isEn ? 'Struggle' : 'Mucadele'}</strong>
              </p>
              <p class="mt-4 text-xs opacity-75">{isEn ? 'Built with feminist solidarity.' : 'Feminist dayanışma ile inşa edildi.'}</p>
            </div>
          </div>

          <div class="border-t border-purple-400 pt-6 text-center">
            <p class="text-sm opacity-75">
              &copy; {year} {siteName}. {isEn ? 'All rights reserved.' : 'Tüm hakları saklıdır.'} |
              <a href={isEn ? '/en/privacy' : '/privacy'} class="hover:underline">{isEn ? 'Privacy' : 'Gizlilik'}</a> |
              <a href={isEn ? '/en/terms' : '/terms'} class="hover:underline">{isEn ? 'Terms' : 'Şartlar'}</a>
            </p>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      const themeLabel = document.getElementById('theme-label');
      const themeContainer = document.getElementById('theme-toggle-container');
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');
      const isEnglish = document.documentElement.lang === 'en';
      const sunIcon = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path></svg>';
      const moonIcon = '<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a8.7 8.7 0 1 0 9 9A7 7 0 0 1 12 3z"></path></svg>';

      function updateThemeUI(isDark) {
        if (themeIcon) {
          themeIcon.innerHTML = isDark ? moonIcon : sunIcon;
        }
        if (themeLabel) {
          themeLabel.textContent = isDark ? (isEnglish ? 'Dark' : 'Koyu') : (isEnglish ? 'Light' : 'Acik');
        }
        if (themeToggle) {
          themeToggle.title = isEnglish ? 'Change theme' : 'Temayi degistir';
        }
        if (themeContainer && themeToggle) {
          if (isDark) {
            themeContainer.classList.remove('bg-gray-200');
            themeContainer.classList.add('bg-gray-700');
            themeToggle.classList.remove('bg-white', 'text-yellow-600');
            themeToggle.classList.add('bg-yellow-500', 'text-white', 'ml-auto');
          } else {
            themeContainer.classList.remove('bg-gray-700');
            themeContainer.classList.add('bg-gray-200');
            themeToggle.classList.remove('bg-yellow-500', 'text-white', 'ml-auto');
            themeToggle.classList.add('bg-white', 'text-yellow-600');
          }
        }
      }

      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = savedTheme ? savedTheme === 'dark' : prefersDark;

      if (isDark) {
        document.body.classList.add('dark-mode');
      }
      updateThemeUI(isDark);

      themeToggle?.addEventListener('click', () => {
        const currentlyDark = document.body.classList.contains('dark-mode');
        document.body.classList.toggle('dark-mode', !currentlyDark);
        updateThemeUI(!currentlyDark);
        localStorage.setItem('theme', !currentlyDark ? 'dark' : 'light');
      });

      menuToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        mobileMenu?.classList.toggle('flex');
      });

      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
        });
      });
    </script>
  </body>
</html>

