---
import '../styles/global.css';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';

interface Props {
  title?: string;
  description?: string;
  currentLang?: 'tr' | 'en';
}

const { title = 'Kampus Cadilari', description = 'Guclu kadinlar, guclu gelecek', currentLang = 'tr' } = Astro.props;
---

<!DOCTYPE html>
<html lang={currentLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="bg-slate-light text-slate-dark">
    <LanguageSwitcher currentLang={currentLang} />

    <div class="flex min-h-screen flex-col">
      <header class="sticky top-0 z-40 border-b-2 border-purple-600 bg-gradient-to-r from-white via-white to-purple-50 shadow-lg">
        <div class="container mx-auto px-4">
          <div class="hidden items-center justify-between border-b border-gray-200 py-2 text-xs md:flex">
            <nav class="flex gap-4 text-gray-600">
              <a href="https://instagram.com/kampuscadilari" target="_blank" class="hover:text-purple-600 transition">Instagram</a>
              <a href="https://twitter.com/kampuscadilari" target="_blank" class="hover:text-purple-600 transition">Twitter</a>
              <a href="mailto:contact@kampuscadilari.org" class="hover:text-purple-600 transition">Iletisim</a>
            </nav>
            <span class="text-gray-600">EST. 2018</span>
          </div>

          <nav class="flex items-center justify-between py-4">
            <a href={currentLang === 'en' ? '/en/' : '/'} class="group flex items-center gap-3 hover:opacity-80 transition">
              <span class="grid h-12 w-12 place-items-center rounded-2xl bg-gradient-to-br from-purple-700 to-pink-600 text-sm font-black text-white shadow-lg">KM</span>
              <div>
                <h1 class="hidden text-3xl font-black leading-tight text-purple-700 sm:block md:text-4xl">Kampus Cadilari</h1>
                <p class="hidden text-xs font-bold text-red-600 sm:block">GUCLU KADINLAR • GUCLU GELECEK</p>
              </div>
            </a>

            <ul class="hidden gap-8 text-sm font-bold uppercase tracking-wide lg:flex">
              <li><a href={currentLang === 'en' ? '/en/' : '/'} class="text-gray-700 transition hover:text-purple-600">{currentLang === 'en' ? 'Home' : 'Ana Sayfa'}</a></li>
              <li><a href={currentLang === 'en' ? '/en/articles' : '/articles'} class="text-gray-700 transition hover:text-purple-600">{currentLang === 'en' ? 'Articles' : 'Yazilar'}</a></li>
              <li><a href={currentLang === 'en' ? '/en/events' : '/events'} class="text-gray-700 transition hover:text-purple-600">{currentLang === 'en' ? 'Events' : 'Etkinlikler'}</a></li>
              <li><a href={currentLang === 'en' ? '/en/archive' : '/archive'} class="text-gray-700 transition hover:text-purple-600">{currentLang === 'en' ? 'Archive' : 'Arsiv'}</a></li>
              <li><a href={currentLang === 'en' ? '/en/map' : '/map'} class="text-gray-700 transition hover:text-purple-600">{currentLang === 'en' ? 'Join Us' : 'Bize Katil'}</a></li>
            </ul>

            <div class="flex items-center gap-3">
              <div id="theme-toggle-container" class="relative inline-flex items-center p-1 bg-gray-200 rounded-full">
                <button id="theme-toggle" class="theme-toggle-btn px-3 py-1.5 rounded-full transition-all font-semibold text-sm flex items-center gap-2" title="Tema değiştir">
                  <span id="theme-icon">☀️</span>
                  <span id="theme-label" class="hidden sm:inline">Açık</span>
                </button>
              </div>
              <a href="/admin/" class="hidden rounded-lg bg-gradient-to-r from-purple-600 to-pink-600 px-4 py-2 text-sm font-bold text-white transition hover:shadow-lg md:block">
                ADMIN
              </a>
              <button class="text-2xl text-purple-600 lg:hidden" id="menu-toggle" aria-label="Menu">=</button>
            </div>
          </nav>

          <nav id="mobile-menu" class="hidden flex-col gap-3 border-t border-gray-200 pb-4">
            <a href={currentLang === 'en' ? '/en/' : '/'} class="rounded px-4 py-2 hover:bg-purple-50">{currentLang === 'en' ? 'Home' : 'Ana Sayfa'}</a>
            <a href={currentLang === 'en' ? '/en/articles' : '/articles'} class="rounded px-4 py-2 hover:bg-purple-50">{currentLang === 'en' ? 'Articles' : 'Yazilar'}</a>
            <a href={currentLang === 'en' ? '/en/events' : '/events'} class="rounded px-4 py-2 hover:bg-purple-50">{currentLang === 'en' ? 'Events' : 'Etkinlikler'}</a>
            <a href={currentLang === 'en' ? '/en/archive' : '/archive'} class="rounded px-4 py-2 hover:bg-purple-50">{currentLang === 'en' ? 'Archive' : 'Arsiv'}</a>
            <a href={currentLang === 'en' ? '/en/map' : '/map'} class="rounded px-4 py-2 hover:bg-purple-50">{currentLang === 'en' ? 'Join Us' : 'Bize Katil'}</a>
            <a href="/admin/" class="rounded bg-purple-600 px-4 py-2 font-bold text-white">{currentLang === 'en' ? 'Admin' : 'Admin'}</a>
          </nav>
        </div>
      </header>

      <main class="container mx-auto flex-grow px-4 py-8 md:py-12">
        <slot />
      </main>

      <footer class="mt-16 bg-gradient-to-r from-purple-600 via-purple-700 to-pink-600 py-12 text-white md:py-16">
        <div class="container mx-auto px-4">
          <div class="mb-8 grid grid-cols-1 gap-8 md:grid-cols-4">
            <div>
              <h3 class="text-lg font-black">Kampus Cadilari</h3>
              <p class="mt-4 text-sm opacity-90">Kampuslerden sokaklara feminist direnisin sesi. Guclu kadinlar, guclu gelecek.</p>
              <p class="mt-3 text-xs opacity-75">EST. 2018</p>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{currentLang === 'en' ? 'Pages' : 'Sayfalar'}</h4>
              <ul class="space-y-2 text-sm opacity-90">
                <li><a href={currentLang === 'en' ? '/en/articles' : '/articles'} class="hover:underline">{currentLang === 'en' ? 'Articles' : 'Yazilar'}</a></li>
                <li><a href={currentLang === 'en' ? '/en/events' : '/events'} class="hover:underline">{currentLang === 'en' ? 'Events' : 'Etkinlikler'}</a></li>
                <li><a href={currentLang === 'en' ? '/en/archive' : '/archive'} class="hover:underline">{currentLang === 'en' ? 'Archive' : 'Arsiv'}</a></li>
                <li><a href={currentLang === 'en' ? '/en/map' : '/map'} class="hover:underline">{currentLang === 'en' ? 'Join Us' : 'Bize Katil'}</a></li>
                <li><a href="/admin-login" class="hover:underline">{currentLang === 'en' ? 'Admin Login' : 'Admin Giris'}</a></li>
              </ul>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{currentLang === 'en' ? 'Contact' : 'Iletisim'}</h4>
              <ul class="space-y-2 text-sm opacity-90">
                <li><a href="https://instagram.com/kampuscadilari" target="_blank" class="hover:underline">Instagram</a></li>
                <li><a href="https://twitter.com/kampuscadilari" target="_blank" class="hover:underline">Twitter</a></li>
                <li><a href="https://t.me/kampuscadilari" target="_blank" class="hover:underline">Telegram</a></li>
              </ul>
            </div>

            <div>
              <h4 class="mb-4 text-sm font-bold uppercase tracking-wide">{currentLang === 'en' ? 'Values' : 'Degerler'}</h4>
              <p class="text-xs opacity-90">
                <strong>{currentLang === 'en' ? 'Freedom' : 'Ozgurluk'}</strong> • <strong>{currentLang === 'en' ? 'Solidarity' : 'Dayanisma'}</strong> • <strong>{currentLang === 'en' ? 'Struggle' : 'Mucadele'}</strong>
              </p>
              <p class="mt-4 text-xs opacity-75">{currentLang === 'en' ? 'Built with feminist solidarity.' : 'Feminist dayanisma ile insa edildi.'}</p>
            </div>
          </div>

          <div class="border-t border-purple-400 pt-6 text-center">
            <p class="text-sm opacity-75">
              &copy; 2026 Kampus Cadilari. Tum haklari saklidir. |
              <a href="/privacy" class="hover:underline">Gizlilik</a> •
              <a href="/terms" class="hover:underline">Sartlar</a>
            </p>
          </div>
        </div>
      </footer>
    </div>

    <script>
      const themeToggle = document.getElementById('theme-toggle');
      const themeIcon = document.getElementById('theme-icon');
      const themeLabel = document.getElementById('theme-label');
      const themeContainer = document.getElementById('theme-toggle-container');
      const menuToggle = document.getElementById('menu-toggle');
      const mobileMenu = document.getElementById('mobile-menu');

      function updateThemeUI(isDark) {
        if (themeIcon) {
          themeIcon.textContent = isDark ? '🌙' : '☀️';
        }
        if (themeLabel) {
          themeLabel.textContent = isDark ? 'Koyu' : 'Açık';
        }
        if (themeContainer && themeToggle) {
          if (isDark) {
            themeContainer.classList.remove('bg-gray-200');
            themeContainer.classList.add('bg-gray-700');
            themeToggle.classList.remove('bg-white', 'text-yellow-600');
            themeToggle.classList.add('bg-yellow-500', 'text-white', 'ml-auto');
          } else {
            themeContainer.classList.remove('bg-gray-700');
            themeContainer.classList.add('bg-gray-200');
            themeToggle.classList.remove('bg-yellow-500', 'text-white', 'ml-auto');
            themeToggle.classList.add('bg-white', 'text-yellow-600');
          }
        }
      }

      // Initialize theme on page load
      const savedTheme = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const isDark = savedTheme ? savedTheme === 'dark' : prefersDark;
      
      if (isDark) {
        document.body.classList.add('dark-mode');
      }
      updateThemeUI(isDark);

      // Theme toggle handler
      themeToggle?.addEventListener('click', () => {
        const currentlyDark = document.body.classList.contains('dark-mode');
        document.body.classList.toggle('dark-mode', !currentlyDark);
        updateThemeUI(!currentlyDark);
        localStorage.setItem('theme', !currentlyDark ? 'dark' : 'light');
      });

      // Mobile menu handler
      menuToggle?.addEventListener('click', () => {
        mobileMenu?.classList.toggle('hidden');
        mobileMenu?.classList.toggle('flex');
      });

      mobileMenu?.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          mobileMenu.classList.remove('flex');
        });
      });
    </script>
  </body>
</html>
